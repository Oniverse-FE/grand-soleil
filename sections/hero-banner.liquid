<section class="relative flex flex-col h-dvh w-full overflow-hidden bg-[#101010]" id="hero-{{ section.id }}">
  <div class="flex-1 relative h-full w-full">
    {% for block in section.blocks %}
      <div
        class="hero-slide {% if forloop.first %}active{% else %}opacity-0 pointer-events-none{% endif %} absolute inset-0 flex flex-col items-center justify-center text-center transition-all duration-[1000ms] ease-in-out z-10"
        data-index="{{ forloop.index0 }}"
      >
        <div class="absolute inset-0 -z-10">
          {% if block.settings.content-media %}
            {%- liquid
              assign video_m = block.settings.content-video-mobile
              assign video_d = block.settings.content-video-desktop
            -%}
            
            {% comment %} Video Mobile {% endcomment %}
            <div class="w-full h-full lg:hidden">
              <video 
                class="hero-v-ele w-full h-full object-cover" 
                autoplay muted loop playsinline preload="auto"
                src="{{ video_m.sources[1].url | default: video_m.sources[0].url }}"
              ></video>
            </div>

            {% comment %} Video Desktop {% endcomment %}
            <div class="w-full h-full hidden lg:block">
              <video 
                class="hero-v-ele w-full h-full object-cover" 
                autoplay muted loop playsinline preload="auto"
                src="{{ video_d.sources[1].url | default: video_d.sources[0].url }}"
              ></video>
            </div>
          {% else %}
            <img src="{{ block.settings.content-image-mobile | img_url: 'master' }}" class="w-full h-full object-cover lg:hidden" alt="">
            <img src="{{ block.settings.content-image-desktop | img_url: 'master' }}" class="w-full h-full object-cover hidden lg:inline" alt="">
          {% endif %}
          <div class="absolute inset-0 bg-black/30"></div>
        </div>

        <div class="relative z-20 px-4 max-w-5xl mx-auto">
          <p class="pretitle-xs_gs pretitle-xs_gsp lg:pretitle-md_gs lg:pretitle-md_gsp mb-4 lg:mb-[20px]" style="color:{{ block.settings.content-title-color }}">
            {{ block.settings.content-subtitle }}
          </p>
          <h2 class="slide-title heading-md_gs heading-md_gsp lg:title_gs lg:title_gsp mb-10" style="color:{{ block.settings.content-title-color }}">
            {{ block.settings.content-title }}
          </h2>
          <div class="slide-actions flex flex-col md:flex-row items-center justify-center gap-[13px]">
            {% if block.settings.button_1_label != blank %}
              <a href="{{ block.settings.button_1_url }}" class="btn-hero link-lg_gs link-lg_gsp cta-blur_gs cta-blur-light_gsp w-full lg:w-fit">{{ block.settings.button_1_label }}</a>
            {% endif %}
            {% if block.settings.button_2_label != blank %}
              <a href="{{ block.settings.button_2_url }}" class="btn-hero link-lg_gs link-lg_gsp cta-border-light_gsp cta-border-light_gs w-full lg:w-fit">{{ block.settings.button_2_label }}</a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

{% comment %} PAGINAZIONE {% endcomment %}
  <div class="absolute bottom-6 lg:bottom-10 left-1/2 -translate-x-1/2 z-30 flex items-center gap-3 h-10 px-6 py-2 stepper-hero_gs stepper-hero_gsp">
    {% for block in section.blocks %}
      <button class="pagination-dot relative flex items-center justify-center p-0 bg-transparent border-none cursor-pointer" data-index="{{ forloop.index0 }}" style="width: 24px; height: 24px;">
        
      {% if template contains 'gsp' %}
        <svg class="progress-svg absolute inset-0 w-6 h-6 -rotate-90 opacity-0 transition-opacity duration-300" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="11" fill="none" stroke="rgba(40,38,36,0.2)" stroke-width="2"></circle>
          <circle class="progress-ring-fill" cx="12" cy="12" r="11" fill="none" stroke="#282624" stroke-width="2" stroke-dasharray="70" stroke-dashoffset="70" stroke-linecap="round"></circle>
        </svg>
      {% else %}
        {% comment %} Cerchio per template GS (Azzurro #4DBAFA) {% endcomment %}
        <svg class="progress-svg absolute inset-0 w-6 h-6 -rotate-90 opacity-0 transition-opacity duration-300" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="11" fill="none" stroke="rgba(201, 191, 178, 0.72)" stroke-width="2"></circle>
          <circle class="progress-ring-fill" cx="12" cy="12" r="11" fill="none" stroke="#4DBAFA" stroke-width="2" stroke-dasharray="70" stroke-dashoffset="70" stroke-linecap="round"></circle>
        </svg>
      {% endif %}

        <div class="dot-inner relative z-10 flex items-center justify-center">
          {% if block.settings.content-media %}
            <div class="media-icon text-color_gs text-color_gsp hidden">
              <svg class="w-3 h-3 fill-current icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              <svg class="w-3 h-3 fill-current icon-pause hidden" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
            </div>
          {% endif %}
          <div class="simple-dot w-2 h-2 bg-141312_gsp bg-EBEFF2_gs rounded-full"></div>
        </div>
      </button>
    {% endfor %}
  </div>
</section>

<style>
  .btn-hero { display: inline-block; padding: 16px 24px; text-align: center; min-width: 157px;}
  .hero-slide.active { opacity: 1; pointer-events: auto; }
  .pagination-dot.is-active .progress-svg { opacity: 1; }
  .pagination-dot.is-active .simple-dot { display: none; }
  .pagination-dot.is-active .media-icon { display: block; }
  .pagination-dot.is-playing .icon-play { display: none; }
  .pagination-dot.is-playing .icon-pause { display: block; }
  .progress-ring-fill { transition: stroke-dashoffset 0.1s linear; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('#hero-{{ section.id }}');
  const slides = section.querySelectorAll('.hero-slide');
  const dots = section.querySelectorAll('.pagination-dot');
  let current = 0;
  let isPaused = false;
  let animationFrame;
  let startTime;
  let pausedAt = 0;
  const IMG_DURATION = 10000;

  function updateSlide(index) {
    cancelAnimationFrame(animationFrame);
    
    dots.forEach((d, i) => {
      d.classList.remove('is-active', 'is-playing');
      d.querySelector('.progress-ring-fill').style.strokeDashoffset = 70;
      if(i === index) d.classList.add('is-active');
    });

    slides.forEach((s, i) => {
      s.classList.toggle('active', i === index);
      const videos = s.querySelectorAll('.hero-v-ele');
      videos.forEach(v => {
        v.pause();
        v.currentTime = 0;
      });
    });

    current = index;
    isPaused = false;
    pausedAt = 0;
    startTime = performance.now();

    const activeSlide = slides[current];
    const video = Array.from(activeSlide.querySelectorAll('.hero-v-ele')).find(v => v.offsetParent !== null);

    if (video) {
      dots[current].classList.add('is-playing');
      video.muted = true; // Essenziale per autoplay
      video.play().then(() => {
        const d = video.duration ? video.duration * 1000 : IMG_DURATION;
        startProgress(d);
      }).catch(() => startProgress(IMG_DURATION));
    } else {
      startProgress(IMG_DURATION);
    }
  }

  function startProgress(duration) {
    const ring = dots[current].querySelector('.progress-ring-fill');
    function animate(now) {
      if (!startTime) startTime = now;
      let elapsed = isPaused ? pausedAt : (now - startTime);
      let progress = Math.min(elapsed / duration, 1);
      ring.style.strokeDashoffset = 70 - (progress * 70);
      if (progress < 1) {
        if (!isPaused) animationFrame = requestAnimationFrame(animate);
      } else {
        updateSlide((current + 1) % slides.length);
      }
    }
    animationFrame = requestAnimationFrame(animate);
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.index);
      if (idx === current) {
        const video = Array.from(slides[current].querySelectorAll('.hero-v-ele')).find(v => v.offsetParent !== null);
        if (video) {
          if (isPaused) {
            isPaused = false;
            startTime = performance.now() - pausedAt;
            video.play();
            dot.classList.add('is-playing');
            startProgress(video.duration * 1000 || IMG_DURATION);
          } else {
            isPaused = true;
            pausedAt = performance.now() - startTime;
            video.pause();
            dot.classList.remove('is-playing');
            cancelAnimationFrame(animationFrame);
          }
        }
      } else {
        updateSlide(idx);
      }
    });
  });

  updateSlide(0);
});
</script>

{% schema %}
{
  "name": "Hero Banner",
  "blocks": [
    {
      "type": "content",
      "name": "Slide",
      "settings": [
        { "type": "checkbox", "id": "content-media", "label": "Usa Video", "default": false },
        { "type": "image_picker", "id": "content-image-mobile", "label": "Img Mobile" },
        { "type": "image_picker", "id": "content-image-desktop", "label": "Img Desktop" },
        { "type": "video", "id": "content-video-mobile", "label": "Video Mobile" },
        { "type": "video", "id": "content-video-desktop", "label": "Video Desktop" },
        { "type": "text", "id": "content-subtitle", "label": "Subtitle", "default": "Nuova Collezione" },
        { "type": "text", "id": "content-title", "label": "Titolo", "default": "Nuova Collezione" },
        { "type": "color", "id": "content-title-color", "label": "Colore Titolo", "default": "#ffffff" },
        { "type": "text", "id": "button_1_label", "label": "Btn 1", "default": "Scopri" },
        { "type": "url", "id": "button_1_url", "label": "Url 1" },
        { "type": "text", "id": "button_2_label", "label": "Btn 2", "default": "Contatti" },
        { "type": "url", "id": "button_2_url", "label": "Url 2" }
      ]
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}