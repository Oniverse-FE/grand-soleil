<div class="w-full key-padding bg_gsp" style="--padding-top-desktop: {{ section.settings.padding_top }}; --padding-bottom-desktop: {{ section.settings.padding_bottom }};  --padding-top-mobile: {{ section.settings.padding_top_mobile }};   --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }};">

  <!-- Lista box scrollabile su mobile -->
  <div id="scroll-container-{{ section.id }}" class="flex flex-col lg:hidden px-4 md:px-12 gap-2 lg:gap-4">
    {% for block in section.blocks %}
      {% case block.type %}
      {% when 'feature' %}
      <div class="w-full flex-shrink-0 h-auto p-8 gap-3 bg-[#EFECE8] rounded-[16px] items-center justify-center flex">
        <div class="subtitle_gsp text-color_gsp">
          <h6>{{ block.settings.feature-title }}</h6>
        </div>
        <div class="body-md_gsp text-color_gsp w-full">
          {{ block.settings.feature-text }}
        </div>
      </div>
      {% endcase %}
    {% endfor %}
  </div>

  {% assign total_blocks = section.blocks | size %}

  <!-- Grid su desktop -->
  <div class="hidden lg:grid px-24 gap-4"
    style="
      {% if total_blocks == 3 %}
        grid-template-columns: repeat(3, minmax(0, 1fr));
      {% else %}
        grid-template-columns: repeat(2, minmax(0, 1fr));
      {% endif %}
      grid-auto-rows: auto;
    ">
    {% for block in section.blocks %}
      {% case block.type %}
      {% when 'feature' %}
      <div class="flex flex-col h-auto p-10 gap-6 bg-[#EFECE8] rounded-[16px] items-start justify-center">
        <div class="heading-md_gsp text-color_gsp">
          <h6>{{ block.settings.feature-title }}</h6>
        </div>
        <div class="body-lg_gsp text-color_gsp w-full">
          {{ block.settings.feature-text }}
        </div>
      </div>
      {% endcase %}
    {% endfor %}
  </div>
</div>

<style>
.key-padding {
  padding-top: var(--padding-top-mobile);
  padding-bottom: var(--padding-bottom-mobile);
}

@media screen and (min-width: 768px) {
  .key-padding {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
  }
}

/* Scroll libero */
#scroll-container-{{ section.id }} {
  /* scroll-snap-type: x mandatory; rimosso */
}

#scroll-container-{{ section.id }} > * {
  
}

/* Nascondi scrollbar */
.no-scrollbar {
  -ms-overflow-style: none;  /* IE e Edge */
  scrollbar-width: none;     /* Firefox */
}
.no-scrollbar::-webkit-scrollbar {
  display: none;             /* Chrome, Safari e Opera */
}

/* Cursor durante drag */
.cursor-grabbing {
  cursor: grabbing !important;
}
</style>

<script>
(function () {
  const slider = document.getElementById('scroll-container-{{ section.id }}');
  if (!slider) return;

  const container = slider.parentElement || document;
  const prevBtn = container.querySelector('.prev-features');
  const nextBtn = container.querySelector('.next-features');

  // Calcola scrollAmount basato sulla larghezza primo elemento + gap
  const firstItem = slider.querySelector(':scope > *');
  let scrollAmount = Math.round(slider.clientWidth * 0.8);
  if (firstItem) {
    const itemWidth = firstItem.getBoundingClientRect().width;
    const gapStr = getComputedStyle(slider).gap || '0px';
    const gapPx = parseFloat(gapStr) || 0;
    scrollAmount = Math.round(itemWidth + gapPx);
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      const move = Math.min(scrollAmount, slider.scrollLeft);
      slider.scrollBy({ left: -move, behavior: 'smooth' });
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      const remainingScroll = slider.scrollWidth - slider.clientWidth - slider.scrollLeft;
      const move = Math.min(scrollAmount, remainingScroll);
      slider.scrollBy({ left: move, behavior: 'smooth' });
    });
  }

  // Drag con pointer events
  let isDown = false;
  let startX = 0;
  let scrollLeft = 0;

  slider.addEventListener('pointerdown', (e) => {
    isDown = true;
    slider.setPointerCapture(e.pointerId);
    slider.classList.add('cursor-grabbing');
    startX = e.clientX;
    scrollLeft = slider.scrollLeft;
    slider.style.userSelect = 'none';
  });

  slider.addEventListener('pointermove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const walk = e.clientX - startX;
    slider.scrollLeft = scrollLeft - walk;
  });

  const endDrag = (e) => {
    if (!isDown) return;
    isDown = false;
    try { slider.releasePointerCapture(e.pointerId); } catch {}
    slider.classList.remove('cursor-grabbing');
    slider.style.removeProperty('user-select');
  };

  slider.addEventListener('pointerup', endDrag);
  slider.addEventListener('pointercancel', endDrag);
  slider.addEventListener('pointerleave', endDrag);

  // Disabilita i bottoni se scroll agli estremi
  const updateButtons = () => {
    if (!prevBtn || !nextBtn) return;
    prevBtn.disabled = slider.scrollLeft <= 0;
    nextBtn.disabled = Math.ceil(slider.scrollLeft + slider.clientWidth) >= slider.scrollWidth - 1;
  };
  slider.addEventListener('scroll', updateButtons);
  updateButtons();

})();
</script>


{% schema %}
{
  "name": "Key features",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Space top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Space bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Space top (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Space bottom (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "name": "Feature",
      "type": "feature",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "feature-title",
          "label": "Title",
          "default": "Accoglienza"
        },
        {
          "type": "textarea",
          "id": "feature-text",
          "label": "Text",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam sagittis pulvinar nulla ac imperdiet. Curabitur ut ipsum non diam fringilla gravida."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Key feature",
      "category": "Only GSP"
    }
  ]
}
{% endschema %}