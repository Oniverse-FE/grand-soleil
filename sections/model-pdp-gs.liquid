<div class="gamma-section w-full py-12 lg:py-[80px] bg_gs bg-truffle_gsp">
  <div class="max-w-[1440px] mx-auto px-4 flex flex-col items-center">
    
    <h2 class="subtitle_gs subtitle_gsp mb-6 text-center w-full text-color_gs text-FAF9F7_gsp">
      {{ section.settings.tab_collections }}
    </h2>

    <div class="flex flex-nowrap md:flex-wrap justify-start md:justify-center gap-3 mb-8 w-full overflow-x-auto no-scrollbar pb-2">
      {% for block in section.blocks %}
        {% if block.type == 'tab' %}
          <div class="tab-gamma px-6 py-3 cursor-pointer transition-all duration-300 group whitespace-nowrap cta-border-light_gs cta-border-light_gsp" 
               data-collection-handle="{{ block.settings.tab_collection | default: '' }}">
            <span class="transition-colors">
              {{ block.settings.tab_title }}
            </span>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="relative w-full flex justify-start md:justify-center mb-10 overflow-x-auto no-scrollbar">
      <div class="relative inline-flex border-b border-gray-300 min-w-fit">
        <div class="model-names-container flex gap-8 pb-4 relative">
            </div>
        <div class="absolute bottom-0 h-[2px] bg-[#EBEFF2] transition-all duration-500 ease-in-out z-10" id="model-indicator"></div>
      </div>
    </div>

    <div class="w-full lg:max-w-[1200px] flex flex-col relative">
      <div class="relative w-full aspect-video overflow-hidden rounded-[16px] shadow-xl bg-[#D1D5DB]">
        <div class="slider-track w-full h-full relative">
          {% for block in section.blocks %}
            {% if block.type == 'tab' %}
              {% assign collection = collections[block.settings.tab_collection] %}
              {% for product in collection.products %}
                <div class="product-slide absolute inset-0 opacity-0 transition-opacity duration-500" 
                     data-collection="{{ collection.handle }}" 
                     data-collection-name="{{ collection.title }}"
                     data-collection-url="{{ collection.url }}"
                     data-title="{{ product.title }}"
                     data-url="{{ product.url }}">
                  {% if product.tags contains 'coming-soon' %}
                    <div class="absolute top-2 left-2 lg:top-4 lg:left-4 px-4 lg:px-[18px] py-2 lg:py-2.5 z-[50px] rounded-[50px] pointer-events-none link-sm_gs link-sm_gsp coming-soon_gs coming-soon_gsp">
                      {{ section.settings.label_coming_soon }}
                    </div>
                  {% endif %}

                  <img src="{{ product.featured_image | img_url: '1400x' }}" 
                       alt="{{ product.title }}" 
                       class="w-full h-full object-cover">
                </div>
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>
        <div class="hidden lg:block absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none z-20"></div>
      </div>

      <div class="lg:absolute lg:bottom-4 lg:left-4 lg:right-4 w-auto lg:p-6 flex flex-col lg:flex-row justify-between items-start lg:items-center z-30 space-y-6 lg:space-y-0 lg:bg-modelli_gs lg:bg-modelli_gsp">
        <div class="heading-sm_gs heading-sm_gsp md:heading-md_gs md:heading-md_gsp text-color_gs text-FAF9F7_gsp pt-6 lg:pt-0">
          <h3 id="current-model-name" class="heading-sm_gs heading-sm_gsp md:heading-md_gs md:heading-md_gsp text-color_gs text-FAF9F7_gsp tracking-tighter"></h3>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a href="#" id="cta-main" class="px-8 py-4 cta-blue_gs cta-truffle_gsp transition-all text-center link-lg_gs link-lg_gsp pointer-events-auto"></a>
          <a href="#" id="cta-collection" class="px-8 py-4 cta-border-light_gs cta-border-light_gsp transition-all link-lg_gs link-lg_gsp text-center pointer-events-auto"></a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.model-name {
  font-family: "Helvetica Neue", sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 22px;
  color: #EBEFF2;
  cursor: pointer;
  white-space: nowrap;
}
.product-slide.active { opacity: 1; z-index: 10; }
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
#cta-main, #cta-collection { pointer-events: auto !important; }
#model-indicator { bottom: -1px; }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const tabs = document.querySelectorAll('.tab-gamma');
  const slides = document.querySelectorAll('.product-slide');
  const modelContainer = document.querySelector('.model-names-container');
  const indicator = document.getElementById('model-indicator');
  const nameDisplay = document.getElementById('current-model-name');
  
  const ctaProduct = document.getElementById('cta-main');
  const ctaCollection = document.getElementById('cta-collection');

  function updateIndicator(element) {
    if(!element) return;
    indicator.style.width = `${element.offsetWidth}px`;
    indicator.style.left = `${element.offsetLeft}px`;
  }

  function setActiveSlide(title) {
    slides.forEach(slide => {
      if(slide.dataset.title === title) {
        slide.classList.add('active');
        nameDisplay.textContent = slide.dataset.title;
        
        const discoverLabel = `{{ section.settings.label_discover }}`;
        ctaProduct.textContent = `${discoverLabel} ${slide.dataset.title}`;
        ctaProduct.href = slide.dataset.url;
        
        ctaCollection.textContent = `${discoverLabel} ${slide.dataset.collectionName}`;
        ctaCollection.href = slide.dataset.collectionUrl;
      } else {
        slide.classList.remove('active');
      }
    });
  }

  function handleTabClick(tab) {
    const handle = tab.dataset.collectionHandle;
    tabs.forEach(t => t.classList.remove('active-chip'));
    tab.classList.add('active-chip');

    modelContainer.innerHTML = '';
    const filteredSlides = Array.from(slides).filter(s => s.dataset.collection === handle);

    filteredSlides.forEach((slide, index) => {
      const div = document.createElement('div');
      div.className = 'model-name';
      div.textContent = slide.dataset.title;
      div.onclick = () => {
        document.querySelectorAll('.model-name').forEach(m => m.classList.remove('active'));
        div.classList.add('active');
        updateIndicator(div);
        setActiveSlide(slide.dataset.title);
      };
      modelContainer.appendChild(div);
      
      if(index === 0) {
        div.classList.add('active');
        setTimeout(() => updateIndicator(div), 150);
        setActiveSlide(slide.dataset.title);
      }
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => handleTabClick(tab));
  });

  if(tabs.length > 0) handleTabClick(tabs[0]);

  window.addEventListener('resize', () => {
    const activeModel = document.querySelector('.model-name.active');
    if(activeModel) updateIndicator(activeModel);
  });
});
</script>

{% schema %}
{
  "name": "Gamma Section",
  "settings": [
    {"type": "text","id": "tab_collections","label": "Titolo Sezione","default": "Le Nostre Collezioni"},
    {"type": "text","id": "label_discover","label": "Label Discover","default": "Scopri"},
    {"type": "text","id": "label_coming_soon","label": "Testo Coming Soon","default": "Coming Soon"}
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collezione",
      "settings":[
        {"type": "text","id": "tab_title","label": "Nome Visualizzato","default": "Gamma"},
        {"type": "collection","id": "tab_collection","label": "Seleziona Collezione"}
      ]
    }
  ],
  "presets":[{"name":"Gamma Section", "category": "Only GS"}]
}
{% endschema %}