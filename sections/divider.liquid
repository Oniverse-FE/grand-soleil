<div class="divider-container-{{ section.id }} w-full">
  <div class="divider-wrapper-{{ section.id }} mx-auto w-full">
    <div class="line-element-{{ section.id }}"></div>
  </div>
</div>

<style>
  .divider-container-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .divider-wrapper-{{ section.id }} {
    /* Margini laterali personalizzabili */
    padding-left: {{ section.settings.margin_side }}px;
    padding-right: {{ section.settings.margin_side }}px;
  }

  /* Supporto per mobile: se il margine laterale è troppo grande, evita che schiacci il contenuto */
  @media screen and (max-width: 768px) {
    .divider-wrapper-{{ section.id }} {
      padding-left: 16px;
      padding-right: 16px;
    }
  }

  .line-element-{{ section.id }} {
    border-top: {{ section.settings.line_thickness }}px solid {{ section.settings.line_color }};
    width: 100%;
  }

</style>

{% schema %}
{
  "name": "Divider",
  "settings": [
    {
      "type": "header",
      "content": "Contenuto Testuale"
    },
    {
      "type": "header",
      "content": "Stile Linea"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Colore della Linea",
      "default": "#BEBEBE"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Spessore Linea",
      "default": 1
    },
    {
      "type": "header",
      "content": "Sfondo e Spazi"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore di Sfondo Sezione",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Spazio Superiore (Padding)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Spazio Inferiore (Padding)",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_side",
      "min": 0,
      "max": 400,
      "step": 8,
      "unit": "px",
      "label": "Margini Laterali (Desktop)",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "Divider",
      "category": "Common sections"
    }
  ]
}
{% endschema %}