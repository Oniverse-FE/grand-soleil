<div id="{{ section.settings.id }}" class="flex tech-padding flex-col px-4 md:px-12 lg:px-24 bg_gs bg_gsp" 
     style="--padding-top-desktop: {{ section.settings.padding_top }}; --padding-bottom-desktop: {{ section.settings.padding_bottom }}; --padding-top-mobile: {{ section.settings.padding_top_mobile }}; --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }};">
  
  <div class="flex flex-col lg:flex-row gap-10 lg:gap-0">
    
    <div class="w-full lg:w-1/2">
      <div class="heading-sm_gsp heading-sm_gs md:heading-md_gsp md:heading-md_gs text-color_gs text-color_gsp">
        {{ section.settings.tech-spec-title }}
      </div>
    </div>

    <div class="flex flex-col w-full lg:w-1/2 gap-8 lg:gap-10">
      
      <div class="flex flex-col w-full">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'tech-spec-item' %}
              <div class="tech-spec-div tech-spec_gs tech-spec_gsp" {{ block.shopify_attributes }}>
                <div class="flex pretitle-sm_gs pretitle-sm_gsp text-color_gs text-color_gsp">
                  {{ block.settings.label }}
                </div>
                <div class="flex body-lg_gs body-lg_gsp text-color_gs text-color_gsp text-left md:text-right lg:max-w-[280px]">
                  {{ block.settings.value }}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>

      <div class="flex flex-col lg:flex-row w-full gap-4 pt-6 lg:pt-8">
        {% if section.settings.brochure-visible %}
          <div class="flex w-full">
            <a href="{{ section.settings.brochure-link }}" target="_blank"
               class="tech-btn cta-blue_gs cta-truffle_gsp">
              {{ section.settings.brochure-cta-label }}
            </a>
          </div>
        {% endif %}

        {% if section.settings.info-cta-visible %}
          <div class="flex w-full">
            <a href="{{ section.settings.info-cta-link }}"
               class="tech-btn cta-border-light_gs cta-border-dark_gsp">
              {{ section.settings.info-cta-label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
.tech-spec-div {
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 16px 0px;
  align-items: flex-start;
  gap: 0;
}
.tech-padding {
  padding-top: var(--padding-top-mobile);
  padding-bottom: var(--padding-bottom-mobile);
}
@media screen and (min-width: 768px) {
  .tech-padding {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
  }
  .tech-spec-div {
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 12px 12px;
  align-items: flex-start;
  gap: 12px;
}
}
.tech-btn {
  width: 100%;
  border-radius: 50px;
  text-align: center;
  padding: 16px 24px;
  transition: all 0.3s ease;
  display: block;
}
</style>

{% schema %}
{
  "name": "Technical Spec",
  "settings": [
    { "type": "header", "content": "Section Identification" },
    { "type": "text", "id": "id", "label": "Id section", "default": "tech-spec" },
    { "type": "text", "id": "tech-spec-title", "label": "Technical specifications title", "default": "SPECIFICHE TECNICHE" },
    { "type": "header", "content": "Brochure Button" },
    { "type": "checkbox", "id": "brochure-visible", "label": "Brochure button visible", "default": true },
    { "type": "text", "id": "brochure-cta-label", "label": "Brochure CTA Label", "default": "Scarica la brochure" },
    { "type": "url", "id": "brochure-link", "label": "Link to the brochure file" },
    { "type": "header", "content": "Info CTA Button" },
    { "type": "checkbox", "id": "info-cta-visible", "label": "Info CTA button visible", "default": true },
    { "type": "text", "id": "info-cta-label", "label": "Info CTA Label", "default": "Richiedi informazioni" },
    { "type": "url", "id": "info-cta-link", "label": "Link to the info page" },
    { "type": "header", "content": "Padding & Spacing" },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Space top",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "72px", "label": "Small - 72px" },
        { "value": "128px", "label": "Medium - 128px" },
        { "value": "160px", "label": "Big - 160px" }
      ],
      "default": "72px"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Space bottom",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "72px", "label": "Small - 72px" },
        { "value": "128px", "label": "Medium - 128px" },
        { "value": "280px", "label": "Big - 280px" }
      ],
      "default": "128px"
    },
    {
      "type": "select",
      "id": "padding_top_mobile",
      "label": "Space top (mobile)",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "48px", "label": "Extra small - 48px" },
        { "value": "72px", "label": "Small - 72px" }
      ],
      "default": "48px"
    },
    {
      "type": "select",
      "id": "padding_bottom_mobile",
      "label": "Space bottom (mobile)",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "48px", "label": "Small - 48px" },
        { "value": "72px", "label": "Medium - 72px" }
      ],
      "default": "48px"
    }
  ],
  "blocks": [
    {
      "type": "tech-spec-item",
      "name": "Specifica (Riga)",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta (es: Motore)",
          "default": "Etichetta"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Valore (es: V8 Turbo)",
          "default": "Valore"
        }
      ]
    }
  ],
  "presets": [
    { 
      "name": "Technical Spec",
      "blocks": [
        { "type": "tech-spec-item" },
        { "type": "tech-spec-item" },
        { "type": "tech-spec-item" }
      ]
    }
  ]
}
{% endschema %}