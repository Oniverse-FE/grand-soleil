<div id="{{ section.settings.id }}" class="flex tech-padding flex-col px-4 md:px-12 lg:px-24 bg_gs bg_gsp" style="--padding-top-desktop: {{ section.settings.padding_top }}; --padding-bottom-desktop: {{ section.settings.padding_bottom }};  --padding-top-mobile: {{ section.settings.padding_top_mobile }};   --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }};">
  
  <div class="flex flex-col lg:flex-row gap-10 lg:gap-0">
    
    <div class="w-full lg:w-1/2">
      <div class="heading-md_gsp heading-md_gs md:heading-lg_gsp md:heading-lg_gs text-color_gs text-color_gsp">
        {{ section.settings.tech-spec-title }}
      </div>
    </div>

    <div class="flex flex-col w-full lg:w-1/2 gap-8 lg:gap-10">
      
      <div class="flex flex-col w-full">
        {% for block in section.blocks %}
          {% if block.type == 'tech-spec-block' %}
            <div class="flex flex-col w-full {% unless forloop.last %}mb-6{% endunless %}" {{ block.shopify_attributes }}>

              <div class="flex flex-col gap-2 lg:gap-3">
                {% for i in (1..30) %}
                  {% assign title_key = "tech-spec-div" | append: i | append: "-title" %}
                  {% assign text_key = "tech-spec-div" | append: i | append: "-text" %}
                  {% assign title = block.settings[title_key] %}
                  {% assign text = block.settings[text_key] %}
                  
                  {% if title != blank and text != blank %}
                    <div class="tech-spec-div tech-spec-text">
                      <div class="flex pretitle-sm_gs pretitle-sm_gsp text-color_gs text-color_gsp">{{ title }}</div>
                      <div class="flex body-lg_gs body-lg_gsp text-color_gs text-color_gsp text-right">{{ text }}</div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="flex flex-row w-full gap-4 pt-6 lg:pt-8">
        {% if section.settings.brochure-visible %}
          <div class="flex w-full">
            <a href="{{ section.settings.brochure-link }}" target="_blank"
               class="tech-btn cta-blue_gs cta-truffle_gsp">
              {{ section.settings.brochure-cta-label }}
            </a>
          </div>
        {% endif %}

        {% if section.settings.info-cta-visible %}
          <div class="flex w-full">
            <a href="{{ section.settings.info-cta-link }}"
               class="tech-btn cta-border-light_gs cta-border-dark_gsp">
              {{ section.settings.info-cta-label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
.tech-spec-div {
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 12px 16px;
  align-items: flex-start;
  gap: 32px;
  border-radius: 4px;
  background: #292929;
  margin-bottom: 2px;
}
.tech-spec-block-category {
  font-family: "aktiv-grotesk";
  font-size: 14px;
  letter-spacing: 0.05em;
  font-weight: 500;
}
.tech-spec-text { font-family: "aktiv-grotesk"; }
.tech-padding {
  padding-top: var(--padding-top-mobile);
  padding-bottom: var(--padding-bottom-mobile);
}
@media screen and (min-width: 768px) {
  .tech-padding {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
  }
}
.tech-btn {
  width: 100%;
  font-weight: 600;
  border-radius: 9999px;
  text-align: center;
  padding: 14px 28px;
  transition: all 0.3s ease;
  display: block;
  font-size: 14px;
}
.tech-btn:hover { opacity: 0.75; }
</style>

{% schema %}
{
  "name": "Technical Spec Right Col",
  "settings": [
    { "type": "header", "content": "Section Identification" },
    { "type": "text", "id": "id", "label": "Id section", "default": "tech-spec" },
    { "type": "text", "id": "tech-spec-title", "label": "Technical specifications title", "default": "SPECIFICHE TECNICHE" },
    { "type": "header", "content": "Brochure Button" },
    { "type": "checkbox", "id": "brochure-visible", "label": "Brochure button visible", "default": true },
    { "type": "text", "id": "brochure-cta-label", "label": "Brochure CTA Label", "default": "Scarica la brochure" },
    { "type": "url", "id": "brochure-link", "label": "Link to the brochure file" },
    { "type": "header", "content": "Info CTA Button" },
    { "type": "checkbox", "id": "info-cta-visible", "label": "Info CTA button visible", "default": true },
    { "type": "text", "id": "info-cta-label", "label": "Info CTA Label", "default": "Richiedi informazioni" },
    { "type": "url", "id": "info-cta-link", "label": "Link to the info page" },
    { "type": "header", "content": "Padding & Spacing" },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Space top",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "72px", "label": "Small - 72px" },
        { "value": "128px", "label": "Medium - 128px" },
        { "value": "160px", "label": "Big - 160px" }
      ],
      "default": "72px"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Space bottom",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "72px", "label": "Small - 72px" },
        { "value": "128px", "label": "Medium - 128px" },
        { "value": "280px", "label": "Big - 280px" }
      ],
      "default": "128px"
    },
    {
      "type": "select",
      "id": "padding_top_mobile",
      "label": "Space top (mobile)",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "48px", "label": "Extra small - 48px" },
        { "value": "72px", "label": "Small - 72px" }
      ],
      "default": "48px"
    },
    {
      "type": "select",
      "id": "padding_bottom_mobile",
      "label": "Space bottom (mobile)",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "48px", "label": "Small - 48px" },
        { "value": "72px", "label": "Medium - 72px" }
      ],
      "default": "48px"
    }
  ],
  "blocks": [
    {
      "type": "tech-spec-block",
      "name": "Specifiche",
      "limit": 30,
      "settings": [
        { "type": "text", "id": "tech-spec-title", "label": "Block Title (Optional)", "default": "Categoria" },
        { "type": "text", "id": "tech-spec-div1-title", "label": "Label 1" },
        { "type": "text", "id": "tech-spec-div1-text", "label": "Value 1", "default": "Valore" },
        { "type": "text", "id": "tech-spec-div2-title", "label": "Label 2" },
        { "type": "text", "id": "tech-spec-div2-text", "label": "Value 2" },
        { "type": "text", "id": "tech-spec-div3-title", "label": "Label 3" },
        { "type": "text", "id": "tech-spec-div3-text", "label": "Value 3" },
        { "type": "text", "id": "tech-spec-div4-title", "label": "Label 4" },
        { "type": "text", "id": "tech-spec-div4-text", "label": "Value 4" },
        { "type": "text", "id": "tech-spec-div5-title", "label": "Label 5" },
        { "type": "text", "id": "tech-spec-div5-text", "label": "Value 5" },
        { "type": "text", "id": "tech-spec-div6-title", "label": "Label 6" },
        { "type": "text", "id": "tech-spec-div6-text", "label": "Value 6", "default": "Valore" },
        { "type": "text", "id": "tech-spec-div7-title", "label": "Label 7" },
        { "type": "text", "id": "tech-spec-div7-text", "label": "Value 7" },
        { "type": "text", "id": "tech-spec-div8-title", "label": "Label 8" },
        { "type": "text", "id": "tech-spec-div8-text", "label": "Value 8" },
        { "type": "text", "id": "tech-spec-div9-title", "label": "Label 9" },
        { "type": "text", "id": "tech-spec-div9-text", "label": "Value 9" },
        { "type": "text", "id": "tech-spec-div10-title", "label": "Label 10" },
        { "type": "text", "id": "tech-spec-div10-text", "label": "Value 10" },
        { "type": "text", "id": "tech-spec-div11-text", "label": "Value 11", "default": "Valore" },
        { "type": "text", "id": "tech-spec-div12-title", "label": "Label 12" },
        { "type": "text", "id": "tech-spec-div12-text", "label": "Value 12" },
        { "type": "text", "id": "tech-spec-div13-title", "label": "Label 13" },
        { "type": "text", "id": "tech-spec-div13-text", "label": "Value 13" },
        { "type": "text", "id": "tech-spec-div14-title", "label": "Label 13" },
        { "type": "text", "id": "tech-spec-div14-text", "label": "Value 14" },
        { "type": "text", "id": "tech-spec-div15-title", "label": "Label 15" },
        { "type": "text", "id": "tech-spec-div15-text", "label": "Value 15" }
      ]
    }
  ],
  "presets": [
    { "name": "Technical Spec Right Col" }
  ]
}
{% endschema %}