<!-- Footer start -->
<footer class="w-full px-4 py-10 lg:px-24 md:px-12 lg:py-14 bg-slate-grey" style="background-color: #4D565A;">
    <div id="footer" class="flex flex-col gap-[2px] lg:gap-[104px]">

        <!-- Griglia principale a 12 colonne -->
        <div class="flex flex-col lg:flex-row gap-x-[16px]">

            <!-- Newsletter form: 4 colonne -->
            <div class="tk-aktiv-grotesk flex flex-col bg-transparent lg:w-4/12">
                {% for block in section.blocks %}
                    {% case block.type %}
                        {% when 'newsletter' %}
                            <div class="flex flex-col w-full  gap-6 lg:gap-10">
                                <div class="flex flex-col gap-4 lg:gap-8">
                                    <div class="flex body-semibold text-[24px] lg:text-[26px] leading-[30px] lg:leading-[32px] mb-2 lg:mb-4 text-white">
                                        {{ block.settings.newsletter-title }}
                                    </div>
                                    <div class="flex body-regular text-[14px] leading-[20px] lg:text-[16px] lg:leading-[22px] text-white">
                                        {{ block.settings.newsletter-text }}
                                    </div>
                                    <div class="flex body-regular text-[12px] leading-[18px] text-white">
                                        {{ block.settings.newsletter-fields-required }}
                                    </div>
                                    <div class="flex flex-col gap-1">
                                        <div class="flex text-xs text-[#D6CBC9]">E-mail*</div>
                                        <div id="newsletter-input-mail" class="flex w-full text-white">
                                            <input type="email" name="contact[email]" id="newsletter-mail"
                                                class="border-b-white border-b-1 font-normal text-white w-full bg-transparent body-regular text-[16px] leading-[22px] py-1"
                                                {% if block.settings.newsletter-is-required %} required
                                                placeholder="{{ block.settings.newsletter-mail-placeholder }} *" {% endif %}
                                                placeholder="{{ block.settings.newsletter-mail-placeholder }}">
                                        </div>
                                    </div>
                                </div>
                                <div class="flex body-medium">
                                    <button id="newsletter-submit" type="button" aria-label="{{ block.settings.newsletter-title }}"
                                        class="font-semibold leading-none px-7 py-3.5 rounded-4xl"
                                        style="color:{{ block.settings.newsletter-button-text-color }};background-color:{{ block.settings.newsletter-button-background-color }};">
                                        {{ block.settings.newsletter-submit-button-text }}
                                    </button>
                                </div>
                            </div>
                    {% endcase %}
                {% endfor %}
            </div>

            <!-- Gap: 2 colonne -->
            <div class="h-10 lg:h-0 lg:w-2/12"></div>

            <!-- Contenuto menu a destra: 5 colonne -->
            <div class="flex flex-row gap-6 lg:gap-32 lg:w-5/12 tk-aktiv-grotesk">

                {% for block in section.blocks %}
                    {% case block.type %}
                        {% when 'footer-menu' %}

                            <!-- Left menu -->
                            <div id="footer-menu-l" class="flex flex-col w-1/2">
                                {% for i in (1..2) %}
                                    {% assign left_menu_key = "footer-left-menu-" | append: i %}
                                    {% assign left_menu = block.settings[left_menu_key] %}
                                    <div class="flex flex-col mb-7 lg:mb-8">
                                        <div class="flex mb-4 text-[16px] leading-[22px] lg:text-[18px] lg:leading-[24px]" style="color:{{ left_menu.title-color | default: block.settings.footer-menu-title-color }};">
                                            {{ left_menu.title }}
                                        </div>
                                        {% for link in left_menu.links %}
                                            {% assign caps_key = "footer-menu-link-caps-l" | append: i %}
                                            <div class="flex mb-[12px] text-[16px] leading-[22px] lg:text-[18px] lg:leading-[24px]"
                                                 style="color:{{ block.settings.footer-menu-link-color }}; {% if block.settings[caps_key] %} text-transform: uppercase;{% endif %}">
                                                {% case link.title %}
                                                    {% when 'Instagram' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'instagram.png' | asset_url }}" alt="Instagram" class="w-4">
                                                        </div>
                                                    {% when 'YouTube' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'youtube.png' | asset_url }}" alt="Youtube" class="w-4">
                                                        </div>
                                                    {% when 'Facebook' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'facebook.png' | asset_url }}" alt="Facebook" class="w-4">
                                                        </div>
                                                    {% when 'LinkedIn' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'linkedin.png' | asset_url }}" alt="Linkedin" class="w-4">
                                                        </div>
                                                {% endcase %}
                                                {{ link.title | link_to: link.url }}
                                                {% if link.title == "Lingua" or link.title == "Language" %}
                                                    <div class="flex ml-1">
                                                        <a href="/it" aria-label="Italiano" class="flex justify-center items-center ml-1">
                                                            <img src="{{ 'it.png' | asset_url }}" alt="Italiano" class="w-4 mr-2">
                                                        </a>
                                                        <a href="/en" aria-label="English" class="flex justify-center items-center ml-1">
                                                            <img src="{{ 'en.png' | asset_url }}" alt="English" class="w-4">
                                                        </a>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>

                            <!-- Right menu -->
                            <div id="footer-menu-r" class="flex flex-col w-1/2">
                                {% for i in (1..3) %}
                                    {% assign right_menu_key = "footer-right-menu-" | append: i %}
                                    {% assign right_menu = block.settings[right_menu_key] %}
                                    <div class="flex flex-col mb-7 lg:mb-8">
                                        <div class="flex mb-4 text-[16px] leading-[22px] lg:text-[18px] lg:leading-[24px]" style="color:{{ block.settings.footer-menu-title-color }};">
                                            {{ right_menu.title }}
                                        </div>
                                        {% for link in right_menu.links %}
                                            {% assign caps_key = "footer-menu-link-caps-r" | append: i %}
                                            <div class="flex mb-[12px] text-[16px] leading-[22px] lg:text-[18px] lg:leading-[24px]"
                                                 style="color:{{ block.settings.footer-menu-link-color }}; {% if block.settings[caps_key] %} text-transform: uppercase;{% endif %}">
                                                {% case link.title %}
                                                    {% when 'Instagram' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'instagram.png' | asset_url }}" alt="Instagram" class="w-4">
                                                        </div>
                                                    {% when 'YouTube' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'youtube.png' | asset_url }}" alt="Youtube" class="w-4">
                                                        </div>
                                                    {% when 'Facebook' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'facebook.png' | asset_url }}" alt="Facebook" class="w-4">
                                                        </div>
                                                    {% when 'LinkedIn' %}
                                                        <div class="flex justify-center items-center mr-2">
                                                            <img src="{{ 'linkedin.png' | asset_url }}" alt="Linkedin" class="w-4">
                                                        </div>
                                                {% endcase %}
                                                {{ link.title | link_to: link.url }}
                                                {% if link.title == "Lingua" or link.title == "Language" %}
                                                    {%- assign current_path = request.path -%}
                                                    {%- if current_path contains '/it/' -%}
                                                        {%- assign clean_path = current_path | remove_first: '/it' -%}
                                                    {%- else -%}
                                                        {%- assign clean_path = current_path -%}
                                                    {%- endif -%}
                                                    <div class="flex ml-1">
                                                        <a href="/it{{ clean_path }}" aria-label="Italiano" class="flex justify-center items-center ml-1">
                                                            <img src="{{ 'it.png' | asset_url }}" alt="Italiano" class="w-4 mr-2">
                                                        </a>
                                                        <a href="{{ clean_path }}" aria-label="English" class="flex justify-center items-center ml-1">
                                                            <img src="{{ 'en.png' | asset_url }}" alt="English" class="w-4">
                                                        </a>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>

                    {% endcase %}
                {% endfor %}
            </div>
            <div class="h-0 lg:h-0 lg:w-1/12"></div>
        </div>

        <!-- Bottom bar -->
        <div class="flex flex-col gap-10 lg:gap-0 lg:flex-row">
            <div class="flex flex-col bg-transparent lg:w-[50.5%]">
                <a href="{{ section.settings.bar-button-url }}" aria-label="{{ section.settings.bar-button-url }}"
                    class="flex font-semibold rounded-full py-3.5 px-7 w-fit leading-none tk-aktiv-grotesk"
                    style="background-color:{% if section.settings.bar-button-bg-trasparent %}transparent{% else %}{{ section.settings.bar-button-bg-color }}{% endif %}; color:{{ section.settings.bar-button-text-color }};">
                    {{ section.settings.bar-button-text }}
                </a>
            </div>
            <div class="flex gap-32 lg:w-[49.5%] tk-aktiv-grotesk">
                <div class="flex bg-trasparent tk-aktiv-grotesk-thin md:max-w-[700px] max-w-[300px] text-white text-xs">
                    {{ section.settings.bar-text }}
                </div>
            </div>
        </div>

    </div>

    <!-- UNICO contenitore con overlay -->
    <div id="form-wrapper"
        class="fixed top-0 left-0 flex justify-center items-end md:items-center w-full h-full z-50 opacity-0 pointer-events-none transition-all duration-700 ease-out"
        style="background-color: rgba(0,0,0,0.5); backdrop-filter: blur(48px);">

        {% form 'customer', id: 'newsletter_form' %}

        <!-- Box form animato da sotto -->
        <div id="form-box-news"
             class="flex flex-col max-h-[80vh] overflow-y-auto opacity-0 translate-y-full transition-all duration-[800ms] max-w-[720px] w-full bg-white rounded-xl lg:px-10 py-8 px-4 gap-10"
             style="background-color: {{ section.settings.newsletter-form-bg-color }}; color: {{ section.settings.newsletter-form-text-color }}">

            <!-- Header con titolo e X e testo-->
            <div class="flex flex-col gap-6">
                <div class="flex justify-between">
                    <div class="body-medium text-xl">{{ section.settings.newsletter-form-title }}</div>
                    <div id="newsletter-form-close" class="cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                            stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </div>
                </div>
                <div class="text-[16px]">{{ section.settings.newsletter-form-text }}</div>
            </div>
            <!-- Input mail -->
            <div class=" flex flex-col">
                <div class="hidden lg:block flex text-xs text-[#D6CBC9]">Email*</div>
                <input type="email" id="form-newsletter-mail" name="contact[email]"
                    class="w-full bg-transparent text-sm py-3 border-b border-white" {% if
                    section.settings.newsletter-mail-is-required==true %} required placeholder="Email*" {% endif %}
                    placeholder="Email" />
            </div>

            <!-- Join choice -->
            <div class="flex flex-col text-lg gap-6">
                <label>{{ section.settings.join-label }}</label>
                <div class="flex flex-col gap-4 text-[16px]">
                    <div class="flex gap-2">
                        <input type="radio" id="join-vd" name="join_choice"
                            value="{{ section.settings.join-vd-label | escape }}"
                            class="appearance-none h-5 w-5 border-1 border-white rounded-full bg-transparent checked:bg-white transition-all duration-200">
                        <label for="join-vd">{{ section.settings.join-vd-label }}</label>
                    </div>
                    <div class="flex gap-2">
                        <input type="radio" id="join-ent" name="join_choice"
                            value="{{ section.settings.join-ent-label | escape }}"
                            class="appearance-none h-5 w-5 border-1 border-white rounded-full bg-transparent checked:bg-white transition-all duration-200">
                        <label for="join-ent">{{ section.settings.join-ent-label }}</label>
                    </div>
                </div>
            </div>

            <div class="flex text-[14px]">
                {{ section.settings.newsletter-form-required-text }}
            </div>

            <!-- Consensi -->
            <div class="flex flex-col gap-6 text-[18px]">
                <div class="flex items-center h-auto gap-4">
                    <input style="aspect-ratio:1/1" type="checkbox"
                        class="w-6 h-6 rounded-sm appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                        id="marketingConsent">
                    <label class="w-auto">
                        {{ section.settings.newsletter-markConsLabel }}
                        <u><a id="shortMarketing">{{ section.settings.newsletter-privacy-label | default: "Privacy
                                Policy" }}</a></u>
                    </label>
                </div>
                <div class="flex items-center h-auto gap-4">
                    <input style="aspect-ratio:1/1" type="checkbox"
                        class="appearance-none w-6 h-6 rounded-sm border-1 border-white bg-transparent checked:bg-white transition-all duration-200 disabled:border-[#ACACAC]"
                        id="profilingConsent" disabled>
                    <label class="text-white transition-colors duration-200" id="profilingLabel">
                        {{ section.settings.newsletter-profConsLabel }}
                        <u><a id="shortProfiling">{{ section.settings.newsletter-privacy-label | default: "Privacy
                                Policy" }}</a></u>
                    </label>
                </div>
            </div>

            <u><a href="{{ section.settings.newsletter-privacy-url.url }}">{{ section.settings.privacy_label | default:
                    "Privacy Policy" }}</a></u>

            <div class="flex body-medium justify-center tk-aktiv-grotesk">
                <button id="newsletter-form-submit"
                    aria-label="{{ section.settings.newsletter-form-submit-button-text }}" type="submit"
                    class="w-full px-7 py-3.5 rounded-4xl text-[16px] font-semibold w-[300px]"
                    style="color:{{ section.settings.newsletter-form-button-text-color }};background-color:{{ section.settings.newsletter-form-button-background-color }};">
                    {{ section.settings.newsletter-form-submit-button-text }}
                </button>
            </div>

            <!-- Hidden tags gestito dallo script -->
            <input type="hidden" id="contactTags" name="contact[tags]" value="">
        </div>
        {% endform %}
    </div>

    <div id="marketing-overlay"
        class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
        <div
            class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
            <div class="flex flex-row justify-between">
                <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.newsletter-marketing-title
                    }}</h6>
                <button id="marketing-close" aria-label="Chiudi">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                            fill="white" />
                    </svg>
                </button>
            </div>
            <div>
                {{ section.settings.newsletter-marketing-text }} <u><a
                        href="{{ section.settings.newsletter-privacy-url.url }}">{{ section.settings.privacy_label |
                        default: "Privacy Policy" }}</a></u>
            </div>
        </div>
    </div>

    <div id="profiling-overlay"
        class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
        <div
            class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
            <div class="flex justify-between">
                <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.newsletter-profiling-title
                    }}</h6>
                <button id="profiling-close" aria-label="Chiudi">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                            fill="white" />
                    </svg>
                </button>
            </div>
            <div>
                {{ section.settings.newsletter-profiling-text }} <u><a
                        href="{{ section.settings.newsletter-privacy-url.url}}">{{ section.settings.privacy_label |
                        default: "Privacy Policy" }}</a></u>
            </div>
        </div>
    </div>
    <!-- Popup nascosto -->
    <!-- Overlay -->
    <div id="newsletter-thankyou-popup" class="fixed inset-0 flex items-center justify-center z-50 hidden">
        <div
            class="flex flex-col w-full max-w-[720px] h-fit items-center justify-center bg-[#292929] text-white px-14 py-10 gap-10 rounded-xl">
            <div class="flex flex-row justify-between w-full">
                <div class="flex size-6"></div>
                <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">
                    {{ section.settings.newsletter-form-ty-title }}
                </h6>
                <button id="app-newsletter-ty-close" aria-label="Chiudi">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                            fill="white" />
                    </svg>
                </button>
            </div>
            <div class="text-center">
                {{ section.settings.newsletter-form-ty-text }}
            </div>
            <div>
                <button
                    class="w-full lg:w-[234px] py-3.5 px-7 body-semibold text-[16px] leading-[14px] bg-white text-black rounded-4xl"
                    id="app-newsletter-ty-close-btn">
                    {{ section.settings.newsletter-form-ty-btn-label }}
                </button>
            </div>
        </div>
    </div>
</footer>
<style>
    .text-disabled {
        color: #ACACAC;
        cursor: not-allowed;
    }


    #newsletter-mail::placeholder {
        color: #D6CBC9 !important;
    }

    #form-box-news::-webkit-scrollbar {
        display: none;
    }

    #form-box-news input[type="email"]:focus {
        outline: none !important;
        /* niente bordo blu default */
        border-bottom: 1px solid #F76C00 !important;
        /* bordo arancione al focus */
    }

    #newsletter-input-mail input[type="email"]:focus {
        outline: none !important;
        /* niente bordo blu default */
        border-bottom: 1px solid #F76C00 !important;
        /* bordo arancione al focus */
    }

    #form-box-news {
        -ms-overflow-style: none;
        /* IE e Edge vecchi */
        scrollbar-width: none;
        /* Firefox */
    }
</style>
<script>
    document.addEventListener("DOMContentLoaded", () => {
    const formWrapper = document.getElementById("form-wrapper");
    const formBox = document.getElementById("form-box-news");
    const submitBtn = document.getElementById("newsletter-submit");
    const submitFormBtn = document.getElementById("newsletter-form-submit");
    const formClose = document.getElementById("newsletter-form-close");
    const footer = document.getElementById("footer");
    const mail = document.getElementById("newsletter-mail");
    const formMail = document.getElementById("form-newsletter-mail");

    const shortMarketing = document.getElementById("shortMarketing");
    const marketingOverlay = document.getElementById("marketing-overlay");
    const marketingClose = document.getElementById("marketing-close");

    const shortProfiling = document.getElementById("shortProfiling");
    const profilingOverlay = document.getElementById("profiling-overlay");
    const profilingClose = document.getElementById("profiling-close");

    const marketingConsent = document.getElementById("marketingConsent");
    const profilingConsent = document.getElementById("profilingConsent");
    const profilingLabel = document.getElementById("profilingLabel");

    const hiddenTags = document.querySelector('#contactTags');
    const radios = document.querySelectorAll("input[name='join_choice']");
    const footerForm = document.getElementById('newsletter_form');

    /** ---------------------------
     * Profilazione abilitata solo se marketing è spuntato
     ---------------------------- */
    function updateProfilingState() {
        if (marketingConsent.checked) {
            profilingConsent.disabled = false;
            profilingConsent.classList.remove("cursor-not-allowed");
            profilingLabel.classList.remove("text-[#ACACAC]", "cursor-not-allowed");
            profilingLabel.classList.add("text-white");
        } else {
            profilingConsent.checked = false;
            profilingConsent.disabled = true;
            profilingConsent.classList.add("cursor-not-allowed");
            profilingLabel.classList.remove("text-white");
            profilingLabel.classList.add("text-[#ACACAC]", "cursor-not-allowed");
        }
    }
    updateProfilingState();
    marketingConsent.addEventListener("change", updateProfilingState);

    /** ---------------------------
     * Overlay marketing/profiling
     ---------------------------- */
    function openOverlay(overlay) {
        overlay.classList.remove("opacity-0", "pointer-events-none");
        overlay.classList.add("opacity-100");
        hideNewsletterForm();
    }

    function closeOverlay(overlay) {
        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0");
        showNewsletterForm();
        setTimeout(() => overlay.classList.add("pointer-events-none"), 800);
    }

    shortMarketing?.addEventListener("click", () => openOverlay(marketingOverlay));
    marketingClose?.addEventListener("click", () => closeOverlay(marketingOverlay));
    shortProfiling?.addEventListener("click", () => openOverlay(profilingOverlay));
    profilingClose?.addEventListener("click", () => closeOverlay(profilingOverlay));

    /** ---------------------------
     * Apertura/chiusura form principale con animazione COD1
     ---------------------------- */
    function showNewsletterForm() {
        // Overlay
        formWrapper.classList.remove("opacity-0", "pointer-events-none");
        formWrapper.classList.add("opacity-100");

        // Modale
        formBox.classList.remove("opacity-0", "translate-y-full");
        formBox.classList.add("opacity-100", "translate-y-0");

        // Sfondo blur
        footer?.classList.add("blur-xs");
        document.body.classList.add("overflow-hidden");
    }

    function hideNewsletterForm() {
        // Overlay
        formWrapper.classList.remove("opacity-100");
        formWrapper.classList.add("opacity-0");

        // Modale
        formBox.classList.remove("opacity-100", "translate-y-0");
        formBox.classList.add("opacity-0", "translate-y-full");

        // Sfondo blur
        footer?.classList.remove("blur-xs");
        document.body.classList.remove("overflow-hidden");

        setTimeout(() => formWrapper.classList.add("pointer-events-none"), 800);
    }

    // Chiudi popup ringraziamento
    document.getElementById("app-newsletter-ty-close").addEventListener("click", () => {
        document.getElementById("newsletter-thankyou-popup").classList.add("hidden");
        hideNewsletterForm();
    });
    document.getElementById("app-newsletter-ty-close-btn").addEventListener("click", () => {
        document.getElementById("newsletter-thankyou-popup").classList.add("hidden");
        hideNewsletterForm();
    });

    // Apertura form dal pulsante
    submitBtn?.addEventListener("click", () => {
        showNewsletterForm();
        if (mail.value !== "") {
            formMail.value = mail.value;
        }
    });

    // Chiudi form X
    formClose?.addEventListener("click", hideNewsletterForm);

    // Click esterno
    formWrapper?.addEventListener("click", (event) => {
        if (!formBox.contains(event.target)) hideNewsletterForm();
    });

    // ESC
    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") hideNewsletterForm();
    });

    /** ---------------------------
     * Invio form con AJAX + gestione tags
     ---------------------------- */
    submitFormBtn.addEventListener('click', (e) => {
        e.preventDefault();

        if (!footerForm.checkValidity()) {
            footerForm.reportValidity();
            return;
        }

        // COSTRUZIONE TAGS
        const tags = ["newsletter"];
        if (marketingConsent?.checked) tags.push("marketing");
        if (profilingConsent?.checked) tags.push("profiling");
        radios.forEach(radio => {
            if (radio.checked) tags.push(radio.value.replace(/\s+/g, "-"));
        });

        hiddenTags.value = [...new Set(tags.map(t => t.trim()))].join(",");

        // INVIO AJAX
        const footerFormData = new FormData(footerForm);

        fetch(footerForm.action, {
            method: "POST",
            body: footerFormData,
            headers: { "Accept": "application/json" },
            redirect: "follow"
        })
        .then(response => {
            if (response.ok) {
                formBox?.classList.add("hidden");
                document.getElementById("newsletter-thankyou-popup").classList.remove("hidden");
            } else {
                return response.json().then(err => {
                    console.error("Shopify error:", err);
                    alert("Error: " + JSON.stringify(err));
                });
            }
        })
        .catch(err => {
            console.error("Net error:", err);
            alert("An error has occurred");
        });
    });
});
</script>

