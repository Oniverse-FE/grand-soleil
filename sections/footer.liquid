<footer class="w-full px-4 pt-[64px] pb-6 lg:px-[128px] md:px-8 lg:pt-[64px] bg_gs bg_gsp">
    <div id="footer" class="flex flex-col gap-[64px] lg:gap-20">

        <div class="flex justify-center w-full">
            {% if template contains 'gsp' %}
                {% if section.settings.logo_gsp != blank %}
                    <img src="{{ section.settings.logo_gsp | image_url: width: 500 }}" alt="Logo Grand Soleil Yachts" class="w-full lg:max-w-[550px] h-auto object-contain">
                {% endif %}
            {% else %}
                {% if section.settings.logo_gs != blank %}
                    <img src="{{ section.settings.logo_gs | image_url: width: 500 }}" alt="Logo Grand Soleil Yachts" class="w-full lg:max-w-[550px] h-auto object-contain">
                {% endif %}
            {% endif %}
        </div>

        <div class="flex flex-col lg:flex-row gap-x-8">

            <div class="tk-aktiv-grotesk flex flex-col bg-transparent lg:w-4/12 mb-12 lg:mb-0">
                {% for block in section.blocks %}
                    {% if block.type == 'newsletter' %}
                        <div class="flex flex-col w-full gap-6 lg:gap-8">
                            <div class="flex flex-col gap-4">
                                <div class="heading-sm_gsp heading-sm_gs md:heading-md_gsp md:heading-md_gs text-color_gs text-color_gsp">
                                    {{ block.settings.newsletter-title }}
                                </div>
                                <div class="body-sm_gs body-sm_gsp md:body-lg_gs md:body-lg_gsp text-color_gs text-color_gsp">
                                    {{ block.settings.newsletter-text }}
                                </div>
                            </div>
                            <div class="flex flex-col gap-[48px]">
                                <button id="newsletter-submit" type="button" aria-label="{{ block.settings.newsletter-title }}"
                                    class="cta-blue_gs cta-truffle_gsp link-lg_gs link-lg_gsp px-6 py-4 rounded-[50px] w-full md:w-[205px]">
                                    {{ block.settings.newsletter-submit-button-text }}
                                </button>
                                {% if template contains 'gsp' %}
                                <div class="flex flex-row gap-6">
                                    <img src="{{ 'instagram_gsp.png' | asset_url }}" alt="Instagram" class="w-4 h-4 object-contain">
                                    <img src="{{ 'youtube_gsp.png' | asset_url }}" alt="Youtube" class="w-4 h-4 object-contain">
                                    <img src="{{ 'facebook_gsp.png' | asset_url }}" alt="Facebook" class="w-4 h-4 object-contain">
                                    <img src="{{ 'linkedin_gsp.png' | asset_url }}" alt="Linkedin" class="w-4 h-4 object-contain">
                                </div>
                                {% else %}
                                <div class="flex flex-row gap-6">
                                    <img src="{{ 'instagram.png' | asset_url }}" alt="Instagram" class="w-4 h-4 object-contain">
                                    <img src="{{ 'youtube.png' | asset_url }}" alt="Youtube" class="w-4 h-4 object-contain">
                                    <img src="{{ 'facebook.png' | asset_url }}" alt="Facebook" class="w-4 h-4 object-contain">
                                    <img src="{{ 'linkedin.png' | asset_url }}" alt="Linkedin" class="w-4 h-4 object-contain">
                                </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="hidden lg:block lg:w-1/12"></div>

            <div class="flex flex-col lg:flex-row lg:flex-nowrap gap-0 lg:gap-8 lg:w-7/12">
                {% for block in section.blocks %}
                    {% if block.type == 'footer-menu' %}
                        
                        {% for i in (1..3) %}
                            {% assign menu_key = 'footer-menu-' | append: i %}
                            {% assign current_menu = block.settings[menu_key] %}
                            
                            {% if current_menu != blank %}
                                <div class="footer-accordion-item w-full lg:w-1/3">
                                    <button class="footer-accordion-trigger flex justify-between items-center w-full py-3 lg:py-0 lg:mb-4 lg:cursor-default lg:pointer-events-none">
                                        <span class="pretitle-sm_gs pretitle-sm_gsp md:pretitle-md_gs md:pretitle-md_gsp text-color_gs text-color_gsp">
                                            {{ current_menu.title }}
                                        </span>
                                        <span class="lg:hidden transition-transform duration-300 accordion-icon text-color_gs text-color_gsp">
                                            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 0V14M0 7H14"/></svg>
                                        </span>
                                    </button>

                                    <div class="footer-accordion-content overflow-hidden max-h-0 lg:max-h-none transition-all duration-300 ease-in-out">
                                        <div class="pb-6 lg:pb-0 flex flex-col gap-3">
                                            {% for link in current_menu.links %}
                                                <div class="body-sm_gs body-sm_gsp md:body-md_gs md:body-md_gsp text-color_gs text-color_gsp flex items-center">
                                                    {{ link.title | link_to: link.url }}
                                                    {% if link.title == "Lingua" or link.title == "Language" %}
                                                        <div class="flex ml-3 gap-2">
                                                            <a href="/it"><img src="{{ 'it.png' | asset_url }}" class="w-4"></a>
                                                            <a href="/en"><img src="{{ 'en.png' | asset_url }}" class="w-4"></a>
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}

                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <div class="flex flex-col md:flex-row justify-between gap-4">
            <div class="caption_gs caption_gsp text-color_gs text-color_gsp">
                {{ section.settings.bar-text }}
            </div>
            {% if section.settings['footer-menu-lang'] != blank %}
                <div class="flex items-center gap-2">
                    <a href="/it"><img src="{{ 'it.png' | asset_url }}" class="w-4"></a>
                    <a href="/"><img src="{{ 'en.png' | asset_url }}" class="w-4"></a>
                </div>
            {% endif %}
        </div>
    </div>

    <div id="form-wrapper" class="fixed inset-0 flex justify-center items-end md:items-center z-[100] opacity-0 pointer-events-none transition-all duration-700" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(40px);">
        {% form 'customer', id: 'newsletter_form' %}
            <div id="form-box-news" class="bg-[#292929] text-white p-8 lg:p-12 rounded-xl max-w-2xl w-full mx-4 translate-y-20 transition-transform duration-500">
                <div class="flex justify-between mb-8">
                    <h3 class="text-2xl font-bold">{{ section.settings.newsletter-form-title }}</h3>
                    <button type="button" id="newsletter-form-close" class="text-2xl">✕</button>
                </div>
                <input type="email" name="contact[email]" id="form-newsletter-mail" class="w-full bg-transparent border-b border-white py-3 mb-8 outline-none focus:border-blue-400" placeholder="Email*">
                <button type="submit" class="w-full py-4 rounded-full font-bold transition-opacity hover:opacity-90" style="background:{{ section.settings.newsletter-form-button-background-color | default: '#fff' }}; color:{{ section.settings.newsletter-form-button-text-color | default: '#000' }};">
                    {{ section.settings.newsletter-form-submit-button-text }}
                </button>
            </div>
        {% endform %}
    </div>
</footer>

<style>
    /* Animazione rotazione icona */
    .footer-accordion-item.active .accordion-icon {
        transform: rotate(45deg);
    }

    /* Forza apertura su Desktop */
    @media (min-width: 1024px) {
        .footer-accordion-content {
            max-height: none !important;
            opacity: 1 !important;
            visibility: visible !important;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // 1. LOGICA ACCORDION MOBILE
        const accordionItems = document.querySelectorAll('.footer-accordion-item');
        
        accordionItems.forEach(item => {
            const trigger = item.querySelector('.footer-accordion-trigger');
            const content = item.querySelector('.footer-accordion-content');

            trigger.addEventListener('click', () => {
                if (window.innerWidth >= 1024) return;

                const isActive = item.classList.contains('active');
                
                // Chiudi gli altri (opzionale: commenta se vuoi che restino aperti più menu)
                accordionItems.forEach(other => {
                    other.classList.remove('active');
                    other.querySelector('.footer-accordion-content').style.maxHeight = null;
                });

                if (!isActive) {
                    item.classList.add('active');
                    content.style.maxHeight = content.scrollHeight + "px";
                }
            });
        });

        // 2. LOGICA MODALE NEWSLETTER
        const wrapper = document.getElementById("form-wrapper");
        const box = document.getElementById("form-box-news");
        const openBtn = document.getElementById("newsletter-submit");
        const closeBtn = document.getElementById("newsletter-form-close");

        openBtn?.addEventListener("click", () => {
            wrapper.classList.remove("opacity-0", "pointer-events-none");
            box.classList.remove("translate-y-20");
            document.body.style.overflow = 'hidden';
        });

        const closeModale = () => {
            wrapper.classList.add("opacity-0", "pointer-events-none");
            box.classList.add("translate-y-20");
            document.body.style.overflow = '';
        };

        closeBtn?.addEventListener("click", closeModale);
        wrapper.addEventListener("click", (e) => { if(e.target === wrapper) closeModale(); });
    });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo_gs", "label": "Logo GS" },
    { "type": "image_picker", "id": "logo_gsp", "label": "Logo GSP" },
    { "type": "text", "id": "bar-text", "label": "Footer Copyright", "default": "©2026 CANTIERE DEL PARDO S.p.A." },
    { "type": "text", "id": "newsletter-form-title", "label": "Titolo Modale", "default": "Get in touch" },
    { "type": "text", "id": "newsletter-form-submit-button-text", "label": "Bottone Modale", "default": "Subscribe" }
  ],
  "blocks": [
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "newsletter-title", "label": "Titolo", "default": "Newsletter" },
        { "type": "text", "id": "newsletter-text", "label": "Testo", "default": "Iscriviti per aggiornamenti." },
        { "type": "text", "id": "newsletter-mail-placeholder", "label": "Placeholder", "default": "E-mail" },
        { "type": "text", "id": "newsletter-submit-button-text", "label": "Testo Bottone", "default": "Iscriviti" },
        { "type": "color", "id": "newsletter-button-background-color", "label": "Sfondo Bottone", "default": "#ffffff" },
        { "type": "color", "id": "newsletter-button-text-color", "label": "Colore Testo Bottone", "default": "#000000" }
      ]
    },
    {
      "type": "footer-menu",
      "name": "Menu Footer",
      "limit": 1,
      "settings": [
        { "type": "color", "id": "footer-menu-title-color", "label": "Colore Titoli", "default": "#D6CBC9" },
        { "type": "color", "id": "footer-menu-link-color", "label": "Colore Link", "default": "#ffffff" },
        { "type": "link_list", "id": "footer-menu-1", "label": "Menu 1" },
        { "type": "link_list", "id": "footer-menu-2", "label": "Menu 2" },
        { "type": "link_list", "id": "footer-menu-3", "label": "Menu 3" }
      ]
    }
  ]
}
{% endschema %}