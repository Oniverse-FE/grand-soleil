<div class="flex flex-col px-0 py-[64px] lg:py-[128px] gap-4">
   <div class="flex items-center justify-between px-4 md:px-12 lg:px-24 pb-2">
        <!-- Titolo -->
        <h6 class="h6 text-[26px] md:text-[42px] lg:text-[42px] leading-[32px] md:leading-[48px] lg:leading-[48px] text-white uppercase">
            {{ section.settings.vdcenters-slider-title }}
        </h6>

        <!-- Frecce -->
        <div class="md:hidden lg:hidden flex gap-2 lg:gap-4">
            <button class="prev-vd-center p-2 rounded-full flex justify-center items-center bg-transparent text-white border border-white hover:bg-white/40 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3 md:size-5" viewBox="0 0 24 24" fill="none">
                    <path d="M16 4L9.41421 10.5858C8.63316 11.3668 8.63316 12.6332 9.41421 13.4142L16 20" stroke="white" stroke-linecap="round" />
                </svg>
            </button>
            <button class="next-vd-center p-2 rounded-full flex justify-center items-center bg-transparent text-white border border-white hover:bg-white/40 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-3 md:size-5" viewBox="0 0 24 24" fill="none">
                    <path d="M8 20L14.5858 13.4142C15.3668 12.6332 15.3668 11.3668 14.5858 10.5858L8 4" stroke="white" stroke-linecap="round" />
                </svg>
            </button>
        </div>
    </div>


    <!-- Slider -->
    <div id="scroll-container" class="pl-mobile pl-tablet pl-desk flex gap-4 gap-y-[32px] overflow-x-auto lg:overflow-visible md:flex-wrap lg:flex-wrap lg:justify-start pb-4 lg:pt-[32px]">
        {% for block in section.blocks %}
        {% case block.type %}
            {% when '@app' %}
            {% render block %}
            {% when 'vdcenter-card' %}
            <div class="relative flex flex-col flex-shrink-0 
                        w-[320px] sm:w-[calc(50%-0.5rem)] lg:w-[calc(50%-0.5rem)] 
                        xl:w-[32%] h-[582px] lg:h-[678px] 
                        rounded-2xl bg-antracite overflow-hidden">
                <!-- Link che copre tutta la card, ma non blocca elementi interattivi -->
                <a href="{{ block.settings.vdcenters-slider-card-more-cta-url }}" class="absolute inset-0 pointer-events-auto z-10"></a>

                <div class="flex h-[180px] lg:h-[228px] w-full relative z-20 pointer-events-none">
                    <img id="vdcenter-card-image-{{ block.id }}"
                        src="{{ block.settings.vdcenters-slider-card-image | img_url: 'master' }}"
                        alt="{{ block.settings.vdcenters-slider-card-title }}"
                        class="object-fill rounded-t-2xl w-full h-full">
                </div>

                <div class="flex flex-col px-4 lg:px-6 py-6 lg:py-8 w-full text-white flex-1 relative z-20 pointer-events-none">
                    <!-- div info -->
                    <div class="flex flex-col gap-4 flex-1">
                        <!-- title + flag -->
                        <div class="flex flex-row gap-4 justify-start w-full h-auto">
                            <div class="flex justify-center items-center">
                                <img id="vd-center-card-flag-{{ block.id }}"
                                    src="{{ block.settings.vdcenters-slider-card-flag | img_url: 'master' }}"
                                    alt="{{ block.settings.vdcenters-slider-card-flag-alt }}"
                                    class="size-4 rounded-full">
                            </div>
                            <div class="flex body-bold text-[16px] leading-[22px] lg:text-[18px] w-fit h-auto">
                                {{ block.settings.vdcenters-slider-card-title }}
                            </div>
                        </div>
                        <!-- complete address -->
                        <div class="flex flex-col gap-0 justify-start w-full h-auto body-regular text-[14px] lg:text-[16px] leading-5">
                            <div class="flex w-full">
                                {{ block.settings.vdcenters-slider-card-address }}
                            </div>
                            <div class="flex w-full">
                                {{ block.settings.vdcenters-slider-card-country }}
                            </div> 
                        </div>
                        <!-- contact -->
                        <div class="flex flex-col gap-1 justify-start w-full h-auto">
                            <div class="flex font-medium text-[14px] lg:text-[16px] uppercase text-[#D6CBC9]">
                                {{ block.settings.vdcenters-slider-card-contact-title }}
                            </div>
                            <div class="flex flex-col gap-0 justify-start w-full h-auto body-regular text-[14px] lg:text-[16px] leading-5">
                                <div class="flex w-full pointer-events-auto">
                                   {{ block.settings.vdcenters-slider-label-phone }}: <a style="margin-left:2px" href="tel:{{ block.settings.vdcenters-slider-card-phone }}">{{ block.settings.vdcenters-slider-card-phone }}</a>
                                </div>
                                <div class="flex w-full pointer-events-auto">
                                    Email: <a href="mailto:{{ block.settings.vdcenters-slider-card-mail }}">{{ block.settings.vdcenters-slider-card-mail }}</a>
                                </div> 
                            </div>
                        </div>
                    </div>

                    <!-- div buttons -->
                    <div class="flex flex-col w-full gap-3 font-semibold mt-6">
                        <div class="flex w-full pointer-events-auto">
                            <a href="{{ block.settings.vdcenters-slider-card-more-cta-url }}"
                            class="vdcenter-slider-cta {% if block.settings.vdcenters-slider-card-more-transparent %}btn-transparent{% endif %} w-full text-center rounded-4xl leading-3.5 py-3.5 px-5 lg:px-7"
                            style="{% if block.settings.vdcenters-slider-card-more-transparent != true %}background-color:{{ block.settings.vdcenters-slider-card-more-bg-color }};{% endif %}color:{{ block.settings.vdcenters-slider-card-more-color }};border: 1px solid {{ block.settings.vdcenters-slider-card-more-border-color }};backdrop-filter: blur(40px);">
                                {{ block.settings.vdcenters-slider-card-more-cta-label }}
                            </a>
                        </div>
                        <div class="flex w-full pointer-events-auto">
                            <a href="{{ block.settings.vdcenters-slider-card-maps-cta-url }}" target="_blank"
                            class="vdcenter-slider-cta {% if block.settings.vdcenters-slider-card-maps-transparent %}btn-transparent{% endif %} w-full text-center rounded-4xl leading-3.5 py-3.5 px-5 lg:px-7"
                            style="{% if block.settings.vdcenters-slider-card-maps-transparent != true %}background-color:{{ block.settings.vdcenters-slider-card-maps-bg-color }};{% endif %}color:{{ block.settings.vdcenters-slider-card-maps-color }};border: 1px solid {{ block.settings.vdcenters-slider-card-maps-border-color }};backdrop-filter: blur(40px);">
                                {{ block.settings.vdcenters-slider-card-maps-cta-label }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endcase %}
    {% endfor %}
    </div>
</div>


<style>
.pl-desk {
    padding-left: 96px;
    padding-right: 96px;
}

@media (max-width: 768px) {
    .pl-mobile {
        padding-left: 16px;
        padding-right: 16px;
    }
}
@media (min-width: 768px) and (max-width: 1024px) {
    .pl-tablet {
        padding-left: 48px;
        padding-right: 48px;
    }
}
@media (max-width: 1024px) {
    .pl-mobile {
        -ms-overflow-style: none; /* IE e Edge */
        scrollbar-width: none; /* Firefox */
    }
    .pl-mobile::-webkit-scrollbar {
        display: none; /* Chrome, Safari, Opera */
    }
}
.vdcenter-slider-cta {
  transition: all 0.3s ease;
}

.vdcenter-slider-cta:not(.btn-transparent):hover {
  opacity: 0.75;
}

.vdcenter-slider-cta.btn-transparent:hover {
  border-color: #ACACAC !important;
  background-color: #ACACAC !important;
}
/* Frecce solo mobile */
.arrows-mobile {
    display: flex;
}
@media (min-width: 768px) {
    .arrows-mobile {
        display: none;
    }
}

a[href^="tel"],
a[href^="mailto"],
a[href*="maps.google.com"] {
  text-decoration: none !important;   /* rimuove la sottolineatura */
  border-bottom: none !important;     /* sicurezza extra */
  color: inherit;                     /* mantiene il colore normale */
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const slider = document.getElementById('scroll-container');
  const prev = document.querySelector('.prev-vd-center');
  const next = document.querySelector('.next-vd-center');

  const getCardWidth = () => {
    const card = slider.querySelector('div');
    if (!card) return 300;
    const style = getComputedStyle(slider);
    const gap = parseFloat(style.gap) || 0;
    return card.offsetWidth + gap;
  };

  prev.addEventListener('click', () => {
    const move = Math.min(getCardWidth(), slider.scrollLeft);
    slider.scrollBy({ left: -move, behavior: 'smooth' });
  });

  next.addEventListener('click', () => {
    const remainingScroll = slider.scrollWidth - slider.clientWidth - slider.scrollLeft;
    const move = Math.min(getCardWidth(), remainingScroll);
    slider.scrollBy({ left: move, behavior: 'smooth' });
  });
});
</script>

{% schema %}
{
    "name": "VD Centers slider",
    "settings": [
            {
                "type": "text",
                "id": "vdcenters-slider-title",
                "label": "Title",
                "default": "Trova il tuo vandutch center"
            }
        ],
        "blocks": [
            {
                "name": "VD Center Card",
                "type": "vdcenter-card",
                "settings": [
            {
                "type": "header",
