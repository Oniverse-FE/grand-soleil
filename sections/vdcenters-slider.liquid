                "label": "Background color",
                "default": "#ffffff"
            },
            {
                "type": "color",
                "id": "vdcenters-slider-card-more-color",
                "label": "Text color",
                "default": "#000000"
            },
            {
                "type": "color",
                "id": "vdcenters-slider-card-more-border-color",
                "label": "Border color",
                "default": "#ffffff"
            },

            {
                "type": "header",
                "content": "Maps CTA"
            },
            {
                "type": "text",
                "id": "vdcenters-slider-card-maps-cta-label",
                "label": "CTA Label",
                "default": "Mostra su Google Maps"
            },
            {
                "type": "url",
                "id": "vdcenters-slider-card-maps-cta-url",
                "label": "CTA URL"
            },
            {
                "type": "checkbox",
                "id": "vdcenters-slider-card-maps-transparent",
                "label": "Background transparent",
                "default": true
            },
            {
                "type": "color",
                "id": "vdcenters-slider-card-maps-bg-color",
                "label": "Background color",
                "default": "#ffffff"
            },
            {
                "type": "color",
                "id": "vdcenters-slider-card-maps-color",
                "label": "Text color",
                "default": "#ffffff"
            },
            {
                "type": "color",
                "id": "vdcenters-slider-card-maps-border-color",
                "label": "Border color",
                "default": "#ffffff"
            }
        ]
    }
    ],
    "presets": [
        {
            "name": "VD Centers slider",
            "category" : "VD Center Sections"
        }
    ]
}
{% endschema %}