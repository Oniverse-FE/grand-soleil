            },
            {
                "type": "text",
                "id": "vdcenters-slider-card-country",
                "label": "Country",
                "default": "Sassenheim, Paesi Bassi, EU"
            },

            {
                "type": "header",
                "content": "Contact Info"
            },
            {
                "type": "text",
                "id": "vdcenters-slider-card-contact-title",
                "label": "Contact title",
                "default": "contatti"
            },
            {
                "type": "text",
                "id": "vdcenters-slider-label-phone",
                "label": "Phone label",
                "default": "Telefono"
            },
            {
                "type": "text",
                "id": "vdcenters-slider-card-phone",
                "label": "Phone",
                "default": "+31 71 200 11 47"
            },
            {
                "type": "text",
                "id": "vdcenters-slider-card-mail",
                "label": "Email",
                "default": "amsterdam@vandutch.com"
            },

            {
                "type": "header",
                "content": "Discover More CTA"
            },
            {
                "type": "text",
