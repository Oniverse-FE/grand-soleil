<div id="sailing-stories-slider-{{ section.id }}" 
     style="--pt-mob: {{ section.settings.pt_mob }}px; --pb-mob: {{ section.settings.pb_mob }}px;
            --pt-tab: {{ section.settings.pt_tab }}px; --pb-tab: {{ section.settings.pb_tab }}px;
            --pt-desk: {{ section.settings.pt_desk }}px; --pb-desk: {{ section.settings.pb_desk }}px;"
     class="sailing-padding bg_gs bg_gsp flex flex-col lg:flex-row overflow-hidden gap-[56px] lg:gap-[118px] pl-4 md:pl-10 lg:pl-[64px] xl:pl-[128px]">

  {% assign sailing_blog = blogs['sailing-stories'] %}
  {% assign total_sailing = sailing_blog.articles_count %}

  {% comment %} Colonna Testi Sinistra {% endcomment %}
  <div class="flex flex-col justify-start items-start lg:w-[35%] gap-4 z-20 bg-inherit">
      <div class="text-left flex heading-lg_gs heading-lg_gsp text-color_gs text-color_gsp">
          {{ section.settings.sailing-slider-title }}
      </div>

      {% if section.settings.content %}
      <div class="body-lg_gs body-lg_gsp text-color_gs text-color_gsp">
          {{ section.settings.content }}
      </div>
      {% endif %}
       
      {%- if section.settings.sailing-slider-cta-all-label != blank -%}
      <div class="flex flex-col gap-4 lg:flex-row mt-4">
          <a href="{{ sailing_blog.url }}"
             class="cta-all-sailing link-lg_gsp link-ld_gs text-center cta-blue_gs cta-truffle_gsp px-6 py-4">
             {{ section.settings.sailing-slider-cta-all-label }}
          </a>
      </div>
      {% endif %}
  </div>

  {% comment %} Slider sailing {% endcomment %}
  <div class="flex-1 lg:w-[65%] mb-[32px] lg:mb-[60px] relative">
    
    <div id="sailing-container-{{ section.id }}"
         class="flex flex-row gap-4 overflow-x-auto scroll-smooth px-4 lg:px-0 no-scrollbar">

      {% for article in sailing_blog.articles limit: 5 %}
          <div class="sailing-card flex-shrink-0 group relative overflow-hidden rounded-[10px] cursor-pointer shadow-lg"
               onclick="window.location.href='{{ article.url }}'">
              
              <div class="aspect-[4/5] w-full overflow-hidden">
                  {% if article.image %}
                    <img src="{{ article.image | image_url: width: 1000 }}" alt="{{ article.title }}"
                         class="w-full h-full object-cover transition-transform duration-700 ease-in-out transform group-hover:scale-110"
                         loading="lazy">
                  {% else %}
                    <div class="w-full h-full bg-neutral-800 flex items-center justify-center"></div>
                  {% endif %}
                  
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80"></div>
                  
                  <div class="absolute inset-0 p-4 md:p-[20px] flex flex-col justify-end gap-2">
                      <span class="link-md_gs link-md_gsp text-black bg-EBEFF2_gs bg_gsp px-3 py-[6px] rounded-[50px] max-w-[100px]">
                          {{ article.published_at | date: "%d.%m.%Y" }}
                      </span>
                      <h3 class="heading-sm_gs heading-sm_gsp text-color_gs text-EBEFF2_gsp">
                          {{ article.title }}
                      </h3>
                      <div class="cta-sailing-item link-lg_gs link-lg_gsp text-color_gs text-EBEFF2_gsp underline opacity-0 transform translate-y-4 transition-all duration-500 group-hover:opacity-100 group-hover:translate-y-0 mb-[20px] md:mb-0">
                         {{ section.settings.sailing-cta-label }}
                      </div>
                  </div>
              </div>
          </div>
      {% endfor %}
    </div>

    {% comment %} Footer Slider: Contatore e Frecce {% endcomment %}
    <div class="flex items-center justify-between mt-8 px-4 md:pr-10 lg:pr-[64px] xl:pr-[128px]">
        
        <div class="body-md_gs body-md_gsp text-color_gs text-color_gsp">
            <span id="current-index-{{ section.id }}">01</span> - <span>0{{ total_sailing | at_most: 5 }}</span>
        </div>

        <div class="flex gap-[14px]">
            <button id="prev-sailing-{{ section.id }}" class="arrow-btn pt-3 flex items-center justify-center disabled:opacity-20 disabled:pointer-events-none">
                {% if template contains 'gsp' %}{% render 'gs-arrow-left-black' %}{% else %}{% render 'gs-arrow-left-white' %}{% endif %}
            </button>
            <button id="next-sailing-{{ section.id }}" class="arrow-btn pb-3 flex items-center justify-center disabled:opacity-20 disabled:pointer-events-none">
                {% if template contains 'gsp' %}{% render 'gs-arrow-right-black' %}{% else %}{% render 'gs-arrow-right-white' %}{% endif %}
            </button>
        </div>
    </div>
  </div>
</div>

<style>
.sailing-padding {
    padding-top: var(--pt-mob);
    padding-bottom: var(--pb-mob);
}
@media screen and (min-width: 768px) {
    .sailing-padding {
        padding-top: var(--pt-tab);
        padding-bottom: var(--pb-tab);
    }
}
@media screen and (min-width: 1024px) {
    .sailing-padding {
        padding-top: var(--pt-desk);
        padding-bottom: var(--pb-desk);
    }
}

.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

.sailing-card { width: 100%; }
@media (min-width: 1024px) { .sailing-card { width: calc((100% / 2) - 12px); } }
@media (min-width: 1920px) { .sailing-card { width: calc((100% / 3) - 16px); } }

.arrow-btn { width: 44px; height: 44px; cursor: pointer; transition: opacity 0.3s; }

@media(max-width:1024px) {
  .cta-sailing-item { opacity: 1; transform: none; }
  .arrow-btn { width: 40px; height: 40px; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('sailing-container-{{ section.id }}');
    const currentIndexEl = document.getElementById('current-index-{{ section.id }}');
    const prevBtn = document.getElementById('prev-sailing-{{ section.id }}');
    const nextBtn = document.getElementById('next-sailing-{{ section.id }}');
    const cards = container?.querySelectorAll('.sailing-card');

    if (!container || !cards.length) return;

    function updateSlider() {
        const { scrollLeft, scrollWidth, clientWidth } = container;

        prevBtn.disabled = scrollLeft <= 5;
        nextBtn.disabled = scrollLeft >= (scrollWidth - clientWidth) - 5;

        let current = 1;
        cards.forEach((card, index) => {
            if (scrollLeft >= (card.offsetLeft - container.offsetLeft) - 10) {
                current = index + 1;
            }
        });
        currentIndexEl.textContent = current.toString().padStart(2, '0');
    }

    function scrollByCard(direction) {
        const gap = 24;
        const cardWidth = cards[0].offsetWidth + gap;
        container.scrollBy({ left: direction * cardWidth, behavior: 'smooth' });
    }

    container.addEventListener('scroll', updateSlider);
    prevBtn.onclick = (e) => { e.preventDefault(); scrollByCard(-1); };
    nextBtn.onclick = (e) => { e.preventDefault(); scrollByCard(1); };
    
    updateSlider();
});
</script>

{% schema %}
{
"name": "Sailing stories Slider",
"settings": [
{ "type": "header", "content": "Contenuti" },
{ "type": "text","id": "sailing-slider-title", "label": "Title", "default": "LEGGI IL BLOG" },
{ "type": "textarea", "id": "content", "label": "Content" },
{ "type": "text", "id": "sailing-cta-label", "label": "Card CTA Label", "default": "Leggi l'articolo" },
{ "type": "text", "id": "sailing-slider-cta-all-label", "label": "All sailing Label", "default": "Vedi tutto" },
{ "type": "header", "content": "Padding Desktop (1024px+)" },
{ "type": "range", "id": "pt_desk", "label": "Padding Superiore Desktop", "min": 0, "max": 300, "step": 4, "unit": "px", "default": 200 },
{ "type": "range", "id": "pb_desk", "label": "Padding Inferiore Desktop", "min": 0, "max": 300, "step": 4, "unit": "px", "default": 200 },
{ "type": "header", "content": "Padding Tablet (768px - 1023px)" },
{ "type": "range", "id": "pt_tab", "label": "Padding Superiore Tablet", "min": 0, "max": 260, "step": 4, "unit": "px", "default": 160 },
{ "type": "range", "id": "pb_tab", "label": "Padding Inferiore Tablet", "min": 0, "max": 260, "step": 4, "unit": "px", "default": 160 },
{ "type": "header", "content": "Padding Mobile (0px - 767px)" },
{ "type": "range", "id": "pt_mob", "label": "Padding Superiore Mobile", "min": 0, "max": 200, "step": 2, "unit": "px", "default": 104 },
{ "type": "range", "id": "pb_mob", "label": "Padding Inferiore Mobile", "min": 0, "max": 200, "step": 2, "unit": "px", "default": 104 }
],
"presets": [
{ "name": "Sailing stories Slider", "category": "Sailing stories" }

]
}
{% endschema %}