<div id="{{ section.settings.id }}" class="bg_gs bg_gsp flex flex-col py-[104px] md:py-20 lg:py-[96px] px-4 md:px-8 lg:px-[128px]">
    
    <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 lg:gap-[64px] mb-10 lg:mb-16">
        {% for block in section.blocks %}
            {% case block.type %}
                {% when 'title' %}
                    <div class="w-full lg:w-[828px]">
                        <h2 class="heading-lg_gsp heading-lg_gs text-color_gs text-color_gsp">
                            {{ block.settings.editorial-title }}
                        </h2>
                    </div>
                {% when 'text-area' %}
                    <div class="w-full lg:w-[542px] flex flex-col gap-6 tk-aktiv-grotesk">
                        <div class="body-lg_gs body-lg_gsp text-color-gs text-color_gsp">
                            {{ block.settings.editor-text }}
                        </div>
                        {% if block.settings.editorial-label != blank %}
                            <a href="{{ block.settings.editorial-url }}" class="inline-flex px-8 py-4 w-fit link-lg_gs link-lg_gsp cta-truffle_gsp cta-white_gs transition-all">
                                {{ block.settings.editorial-label }}
                            </a>
                        {% endif %}
                    </div>
            {% endcase %}
        {% endfor %}
    </div>

    {% assign card_count = 0 %}
    {% for block in section.blocks %}
        {% if block.type == 'card' %}{% assign card_count = card_count | plus: 1 %}{% endif %}
    {% endfor %}

    <div class="relative">
        <div id="slider-{{ section.id }}" 
             class="flex flex-row overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-3 md:flex-col md:overflow-visible lg:grid lg:grid-cols-{{ card_count }} md:gap-2">
            
            {% for block in section.blocks %}
                {% if block.type == 'card' %}
                    <div class="snap-center shrink-0 w-[85vw] md:w-full">
                        <div class="relative group overflow-hidden rounded-[16px] aspect-[4/5] md:aspect-[16/9] lg:aspect-[4/5]">
                            {% if block.settings.image != blank %}
                                {{ block.settings.image | image_url: width: 1200 | image_tag: 
                                    class: 'absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
                                    loading: 'lazy'
                                }}
                            {% else %}
                                <div class="absolute inset-0 bg-[#f4f4f4]"></div>
                            {% endif %}

                            <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(20, 19, 18, 0.00) 50%, #141312 100%)"></div>

                            <div class="absolute bottom-0 left-0 p-4 md:p-6 w-full z-10">
                                {% if block.settings.card_title != blank %}
                                    <h3 class="heading-sm_gsp heading-sm_gs text-color-gs text-FAF9F7_gsp mb-2">{{ block.settings.card_title }}</h3>
                                {% endif %}
                                {% if block.settings.card_subtitle != blank %}
                                    <p class="body-md_gsp body-md_gs text-color-gs text-FAF9F7_gsp">{{ block.settings.card_subtitle }}</p>
                                {% endif %}
                            </div>
                            
                            {% if block.settings.link != blank %}
                                <a href="{{ block.settings.link }}" class="absolute inset-0 z-20" aria-label="{{ block.settings.card_title }}"></a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {% if card_count > 1 %}
        <div class="flex md:hidden items-center justify-between mt-8">
            <div class="body-sm_gsp body-sm_gs text-color_gs text-color_gsp">
                <span id="current-index-{{ section.id }}">01</span> - 0{{ card_count }}
            </div>

            <div class="flex gap-[14px] items-center">
                <button id="btn-prev-{{ section.id }}" 
                        onclick="document.getElementById('slider-{{ section.id }}').scrollBy({left: -window.innerWidth * 0.8, behavior: 'smooth'})" 
                        class="pt-3 transition-opacity duration-300 opacity-30 pointer-events-none">
                    {% render 'gs-arrow-left-black' %}
                </button>
                <button id="btn-next-{{ section.id }}" 
                        onclick="document.getElementById('slider-{{ section.id }}').scrollBy({left: window.innerWidth * 0.8, behavior: 'smooth'})" 
                        class="pb-3 transition-opacity duration-300">
                    {% render 'gs-arrow-right-black' %}
                </button>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<style>
    /* Nasconde la scrollbar su tutti i browser */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    
    /* Forza l'altezza su mobile per evitare salti */
    #slider-{{ section.id }} { scroll-behavior: smooth; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const slider = document.getElementById('slider-{{ section.id }}');
        const counter = document.getElementById('current-index-{{ section.id }}');
        const btnPrev = document.getElementById('btn-prev-{{ section.id }}');
        const btnNext = document.getElementById('btn-next-{{ section.id }}');
        
        if (slider && counter) {
            slider.addEventListener('scroll', () => {
                // Calcolo indice corrente
                const cardWidth = slider.querySelector('.snap-center').offsetWidth + 16; // width + gap
                const index = Math.round(slider.scrollLeft / cardWidth) + 1;
                
                // Update Counter con zero padding
                counter.innerText = index < 10 ? '0' + index : index;

                // Update Stato Frecce
                const isAtStart = slider.scrollLeft <= 20;
                const isAtEnd = slider.scrollLeft + slider.offsetWidth >= slider.scrollWidth - 20;

                if (isAtStart) {
                    btnPrev.classList.add('opacity-30', 'pointer-events-none');
                } else {
                    btnPrev.classList.remove('opacity-30', 'pointer-events-none');
                }

                if (isAtEnd) {
                    btnNext.classList.add('opacity-30', 'pointer-events-none');
                } else {
                    btnNext.classList.remove('opacity-30', 'pointer-events-none');
                }
            });
        }
    });
</script>

{% schema %}
{
    "name": "Multi Cards Editorial",
    "settings": [
        {
            "type": "text",
            "id": "id",
            "label": "Id section",
            "default": "editorial-cards"
        }
    ],
    "blocks": [
        {
            "type": "title",
            "name": "Title",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id":"editorial-title",
                    "label": "Title"
                }
            ]
        },
        {
            "type": "text-area",
            "name": "Text area",
            "limit": 1,
            "settings": [
                {
                    "type": "textarea",
                    "id": "editor-text",
                    "label": "Editor content text"
                },
                {
                    "type": "text",
                    "id": "editorial-label",
                    "label": "Button text"
                },
                {
                    "type": "url",
                    "id": "editorial-url",
                    "label": "Button link"
                }
            ]
        },
        {
            "type": "card",
            "name": "Card Item",
            "limit": 3,
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Card Image"
                },
                {
                    "type": "text",
                    "id": "card_title",
                    "label": "Card Title",
                    "default": "Titolo Card"
                },
                {
                    "type": "text",
                    "id": "card_subtitle",
                    "label": "Card Subtitle",
                    "default": "Sottotitolo descrittivo"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Card Link"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Multi Cards Editorial",
            "blocks": [
                { "type": "title" },
                { "type": "text-area" },
                { "type": "card" },
                { "type": "card" },
                { "type": "card" }
            ]
        }
    ]
}
{% endschema %}