<section id="sailing-{{ section.id }}" 
         style="--pt-mob: {{ section.settings.pt_mob }}px; --pb-mob: {{ section.settings.pb_mob }}px;
                --pt-tab: {{ section.settings.pt_tab }}px; --pb-tab: {{ section.settings.pb_tab }}px;
                --pt-desk: {{ section.settings.pt_desk }}px; --pb-desk: {{ section.settings.pb_desk }}px;"
         class="sailing-padding bg_gs bg_gsp">
    
    <div class="flex flex-col md:flex-row justify-between items-start px-4 md:px-[60px] pb-8 lg:pb-[56px]">
      <h2 class="heading-md_gsp heading-md_gs text-color_gs text-color_gsp">
        {{ section.settings.main_title }}
      </h2>
      {% if section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url }}" class="body-sm_gsp body-sm_gs md:body-md_gsp md:body-md_gs underline text-color_gs text-color_gsp">
          {{ section.settings.link_text }}
        </a>
      {% endif %}
    </div>

    <div class="relative px-4 md:px-[60px]">     
      
      <div class="relative w-full overflow-hidden rounded-[16px] aspect-[4/5] md:aspect-video">
        <div class="absolute inset-0 z-[1] pointer-events-none" 
            style="background: linear-gradient(0deg, rgba(5, 9, 13, 0.24) 0%, rgba(5, 9, 13, 0.24) 100%);">
        </div>

        {% if section.settings.main_image != blank %}
          <picture>
            {% if section.settings.main_image_mobile != blank %}
              <source media="(max-width: 767px)" srcset="{{ section.settings.main_image_mobile | image_url: width: 800 }}">
            {% endif %}
            <img src="{{ section.settings.main_image | image_url: width: 2000 }}" 
                alt="{{ section.settings.main_image.alt | escape }}" 
                class="absolute inset-0 w-full h-full object-cover block"
                loading="lazy">
          </picture>
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'absolute inset-0 w-full h-full bg-gray-200' }}
        {% endif %}
      </div>

      <div class="absolute inset-0 flex items-end justify-start md:items-center md:justify-center p-8 md:p-[60px] z-[2]">
        <div class="text-left md:text-center max-w-[828px]">
          
          {% if section.settings.subtitle != blank %}
            <span class="block pretitle-xs_gs text-color_gs pretitle-xs_gsp text-FAF9F7_gsp mb-4 uppercase tracking-wider">
              {{ section.settings.subtitle }}
            </span>
          {% endif %}
          
          {% if section.settings.inner_title != blank %}
            <h3 class="heading-md_gs text-color_gs heading-md_gsp text-FAF9F7_gsp mb-5">
              {{ section.settings.inner_title }}
            </h3>
          {% endif %}
          
          {% if section.settings.text != blank %}
            <div class="body-md_gs text-color_gs body-md_gsp text-FAF9F7_gsp mb-10">
              {{ section.settings.text }}
            </div>
          {% endif %}
          
          {% if section.settings.cta_text != blank %}
            <a href="{{ section.settings.cta_url }}" 
               class="inline-block px-8 py-4 cta-blur_gs cta-blur-light_gsp link-lg_gs link-lg_gsp w-full md:w-fit text-center transition-opacity hover:opacity-90">
              {{ section.settings.cta_text }}
            </a>
          {% endif %}

        </div>
      </div>
  </div>
</section>

<style>
.sailing-padding {
    padding-top: var(--pt-mob);
    padding-bottom: var(--pb-mob);
}

@media screen and (min-width: 768px) {
    .sailing-padding {
        padding-top: var(--pt-tab);
        padding-bottom: var(--pb-tab);
    }
}

@media screen and (min-width: 1024px) {
    .sailing-padding {
        padding-top: var(--pt-desk);
        padding-bottom: var(--pb-desk);
    }
}
</style>

{% schema %}
{
  "name": "Sailing story",
  "settings": [
    { "type": "header", "content": "Testata" },
    { "type": "text", "id": "main_title", "label": "Titolo In alto a sx", "default": "Highlights" },
    { "type": "text", "id": "link_text", "label": "Link in alto a dx", "default": "Esplora collezione" },
    { "type": "url", "id": "link_url", "label": "URL Link" },
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "main_image", "label": "Immagine Desktop" },
    { "type": "image_picker", "id": "main_image_mobile", "label": "Immagine Mobile (Opzionale)" },
    { "type": "header", "content": "Contenuto Overlay" },
    { "type": "text", "id": "subtitle", "label": "Sottotitolo", "default": "In Evidenza" },
    { "type": "text", "id": "inner_title", "label": "Titolo", "default": "Design d'Avanguardia" },
    { "type": "richtext", "id": "text", "label": "Descrizione", "default": "<p>Sperimenta il massimo del comfort.</p>" },
    { "type": "text", "id": "cta_text", "label": "Testo Bottone", "default": "Scopri i Prodotti" },
    { "type": "url", "id": "cta_url", "label": "Link Bottone" },
    { "type": "header", "content": "Padding Desktop (1024px+)" },
    { "type": "range", "id": "pt_desk", "label": "Padding Superiore Desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "pb_desk", "label": "Padding Inferiore Desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "header", "content": "Padding Tablet (768px - 1023px)" },
    { "type": "range", "id": "pt_tab", "label": "Padding Superiore Tablet", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "pb_tab", "label": "Padding Inferiore Tablet", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 60 },
    { "type": "header", "content": "Padding Mobile (0px - 767px)" },
    { "type": "range", "id": "pt_mob", "label": "Padding Superiore Mobile", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "pb_mob", "label": "Padding Inferiore Mobile", "min": 0, "max": 120, "step": 2, "unit": "px", "default": 32 }
  ],
  "presets": [
    { "name": "Sailing story", "category": "Home Page" }
  ]
}
{% endschema %}