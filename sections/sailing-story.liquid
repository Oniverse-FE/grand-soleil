<section class="bg_gs bg_gsp">
    
    <div class="flex flex-col md:flex-row justify-between items-start pt-8 pb-8 px-4 md:px-[60px] md:pt-20 md:pb-[56px]">
      <h2 class="heading-md_gsp heading-md_gs text-color_gs text-color_gsp">
        {{ section.settings.main_title }}
      </h2>
      <a href="{{ section.settings.link_url }}" class="body-md_gsp body-md_gsunderline text-color_gs text-color_gsp">
        {{ section.settings.link_text }}
      </a>
    </div>

    <div class="relative px-4 md:px-[60px]">
      
      <div class="relative w-full overflow-hidden rounded-[16px]">
        <div class="absolute inset-0 z-[1] pointer-events-none" 
             style="background: linear-gradient(0deg, rgba(5, 9, 13, 0.24) 0%, rgba(5, 9, 13, 0.24) 100%);">
        </div>

        {% if section.settings.main_image != blank %}
          <img src="{{ section.settings.main_image | img_url: '1600x' }}" 
               alt="{{ section.settings.main_image.alt }}" 
               class="w-full max-h-[936px] object-cover block">
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-[600px] bg-gray-200' }}
        {% endif %}
      </div>

      <div class="absolute inset-0 flex items-center justify-center p-[60px] z-[2]">
        <div class="text-center max-w-[828px]">
          
          <span class="block pretitle-xs_gs text-color_gs pretitle-xs_gsp text-FAF9F7_gsp mb-4 uppercase tracking-wider">
            {{ section.settings.subtitle }}
          </span>
          
          <h3 class="heading-md_gs text-color_gs heading-md_gsp text-FAF9F7_gsp mb-5">
            {{ section.settings.inner_title }}
          </h3>
          
          <div class="body-md_gs text-color_gs body-md_gsp text-FAF9F7_gsp mb-10">
            {{ section.settings.text }}
          </div>
          
          <a href="{{ section.settings.cta_url }}" 
             class="inline-block px-10 py-4 cta-blur-dark_gs cta-blur-light_gsp link-lg_gs link-lg_gsp">
            {{ section.settings.cta_text }}
          </a>

        </div>
      </div>
  </div>
</section>

{% schema %}
{
  "name": "Sailing story",
  "settings": [
    { "type": "text", "id": "main_title", "label": "Titolo In alto a sx", "default": "Highlights" },
    { "type": "text", "id": "link_text", "label": "Link in alto a dx", "default": "Esplora collezione" },
    { "type": "url", "id": "link_url", "label": "URL Link" },
    { "type": "image_picker", "id": "main_image", "label": "Immagine di Sfondo" },
    { "type": "text", "id": "subtitle", "label": "Sottotitolo Overlay", "default": "In Evidenza" },
    { "type": "text", "id": "inner_title", "label": "Titolo Overlay", "default": "Design d'Avanguardia" },
    { "type": "richtext", "id": "text", "label": "Testo Overlay", "default": "<p>Sperimenta il massimo del comfort con la nostra nuova linea esclusiva pensata per l'uso quotidiano.</p>" },
    { "type": "text", "id": "cta_text", "label": "Testo Bottone", "default": "Scopri i Prodotti" },
    { "type": "url", "id": "cta_url", "label": "Link Bottone" }
  ],
  "presets": [
    { "name": "Sailing story" }
  ]
}
{% endschema %}