<div class="flex flex-col px-4 md:px-10 lg:px-[128px] gap-8 lg:gap-[96px] bg_gs">
    
    <div class="heading-md_gs md:title_gs text-color_gs md:text-center">
        {{ section.settings.news-hub-title }}
    </div>

    <div class="w-full overflow-hidden">
        <div id="news-filter-chips" class="flex flex-nowrap justify-start md:justify-center overflow-x-auto gap-3 pb-8 md:pb-[56px] no-scrollbar outline-none">
            <button class="chip-filter active px-6 py-2 rounded-[50px] link-lg_gs text-[#EBEFF2] transition-all duration-300 hover:bg-[#EBEFF2] hover:text-[#05090D] hover:border-[#EBEFF2] shrink-0" data-tag="all">
                {{ section.settings.chip_all-news }}
            </button>
            {% assign tags = section.settings.filter-tags | split: ',' %}
            {% for tag in tags %}
                {% assign clean_tag = tag | strip %}
                {% if clean_tag != blank %}
                    <button class="chip-filter px-6 rounded-[50px] link-lg_gs text-[#EBEFF2] transition-all duration-300 hover:bg-[#EBEFF2] hover:text-[#05090D] hover:border-[#EBEFF2] shrink-0" data-tag="{{ clean_tag }}">
                        {{ clean_tag }}
                    </button>
                {% endif %}
            {% endfor %}
        </div>
            <div id="news-grid-container" class="flex flex-col gap-12 lg:gap-16">
        <div id="news-cards" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
            </div>

        <div id="no-results" class="hidden text-center py-20">
            <p class="text-lg opacity-60">{{ section.settings.no-event-label }}</p>
        </div>

        <div id="news-pagination" class="flex justify-center gap-6 text-white mt-4 mb-16"></div>
    </div>
    </div>
</div>

<style>

    .aspect-4-3 {
        position: relative;
        padding-top: 75%; 
    }
    .aspect-4-3 img {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
    }

    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    /* Stato Attivo delle Chips */
    .chip-filter.active {
        background-color: #EBEFF2;
        color: #05090D;
        border: 0.5px solid #EBEFF2;
    }
    .chip-filter {
        border: 0.5px solid #EBEFF2;
    }

    .pagination-btn.active {
        opacity: 1;
        font-weight: 700;
        border-bottom: 2px solid white;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const allArticles = [
        {% for article in blogs.news.articles %}
        {
            url: "{{ article.url }}",
            title: {{ article.title | json }},
            date: "{{ article.published_at | date: "%d.%m.%Y" }}",
            image: {{ article.image | image_url: width: 800 | json }},
            tags: [{% for tag in article.tags %}"{{ tag | downcase }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
            displayTag: "{{ article.tags[0] }}"
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
    ];

    const perPage = 9;
    let currentTag = 'all';
    let currentPage = 1;

    const newsCards = document.getElementById('news-cards');
    const pagination = document.getElementById('news-pagination');
    const chips = document.querySelectorAll('.chip-filter');
    const noResults = document.getElementById('no-results');

    function render() {
        const filtered = allArticles.filter(a => 
            currentTag === 'all' || a.tags.includes(currentTag)
        );

        const start = (currentPage - 1) * perPage;
        const items = filtered.slice(start, start + perPage);

        if (filtered.length === 0) {
            newsCards.innerHTML = '';
            noResults.classList.remove('hidden');
        } else {
            noResults.classList.add('hidden');
            newsCards.innerHTML = items.map(article => `
                <a href="${article.url}" class="group flex flex-col">
                    <div class="aspect-4-3 overflow-hidden rounded-[16px] w-full">
                        ${article.image ? `<img src="${article.image}" alt="${article.title}" class="transition-transform">` : ''}
                    </div>
                    <div class="flex flex-wrap gap-[6px] mt-4">
                        <span class="link-sm-gs md:link-md_gs article-data_gs text-data_gs py-[6px] px-3">${article.date}</span>
                        ${article.displayTag ? `<span class="link-sm-gs md:link-md_gs text-color_gs py-[6px] px-3 uppercase">${article.displayTag}</span>` : ''}
                    </div>
                    <h3 class="mt-4 subtitle_gs md:heading-sm_gs text-color_gs">
                        ${article.title}
                    </h3>
                </a>
            `).join('');
        }
        renderPagination(filtered.length);
    }

    function renderPagination(totalItems) {
        pagination.innerHTML = '';
        const totalPages = Math.ceil(totalItems / perPage);
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement('button');
            btn.className = `pagination-btn opacity-40 hover:opacity-100 transition-opacity pb-1 text-lg ${i === currentPage ? 'active' : ''}`;
            btn.innerText = i;
            btn.onclick = (e) => {
                e.preventDefault();
                currentPage = i;
                render();
                window.scrollTo({top: document.getElementById('news-grid-container').offsetTop - 120, behavior: 'smooth'});
            };
            pagination.appendChild(btn);
        }
    }

    chips.forEach(chip => {
        chip.addEventListener('click', () => {
            chips.forEach(c => c.classList.remove('active'));
            chip.classList.add('active');
            currentTag = chip.dataset.tag.toLowerCase();
            currentPage = 1;
            render();
        });
    });

    render();
});
</script>

{% schema %}
{
  "name": "News Hub",
  "settings": [
    {
      "type": "text",
      "id": "news-hub-title",
      "label": "Titolo Sezione",
      "default": "TUTTE LE NOVITÀ DEL MONDO VANDUTCH"
    },
    {
      "type": "text",
      "id": "chip_all-news",
      "label": "Chip all news",
      "default": "All News"
    },
    {
      "type": "textarea",
      "id": "filter-tags",
      "label": "Tag per i Filtri (separati da virgola)",
      "default": "Eventi, Press, Lifestyle"
    }
  ],
  "presets": [
    {
      "name": "News Hub"
    }
  ]
}
{% endschema %}