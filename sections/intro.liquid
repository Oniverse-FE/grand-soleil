<div  id="{{ section.settings.id }}" class="intro intro-padding flex flex-col px-4 md:px-12 lg:px-24" style="--padding-top-desktop: {{ section.settings.padding_top }}; --padding-bottom-desktop: {{ section.settings.padding_bottom }};  --padding-top-mobile: {{ section.settings.padding_top_mobile }};   --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }};">
    {% for block in section.blocks %}
        {% case block.type %}
            {% when '@app' %}
                {% render block %}
                    <!-- blocco titolo --> 
                    {% when 'intro-title' %}
                        <div class="flex flex-col uppercase w-full max-w-[721px] h-auto justify-start{% if block.settings.title-left == true %} lg:justify-start {% else %} lg:justify-end {% endif %} text-white">
                            {% if block.settings.intro-title-text != blank %}
                                <div class="flex">
                                    <h2 class="responsive-title pb-6 lg:pb-0"> {{ block.settings.intro-title-text }} </h2>
                                </div>
                                {% endif %}
                                {% if block.settings.small-title != blank %}
                                <div class="flex">
                                    <h3 class="responsive-small-title pb-6 lg:pb-0"> {{ block.settings.small-title }} </h3>
                                </div>
                            {% endif %}
                        </div>
                    {% when 'intro-text-area' %}
                        <div class="flex lg:mt-[48px] text-white bg-transparent justify-start{% if block.settings.intro-text-left == true %} md:justify-start lg:justify-start {% else %} md:justify-end lg:justify-end {% endif %} w-full tk-aktiv-grotesk">
                            <div class="flex flex-col justify-end">
                                <div class="pb-3 lg:pb-4 flex w-full max-w-[511px]">
                                    <h6 class="text-[26px] leading-[32px] lg:text-[42px] lg:leading-[48px] uppercase"> {{ block.settings.intro-text-area-title }} </h6>
                                </div>
                                <div class="flex justify-start w-full md:w-[437px]  lg:w-[511px] body-regular text-[16px] lg:text-[18px] leading-[22px] lg:leading-6">
                                    {{ block.settings.intro-text-area-text | newline_to_br }}
                                </div>
                                {% if section.settings.first-cta-visible == true %}
                                    <div class="pt-6 lg:pt-8 flex flex-col w-full justify-center items-center body-regular text-[16px] leading-3.5">
                                        <div class="flex flex-col w-full gap-4">
                                            <div class="flex w-full">
                                                {% if section.settings.first-cta-visible == true %}
                                                    <a href="{{ section.settings.first-cta-link }}" class="w-full text-center font-semibold rounded-4xl py-3.5 px-5 lg:px-7 {% if section.settings.brochure-transparent == true %}bg-transparent{% endif %}" style="{% if section.settings.brochure-transparent != true %}background-color:{{ section.settings.brochure-bg-color }};{% endif %}color:{{ section.settings.brochure-color }};border: 1px solid {{ section.settings.brochure-border-color }};backdrop-filter: blur(40px);">
                                                        {{ section.settings.first-cta-label }}
                                                    </a>
                                                {% endif %}
                                            </div>
                                            <div class="flex w-full">
                                                {% if section.settings.second-cta-visible == true %}
                                                    <a href="{{ section.settings.second-cta-link }}" class=" w-full text-center font-semibold rounded-4xl py-3.5 px-5 lg:px-7{% if section.settings.info-transparent == true %}bg-transparent{% endif %}" style="{% if section.settings.info-transparent != true %}background-color:{{ section.settings.info-bg-color }};{% endif %}color:{{ section.settings.info-color }};border: 1px solid {{ section.settings.info-border-color }};backdrop-filter: blur(40px);">
                                                        {{ section.settings.second-cta-label }}
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
        {% endcase %}
    {% endfor %}
</div>
<style>
.responsive-title {
    font-size: 56px;
    font-style: normal;
    font-weight: 700;
    line-height: 62px;
}
.responsive-small-title {
    font-size: 42px;
    font-style: normal;
    font-weight: 700;
    line-height: 48px;
}
@media screen and (min-width: 768px) {
  .responsive-title {
    font-size: 120px;
    font-style: normal;
    font-weight: 700;
    line-height: 126px;
  }
  .responsive-small-title {
    font-size: 80px;
    font-style: normal;
    font-weight: 700;
    line-height: 86px;
  }
}
  .intro-padding {
    padding-top: var(--padding-top-mobile);
    padding-bottom: var(--padding-bottom-mobile);
    }

    @media screen and (min-width: 768px) {
    .intro-padding {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    }
  }
</style>
