<div class="bg_gs bg_gsp flex flex-col px-4 md:px-12 lg:px-24 pt-[96px] lg:pt-[165px] mb-[144px] lg:mb-[280px]">

    <h6 class="text-4xl leading-[42px] md:text-[56px] md:leading-[62px] text-white uppercase mb-[24px] lg:mb-[80px]">
        {{ section.settings.event-section-title }}
    </h6>

    <div class="relative flex justify-center self-center rounded-[10px] bg-antracite body-medium text-[12px] leading-[18px] lg:text-sm lg:leading-5 md:w-[427px] lg:w-[342px] w-full mb-[32px] lg:mb-[64px] overflow-hidden">
        <div id="toggle-slider" class="absolute top-0 left-0 h-full w-1/2 bg-white rounded-[10px] transition-all duration-300"></div>
        <button id="future-toggle" class="toggle-btn w-1/2 relative z-10 py-2 font-semibold text-black transition-colors duration-300">
            {{ section.settings.future-event-label }}
        </button>
        <button id="past-toggle" class="toggle-btn w-1/2 relative z-10 py-2 font-semibold text-white transition-colors duration-300">
            {{ section.settings.past-event-label }}
        </button>
    </div>

    <div class="relative search-wrapper hidden" id="search-wrapper-futuri">
        <input id="future-search" type="text" placeholder="{{ section.settings.event-search-placeholder }}"
            class="w-full p-2 pb-2 pr-10 border-b border-white text-white bg-transparent body-regular text-sm focus:outline-none focus:border-[#F76C00]" />
        <div class="absolute right-2 top-1/2 -translate-y-1/2 cursor-pointer" id="future-icon-search">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"><circle cx="10" cy="10" r="5.5"/><path d="M19 19l-5-5"/></svg>
        </div>
        <div id="future-icon-clear" class="absolute right-2 top-1/2 -translate-y-1/2 hidden cursor-pointer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
        </div>
    </div>

    <div class="relative search-wrapper hidden" id="search-wrapper-passati">
        <input id="past-search" type="text" placeholder="{{ section.settings.event-search-placeholder }}"
            class="w-full p-2 pb-2 pr-10 border-b border-white text-white bg-transparent body-regular text-sm focus:outline-none focus:border-[#F76C00]" />
        <div class="absolute right-2 top-1/2 -translate-y-1/2 cursor-pointer" id="past-icon-search">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"><circle cx="10" cy="10" r="5.5"/><path d="M19 19l-5-5"/></svg>
        </div>
        <div id="past-icon-clear" class="absolute right-2 top-1/2 -translate-y-1/2 hidden cursor-pointer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/></svg>
        </div>
    </div>

    {% assign now_timestamp = 'now' | date: '%s' %}
    <div id="future-event-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mt-[56px] lg:mt-[80px] text-white hidden">
        {% for article in blogs['events'].articles %}
            {% assign end_date_timestamp = article.metafields.custom.event_end_date | date: '%s' %}
            {% if end_date_timestamp >= now_timestamp %}
                <a href="{{ article.url }}" class="evento-card block group" data-title="{{ article.title | downcase }}">
                    <div class="flex flex-col rounded-[10px] bg-antracite p-6 lg:p-8 h-full min-h-[320px] justify-between hover:bg-[#2a2a2a] transition-colors">
                        <div class="flex flex-col gap-6">
                            <h3 class="text-3xl lg:text-[40px] leading-tight uppercase font-medium">{{ article.title }}</h3>
                            <div class="flex flex-col gap-1 text-[16px] lg:text-[18px] opacity-90">
                                <span>{{ article.metafields.custom.event_start_date | date: "%d/%m/%Y" }} - {{ article.metafields.custom.event_end_date | date: "%d/%m/%Y" }}</span>
                                <span class="uppercase">{{ article.metafields.custom.event_location }}</span>
                            </div>
                        </div>
                        <div class="mt-8">
                            <span class="inline-block w-full text-center rounded-full py-4 bg-white text-black font-bold uppercase text-sm tracking-wider group-hover:bg-[#D6CBC9] transition-colors">
                                {{ section.settings.future-event-book-label }}
                            </span>
                        </div>
                    </div>
                </a>
            {% endif %}
        {% endfor %}
    </div>

    <div id="past-event-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mt-[56px] lg:mt-[80px] text-white hidden">
        {% for article in blogs['events'].articles %}
            {% assign end_date_timestamp = article.metafields.custom.event_end_date | date: '%s' %}
            {% if end_date_timestamp < now_timestamp %}
                {% assign has_cta = article.metafields.custom.cta_card %}
                <div class="evento-card block" data-title="{{ article.title | downcase }}">
                    <div class="flex flex-col rounded-[10px] bg-antracite p-6 lg:p-8 h-full min-h-[280px] justify-between border border-transparent hover:border-gray-500 transition-all">
                        <div class="flex flex-col gap-4">
                            <h3 class="text-3xl lg:text-[36px] leading-tight uppercase font-medium">{{ article.title }}</h3>
                            <div class="text-[16px] lg:text-[18px] opacity-70">
                                <p>{{ article.metafields.custom.event_end_date | date: "%d/%m/%Y" }}</p>
                                <p class="uppercase">{{ article.metafields.custom.event_location }}</p>
                            </div>
                        </div>
                        {% if has_cta %}
                        <a href="{{ article.metafields.custom.link_news }}" class="mt-6 inline-block w-full text-center rounded-full py-3 border border-white text-white hover:bg-white hover:text-black transition-all uppercase text-xs font-bold">
                            {{ has_cta }}
                        </a>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <div id="no-results-futuri" class="hidden text-white mt-10">
        <p class="text-lg mb-4">{{ section.settings.no-event-label }}</p>
        <button id="reset-future-search" class="uppercase border-b border-white pb-1 font-bold">{{ section.settings.all-event-label }}</button>
    </div>

    <div id="no-events-futuri" class="hidden text-white mt-10">
        <h2 class="text-3xl uppercase mb-2">{{ section.settings.title-no-event }}</h2>
        <p class="opacity-80">{{ section.settings.text-no-event }}</p>
    </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const futureToggle = document.getElementById("future-toggle");
    const pastToggle = document.getElementById("past-toggle");
    const toggleSlider = document.getElementById("toggle-slider");
    
    const futureWrapper = document.getElementById("search-wrapper-futuri");
    const pastWrapper = document.getElementById("search-wrapper-passati");
    const futureList = document.getElementById("future-event-list");
    const pastList = document.getElementById("past-event-list");
    
    const noResultsFuturi = document.getElementById("no-results-futuri");
    const noEventsFuturi = document.getElementById("no-events-futuri");
    const futureSearch = document.getElementById("future-search");
    const pastSearch = document.getElementById("past-search");

    function updateView(mode) {
        if (mode === 'future') {
            toggleSlider.style.left = "0";
            futureToggle.classList.replace("text-white", "text-black");
            pastToggle.classList.replace("text-black", "text-white");
            
            futureList.classList.remove("hidden");
            pastList.classList.add("hidden");
            futureWrapper.classList.remove("hidden");
            pastWrapper.classList.add("hidden");
        } else {
            toggleSlider.style.left = "50%";
            pastToggle.classList.replace("text-white", "text-black");
            futureToggle.classList.replace("text-black", "text-white");
            
            pastList.classList.remove("hidden");
            futureList.classList.add("hidden");
            pastWrapper.classList.remove("hidden");
            futureWrapper.classList.add("hidden");
        }
    }

    function filter(input, listId, noResultsId) {
        const query = input.value.toLowerCase();
        const items = document.querySelectorAll(`#${listId} .evento-card`);
        let visible = 0;
        
        items.forEach(item => {
            const match = item.dataset.title.includes(query);
            item.classList.toggle("hidden", !match);
            if(match) visible++;
        });
        
        document.getElementById(noResultsId).classList.toggle("hidden", visible > 0 || query === "");
    }

    futureToggle.addEventListener("click", () => updateView('future'));
    pastToggle.addEventListener("click", () => updateView('past'));
    
    futureSearch.addEventListener("input", () => filter(futureSearch, "future-event-list", "no-results-futuri"));
    pastSearch.addEventListener("input", () => filter(pastSearch, "past-event-list", "no-results-passati"));

    // Inizializzazione: se non ci sono eventi futuri, mostra i passati
    if (futureList.querySelectorAll('.evento-card').length === 0) {
        noEventsFuturi.classList.remove("hidden");
        updateView('past');
    } else {
        updateView('future');
    }
});
</script>

{% schema %}
{
"name": "Lista eventi",
"settings": [
{
    "type": "text",
    "id": "event-section-title",
    "label": "Section title",
    "default": "le nostre attività"
},
{
    "type": "text",
    "id": "future-event-label",
    "label": "Future event label",
    "default": "Prossimi eventi"
},
{
    "type": "text",
    "id": "past-event-label",
    "label": "Past event label",
    "default": "Eventi passati"
},
{
    "type": "text",
    "id": "event-search-placeholder",
    "label": "Search bar placeholder",
    "default": "Cerca un evento"
},
{
    "type": "text",
    "id": "future-event-discover-label",
    "label": "Future event discover label",
    "default": "discover more"
},
{
    "type": "text",
    "id": "future-event-calendar-label",
    "label": "Future event calendar label",
    "default": "add to calendar"
},
{
    "type": "text",
    "id": "future-event-book-label",
    "label": "Future event book label",
    "default": "Book an appointment"
},
{
    "type": "text",
    "id": "past-event-discover-label",
    "label": "Past event discover label",
    "default": "Discover what happened"
},
{
    "type": "text",
    "id": "no-event-label",
    "label": "No event label",
    "default": "I'm sorry, there are no events that match your search."
},
{
    "type": "text",
    "id": "all-event-label",
    "label": "All event label",
    "default": "Discover all events"
},
{
    "type": "text",
    "id": "title-no-event",
    "label": "No event title",
    "default": "No events in future"
},
{
    "type": "text",
    "id": "text-no-event",
    "label": "no event desc",
    "default": "I'm sorry, there are no events that match your search."
}
],
"presets": [{ "name": "Lista Eventi" }]
}
{% endschema %}