{% comment %} 
  Utilizziamo "blog.articles" per fare in modo che Shopify filtri 
  automaticamente gli articoli in base al tag presente nell'URL.
{% endcomment %}
{% paginate blog.articles by 5 %}

<div id="events-{{ section.id }}" 
     style="--pt-mob: {{ section.settings.pt_mob }}px; --pb-mob: {{ section.settings.pb_mob }}px;
            --pt-tab: {{ section.settings.pt_tab }}px; --pb-tab: {{ section.settings.pb_tab }}px;
            --pt-desk: {{ section.settings.pt_desk }}px; --pb-desk: {{ section.settings.pb_desk }}px;"
     class="events-padding bg_gs bg_gsp flex flex-col px-4 md:px-12 lg:px-[128px]">
    
    <div class="events-title heading-md_gs md:title_gs text-color_gs text-left md:text-center pb-10 lg:pb-[96px]">
        {{ section.settings.event-slider-title }}
    </div>

    {% comment %} --- CHIPS FILTRI PER TAG --- {% endcomment %}
    {% if blog.all_tags.size > 0 %}
    <div class="flex flex-wrap justify-start md:justify-center gap-2 mb-8 lg:mb-[56px]">
        
        {% comment %} Chip "Tutti gli eventi" {% endcomment %}
        <a href="{{ blog.url }}" 
           class="chip-gs px-4 py-2 rounded-full transition-all no-underline 
           {% unless current_tags %}
              bg-white_gs text-data_gs link-lg_gs
           {% else %}
              cta-border-light_gs text-color_gs link-lg_gs
           {% endunless %}">
           {{ section.settings.chip_all }}
        </a>

        {% for tag in blog.all_tags %}
            {% if current_tags contains tag %}
                {% comment %} Tag attivo: cliccandolo si resetta il filtro {% endcomment %}
                <a href="{{ blog.url }}" class="chip-gs px-4 py-2 rounded-full link-lg_gs bg-white_gs text-data_gs no-underline border-none">
                    {{ tag }} 
                </a>
            {% else %}
                {% comment %} Tag non attivo {% endcomment %}
                <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="chip-gs px-4 py-2 cta-border-light_gs text-color_gs rounded-full link-lg_gs no-underline">
                    {{ tag }}
                </a>
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="flex flex-col w-full justify-center items-start gap-6 lg:gap-8 text-color_gs text-color_gsp">
        
        {% for article in blog.articles %}
            <div class="flex flex-col lg:flex-row gap-4 xl:gap-10 w-full cursor-pointer bg-dark_gs bg-beige_gsp p-6 md:p-8 lg:p-10 transition-all hover:opacity-90"
                 onclick="window.location.href='{{ article.url }}'">

                <div class="flex flex-col md:flex-row items-start w-full justify-between">
                    <div class="flex flex-col gap-6 mb-10 md:mb-0">
                        <div class="flex heading-sm_gs heading-sm_gsp md:heading-md_gs md:heading-md_gsp text-color_gs text-color_gsp">
                            {{ article.title }}
                        </div>

                        <div class="flex flex-col gap-2">
                            <div class="flex gap-2 mb-2">
                                {% for tag in article.tags %}
                                    <span class="text-[10px] uppercase tracking-widest opacity-60">{{ tag }}</span>
                                {% endfor %}
                            </div>

                            <div class="flex flex-row gap-2 lg:gap-2.5">
                                <div class="flex flex-row body-sm_gs body-sm_gsp md:body-md_gs md:body-md_gsp text-color_gs text-color_gsp items-center justify-center">
                                    {{ section.settings.event-slider-date }}:
                                    {%- assign start = article.metafields.custom.event_start_date | date: "%d" -%}
                                    {%- assign end = article.metafields.custom.event_end_date | date: "%d %B %Y" -%}
                                    {{ start }} - {{ end }}
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 lg:gap-2.5">
                                <div class="flex flex-row body-sm_gs body-sm_gsp md:body-md_gs md:body-md_gsp text-color_gs text-color_gsp justify-center items-center">
                                    {{ section.settings.event-slider-location }}: {{ article.metafields.custom.event_location }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="w-full flex flex-col gap-4 lg:flex-row lg:justify-end lg:items-center">
                        <div class="flex w-full md:w-auto">
                            <a href="{{ article.url }}" class="w-full md:min-w-[207px] text-center link-lg-gs link-lg_gsp cta-blue_gs cta-truffle_gsp py-4 px-6 no-underline"> 
                                {{ section.settings.event-slider-cta2-label }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            {% comment %} Fallback se non ci sono articoli nel filtro selezionato {% endcomment %}
            <div class="w-full text-center py-20 opacity-50 body-md_gs">
                Nessun evento disponibile per questa categoria.
            </div>
        {% endfor %}

        {% if paginate.pages > 1 %}
            <div class="flex flex-row justify-center items-center w-full gap-6 mt-8 lg:mt-12">
                {% if paginate.previous %}
                    <a href="{{ paginate.previous.url }}" class="link-lg-gs link-lg_gsp flex items-center justify-center transition-opacity hover:opacity-70">
                        {% render 'gs-arrow-left-white' %}
                    </a>
                {% endif %}

                <div class="body-md_gs body-md_gsp">
                    {{ paginate.current_page }} / {{ paginate.pages }}
                </div>

                {% if paginate.next %}
                    <a href="{{ paginate.next.url }}" class="link-lg-gs link-lg_gsp flex items-center justify-center transition-opacity hover:opacity-70">
                        {% render 'gs-arrow-right-white' %}
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </div>
</div>

{% endpaginate %}

<style>
.events-padding {
    padding-top: var(--pt-mob);
    padding-bottom: var(--pb-mob);
}
.chip-gs {
    border-width: 1px;
}
.chip-gs:hover {
    background-color: #EBEFF2;
    color: #05090D;
}
@media screen and (min-width: 768px) {
    .events-padding {
        padding-top: var(--pt-tab);
        padding-bottom: var(--pb-tab);
    }
}
@media screen and (min-width: 1024px) {
    .events-padding {
        padding-top: var(--pt-desk);
        padding-bottom: var(--pb-desk);
    }
}
</style>

{% schema %}
{
"name": "Events",
"settings": [
{
"type": "header",
"content": "Contenuti"
},
{
"type": "text",
"id": "chip_all",
"label": "Testo Chip Tutti",
"default": "Tutti gli eventi"
},
{
"type": "text",
"id": "event-slider-title",
"label": "Titolo Sezione",
"default": "ARCHIVIO EVENTI"
},
{
"type": "text",
"id": "event-slider-date",
"label": "Label Data",
"default": "Data"
},
{
"type": "text",
"id": "event-slider-location",
"label": "Label Luogo",
"default": "Luogo"
},
{
"type": "text",
"id": "event-slider-cta2-label",
"label": "Label Bottone",
"default": "Discover more"
},
{
"type": "header",
"content": "Padding Desktop (1024px+)"
},
{
"type": "range",
"id": "pt_desk",
"label": "Padding Superiore Desktop",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 96
},
{
"type": "range",
"id": "pb_desk",
"label": "Padding Inferiore Desktop",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 96
},
{
"type": "header",
"content": "Padding Tablet (768px - 1023px)"
},
{
"type": "range",
"id": "pt_tab",
"label": "Padding Superiore Tablet",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 80
},
{
"type": "range",
"id": "pb_tab",
"label": "Padding Inferiore Tablet",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 80
},
{
"type": "header",
"content": "Padding Mobile (0px - 767px)"
},
{
"type": "range",
"id": "pt_mob",
"label": "Padding Superiore Mobile",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 32
},
{
"type": "range",
"id": "pb_mob",
"label": "Padding Inferiore Mobile",
"min": 0, "max": 200, "step": 4, "unit": "px", "default": 32
}
],
"presets": [
{
"name": "Events",
"category" : "Event sections"
}
]
}
{% endschema %}