<div id="{{ section.settings.id }}" 
     class="top-view-section w-full h-auto flex flex-col items-center justify-center py-[64px] md:py-[96px] lg:py-[128px] bg-white_gs bg-truffle_gsp">

  <div class="px-[16px] mb-[24px] lg:mb-[64px] w-full flex flex-col gap-6 justify-center items-start lg:items-center">
    <h2 class="heading-md_gs heading-md_gsp text-data_gs text-EBEFF2_gsp uppercase">{{ section.settings.title_layout }}</h2>
    <div class="relative flex items-center bg_gs bg_gsp rounded-full p-1 w-fit">
      <span class="category-slider-bg absolute h-[calc(100%-8px)] top-[4px] left-[4px] bg-blue_gs bg-truffle_gsp rounded-full transition-all duration-300 ease-in-out"></span>
      {% for block in section.blocks %}
        {% if block.settings.category_name != blank %}
          <div class="top-view-tab-categories cursor-pointer relative z-10 px-8 py-5 transition-colors duration-300 {% if forloop.first %}tab-active{% endif %}" 
               data-tab-index="{{ forloop.index0 }}">
            <p class="link-lg_gs link-lg_gsp">
              {{ block.settings.category_name }}
            </p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% for block in section.blocks %} 
    <div class="top-view-deck-block w-full {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
      
      <div class="top-view-cta-wrapper relative w-full px-[16px] lg:px-[80px] mb-8 lg:mb-12 flex justify-start lg:justify-center">
        <div class="inline-flex flex-row items-center justify-center gap-x-0 border-b border-[#BEBEBE] relative no-scrollbar overflow-x-auto">
          {% for i in (1..7) %}
            {% capture tab_label %}tab_{{ i }}_label{% endcapture %}
            {% capture tab_image %}tab_{{ i }}_image{% endcapture %}
            {% if block.settings[tab_label] != blank and block.settings[tab_image] %}
              <button type="button" 
                      class="top-view-cta-toggle px-3 py-2 body-sm_gs body-sm_gsp lg:body-md_gs lg:body-md_gsp whitespace-nowrap transition-colors duration-300 {% if forloop.first %}active{% endif %}" 
                      data-tab-id="{{ i }}">
                {{ block.settings[tab_label] }}
              </button>
            {% endif %}
          {% endfor %}
          <span class="cta-underline absolute bottom-[-1px] left-0 h-[2px] bg-05090D_gs bg_gsp transition-all duration-300 ease-in-out"></span>
        </div>
      </div>

      {% for i in (1..7) %}
        {% capture tab_label %}tab_{{ i }}_label{% endcapture %}
        {% capture tab_image %}tab_{{ i }}_image{% endcapture %}
        {% if block.settings[tab_label] != blank and block.settings[tab_image] %}
          <div class="top-view-tab-content {% unless forloop.first %}hidden{% endunless %}" data-content-id="{{ i }}">
            
            <div class="xl:px-[128px] lg:px-[64px] px-[16px] w-full flex items-center justify-center mb-12">
              <img src="{{ block.settings[tab_image] | image_url: width: 1440 }}" alt="{{ block.settings[tab_label] }}" class="w-full max-w-[1440px] h-auto block">
            </div>

            <div class="w-full">
              <div class="gallery-slider-container flex flex-row gap-4 overflow-x-auto no-scrollbar xl:px-[128px] lg:px-[64px] px-[16px] scroll-smooth">
                {% for j in (1..12) %}
                  {% capture gallery_img %}tab_{{ i }}_gallery_image{{ j }}{% endcapture %}
                  {% if block.settings[gallery_img] %}
                    <div class="gallery-slide shrink-0 w-[85%] lg:w-[calc(45%-11px)] snap-start">
                      <div class="overflow-hidden rounded-[8px] aspect-[4/5] lg:aspect-[3/2]">
                        <img src="{{ block.settings[gallery_img] | image_url: width: 800 }}" 
                             class="w-full h-full object-cover" 
                             loading="lazy">
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

              <div class="flex flex-row justify-between items-center xl:px-[128px] lg:px-[64px] px-[16px] mt-8">
                  <div class="body-sm_gs body-sm_gsp md:body-md_gs md:body-md_gsp text-data_gs text-EBEFF2_gsp">
                      <span class="current-slide-num">01</span>
                      <span class="mx-2">-</span>
                      <span class="total-slides-num">01</span>
                  </div>

                  <div class="flex gap-[14px]">
                      <button class="gallery-prev flex justify-center items-center transition-all duration-300 pt-3">
                          {% if template contains 'gsp' %}{% render 'gs-arrow-left-black' %}{% else %}{% render 'gs-arrow-left-white' %}{% endif %}
                      </button>
                      <button class="gallery-next flex justify-center items-center transition-all duration-300 pb-3">
                          {% if template contains 'gsp' %}{% render 'gs-arrow-right-black' %}{% else %}{% render 'gs-arrow-right-white' %}{% endif %}
                      </button>
                  </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endfor %}
</div>

<style>
/* Deck Blocks */
.top-view-deck-block { display: none; }
.top-view-deck-block.active { display: block; }

/* Utilities */
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
.hidden { display: none !important; }

.top-view-cta-wrapper div { min-width: fit-content; }

/* Arrow Disabled State */
.gallery-prev.disabled, .gallery-next.disabled {
  opacity: 0.2;
  pointer-events: none;
  cursor: default;
}

@supports not (aspect-ratio: 1/1) {
  .aspect-\[4\/5\] { padding-top: 125%; position: relative; }
  .aspect-\[3\/2\] { padding-top: 66.66%; position: relative; }
  .aspect-\[4\/5\] img, .aspect-\[3\/2\] img { position: absolute; top: 0; left: 0; height: 100%; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const section = document.getElementById("{{ section.settings.id }}");
  if (!section) return;

  const catTabs = section.querySelectorAll('.top-view-tab-categories');
  const catSlider = section.querySelector('.category-slider-bg');
  const deckBlocks = section.querySelectorAll('.top-view-deck-block');

  function updateCategorySlider(activeTab) {
    if (!activeTab || !catSlider) return;
    catSlider.style.width = activeTab.offsetWidth + 'px';
    catSlider.style.left = activeTab.offsetLeft + 'px';
  }

  function updateUnderline(block) {
    const activeBtn = block.querySelector('.top-view-cta-toggle.active');
    const underline = block.querySelector('.cta-underline');
    if (activeBtn && underline) {
      underline.style.width = activeBtn.offsetWidth + 'px';
      underline.style.left = activeBtn.offsetLeft + 'px';
    }
  }

  function initGalleryLogic(container) {
    const scrollContainer = container.querySelector('.gallery-slider-container');
    const prevBtn = container.querySelector('.gallery-prev');
    const nextBtn = container.querySelector('.gallery-next');
    const currentSpan = container.querySelector('.current-slide-num');
    const totalSpan = container.querySelector('.total-slides-num');
    
    if (!scrollContainer) return;

    const slides = scrollContainer.querySelectorAll('.gallery-slide');
    const totalSlides = slides.length;
    if(totalSpan) totalSpan.textContent = totalSlides.toString().padStart(2, '0');

    const updateArrows = () => {
      const scrollLeft = scrollContainer.scrollLeft;
      const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
      
      // Toggle freccia sinistra
      if (scrollLeft <= 5) {
        prevBtn?.classList.add('disabled');
      } else {
        prevBtn?.classList.remove('disabled');
      }

      // Toggle freccia destra
      if (scrollLeft >= maxScroll - 5) {
        nextBtn?.classList.add('disabled');
      } else {
        nextBtn?.classList.remove('disabled');
      }

      // Update counter
      const slideWidth = slides[0]?.offsetWidth + 16 || 1;
      const index = Math.round(scrollLeft / slideWidth);
      if(currentSpan) currentSpan.textContent = (index + 1).toString().padStart(2, '0');
    };

    nextBtn?.addEventListener('click', () => {
      const step = slides[0].offsetWidth + 16;
      scrollContainer.scrollBy({ left: step, behavior: 'smooth' });
    });

    prevBtn?.addEventListener('click', () => {
      const step = slides[0].offsetWidth + 16;
      scrollContainer.scrollBy({ left: -step, behavior: 'smooth' });
    });

    scrollContainer.addEventListener('scroll', updateArrows);
    
    // Inizializzazione immediata
    setTimeout(updateArrows, 100);
  }

  catTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const index = tab.dataset.tabIndex;
      catTabs.forEach(t => t.classList.remove('tab-active'));
      tab.classList.add('tab-active');
      updateCategorySlider(tab);

      deckBlocks.forEach(block => {
        block.classList.toggle('active', block.dataset.blockIndex === index);
        if (block.classList.contains('active')) {
           const firstCta = block.querySelector('.top-view-cta-toggle');
           if (firstCta) firstCta.click();
           updateUnderline(block);
        }
      });
    });
  });

  deckBlocks.forEach(block => {
    const btns = block.querySelectorAll('.top-view-cta-toggle');
    const contents = block.querySelectorAll('.top-view-tab-content');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        contents.forEach(c => c.classList.add('hidden'));
        btn.classList.add('active');
        const target = block.querySelector(`[data-content-id="${btn.dataset.tabId}"]`);
        if (target) {
          target.classList.remove('hidden');
          initGalleryLogic(target);
        }
        updateUnderline(block);
      });
    });

    const firstContent = block.querySelector('.top-view-tab-content:not(.hidden)');
    if (firstContent) initGalleryLogic(firstContent);
  });

  const initAll = () => {
    const activeCat = section.querySelector('.top-view-tab-categories.tab-active') || catTabs[0];
    if (activeCat) updateCategorySlider(activeCat);
    deckBlocks.forEach(updateUnderline);
  };

  window.addEventListener('resize', initAll);
  setTimeout(initAll, 400);
});
</script>

