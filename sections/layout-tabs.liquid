<div id="{{ section.settings.id }}" 
     class="top-view-section w-full h-auto flex flex-col items-center justify-center py-8 lg:py-20" 
     style="background-color: {{ section.settings.bg_color }};">

  <div class="px-[16px] lg:px-[80px] mb-[32px] lg:mb-[60px] w-full flex justify-center">
    <div class="relative flex items-center bg-[#F2F2F2] rounded-full p-1 border border-[#E0E0E0] w-fit">
      <span class="category-slider-bg absolute h-[calc(100%-8px)] top-[4px] left-[4px] bg-black rounded-full transition-all duration-300 ease-in-out"></span>
      {% for block in section.blocks %}
        {% if block.settings.category_name != blank %}
          <div class="top-view-tab-categories cursor-pointer relative z-10 px-6 py-2 lg:px-10 lg:py-3 transition-colors duration-300" 
               data-tab-index="{{ forloop.index0 }}">
            <p class="text-[14px] lg:text-[18px] font-medium leading-none whitespace-nowrap uppercase tracking-wider">
              {{ block.settings.category_name }}
            </p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% for block in section.blocks %} 
    <div class="top-view-deck-block w-full {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
      
      <div class="top-view-cta-wrapper relative w-full px-[16px] lg:px-[80px] mb-8 lg:mb-12 flex justify-center">
        <div class="inline-flex flex-row items-center justify-center gap-x-8 border-b border-[#BEBEBE] relative no-scrollbar overflow-x-auto">
          {% for i in (1..7) %}
            {% capture tab_label %}tab_{{ i }}_label{% endcapture %}
            {% capture tab_image %}tab_{{ i }}_image{% endcapture %}
            {% if block.settings[tab_label] != blank and block.settings[tab_image] %}
              <button type="button" 
                      class="top-view-cta-toggle pb-3 text-[14px] lg:text-[16px] font-semibold tracking-[-0.28px] whitespace-nowrap transition-colors duration-300" 
                      data-tab-id="{{ i }}">
                {{ block.settings[tab_label] }}
              </button>
            {% endif %}
          {% endfor %}
          <span class="cta-underline absolute bottom-[-1px] left-0 h-[2px] bg-black transition-all duration-300 ease-in-out"></span>
        </div>
      </div>

      {% for i in (1..7) %}
        {% capture tab_label %}tab_{{ i }}_label{% endcapture %}
        {% capture tab_image %}tab_{{ i }}_image{% endcapture %}
        {% capture tab_content %}tab_{{ i }}_content{% endcapture %}
        {% if block.settings[tab_label] != blank and block.settings[tab_image] %}
          <div class="top-view-tab-content {% unless forloop.first %}hidden{% endunless %}" data-content-id="{{ i }}">
            <div class="w-full flex items-center justify-center">
              <img src="{{ block.settings[tab_image] | image_url: width: 1440 }}" alt="{{ block.settings[tab_label] }}" class="w-full max-w-[1440px] h-auto block">
            </div>

            <div class="w-full flex flex-col items-center pt-8 pb-8 lg:pt-16 lg:pb-12 px-[16px] lg:px-[160px]">
              <p class="text-center text-black text-[14px] leading-[20px] lg:text-[20px] lg:leading-[28px] max-w-[900px]">
                {{ block.settings[tab_content] }}
              </p>
            </div>

            <div class="w-full lg:px-[160px] px-[16px] mb-12">
              <div class="gallery-slider-container flex flex-row gap-4 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-4">
                {% for j in (1..10) %}
                  {% capture gallery_img %}tab_{{ i }}_gallery_image{{ j }}{% endcapture %}
                  {% if block.settings[gallery_img] %}
                    <div class="gallery-slide shrink-0 w-[85%] lg:w-[calc(33.333%-11px)] snap-start">
                      <div class="overflow-hidden rounded-[8px]">
                        <img src="{{ block.settings[gallery_img] | image_url: width: 800 }}" 
                             class="w-full object-cover wh-image-slider" 
                             loading="lazy">
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endfor %}
</div>

<style>
/* Categorie & Labels */
.top-view-tab-categories { color: #888; }
.top-view-tab-categories.active-tab { color: #FFFFFF; }
.top-view-cta-toggle { color: #888; background: transparent; border: none; cursor: pointer; }
.top-view-cta-toggle.active { color: #000000; }

/* Deck Blocks */
.top-view-deck-block { display: none; }
.top-view-deck-block.active { display: block; }

/* Slider Gallery */
.gallery-slider-container {
  -webkit-overflow-scrolling: touch;
}
.wh-image-slider { 
  height: 250px !important; 
  width: 100%;
}
@media (min-width: 1024px) { 
  .wh-image-slider { height: 400px !important; } 
}

/* Utilities */
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
.hidden { display: none !important; }

/* Forza allineamento centro per contenitore scrollabile */
.top-view-cta-wrapper div {
  min-width: fit-content;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const section = document.getElementById("{{ section.settings.id }}");
  if (!section) return;

  const catTabs = section.querySelectorAll('.top-view-tab-categories');
  const catSlider = section.querySelector('.category-slider-bg');
  const deckBlocks = section.querySelectorAll('.top-view-deck-block');

  function updateCategorySlider(activeTab) {
    if (!activeTab || !catSlider) return;
    catSlider.style.width = activeTab.offsetWidth + 'px';
    catSlider.style.left = activeTab.offsetLeft + 'px';
  }

  function updateUnderline(block) {
    const activeBtn = block.querySelector('.top-view-cta-toggle.active');
    const underline = block.querySelector('.cta-underline');
    if (activeBtn && underline) {
      underline.style.width = activeBtn.offsetWidth + 'px';
      underline.style.left = activeBtn.offsetLeft + 'px';
    }
  }

  // Categorie
  catTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const index = tab.dataset.tabIndex;
      catTabs.forEach(t => t.classList.remove('active-tab'));
      tab.classList.add('active-tab');
      updateCategorySlider(tab);

      deckBlocks.forEach(block => {
        block.classList.toggle('active', block.dataset.blockIndex === index);
        if (block.classList.contains('active')) {
           const firstCta = block.querySelector('.top-view-cta-toggle');
           if (firstCta) firstCta.click();
        }
      });
    });
  });

  // Labels
  deckBlocks.forEach(block => {
    const btns = block.querySelectorAll('.top-view-cta-toggle');
    const contents = block.querySelectorAll('.top-view-tab-content');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('active'));
        contents.forEach(c => c.classList.add('hidden'));
        btn.classList.add('active');
        const target = block.querySelector(`[data-content-id="${btn.dataset.tabId}"]`);
        if (target) target.classList.remove('hidden');
        updateUnderline(block);
      });
    });
  });

  // Init
  const initAll = () => {
    const activeCat = section.querySelector('.top-view-tab-categories.active-tab') || catTabs[0];
    if (activeCat) {
      activeCat.classList.add('active-tab');
      updateCategorySlider(activeCat);
    }
    deckBlocks.forEach(updateUnderline);
  };

  window.addEventListener('resize', initAll);
  // Ritardo per caricamento font/layout
  setTimeout(initAll, 400);
});
</script>

