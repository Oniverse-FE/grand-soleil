        background-color: white;
        transform: translateX(0%);
        transition: transform 2s ease;
    }
    .group-form:hover .underline-form {
        transform: translateX(100%);
    }
    .group-form:hover .cta-underline-form {
        animation: enter-line 1.2s ease forwards;
        animation-delay: 0.8s;
        opacity: 1;
    }
    @keyframes enter-line {
        0% {
            transform: translateX(-100%);
        }
        100% {
            transform: translateX(0);
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('news_form');
    if (!form) return;

    const $ = sel => form.querySelector(sel);
    const $$ = sel => Array.from(form.querySelectorAll(sel));
    const tagsInput = $('#CustomerTags');
    const noteInput = $('#CustomerNote');
    const submitButton = $('#news-form-submit');

    if (submitButton) submitButton.disabled = false;

    const lang = window.location.pathname.includes('/it/') ? 'it' : 'en';

    const errorMessages = {
        'contact[first_name]': { it: 'Inserisci il tuo nome', en: 'Enter your first name' },
        'contact[last_name]': { it: 'Inserisci il tuo cognome', en: 'Enter your last name' },
        'contact[email]': { it: 'Inserisci un’email valida', en: 'Enter a valid email' },
        'contact[phone-number-phone]': { it: 'Inserisci un numero di telefono valido', en: 'Enter a valid phone number' },
        'contact[phone-prefix-phone]': { it: '', en: '' },
        'contact[boat-question]': { it: 'Seleziona una delle opzioni', en: 'Select one of the options' },
        'contact[boat-selection]': { it: 'Seleziona almeno una barca se richiesta', en: 'Select at least one boat if required' },
        'contact[country]': { it: 'Seleziona un paese', en: 'Select a country' }
    };

    // ===== LOGICA CONSENSI =====
    const marketingCheckbox = $('#news-form-marketingConsent');
    const profilingCheckbox = $('#news-form-profilingConsent');
    if (profilingCheckbox) profilingCheckbox.disabled = true;

    if (marketingCheckbox && profilingCheckbox) {
        marketingCheckbox.addEventListener('change', function () {
            if (this.checked) profilingCheckbox.disabled = false;
            else { profilingCheckbox.disabled = true; profilingCheckbox.checked = false; }
        });
    }

    // ===== COUNTRY DROPDOWN =====
    let allCountries = [];
    fetch('https://raw.githubusercontent.com/mledoze/countries/master/countries.json')
        .then(res => res.json())
        .then(data => allCountries = data.map(c => ({ name: c.name.common, code: c.cca2.toLowerCase() })))
        .catch(err => console.error(err));

    const countryInputs = document.querySelectorAll('.country-input');
    countryInputs.forEach(input => {
        const container = input.closest('.flex.flex-col.gap-1.relative');
        if (!container) return;
        const ul = container.querySelector('.countryList');
        const flagContainer = container.querySelector('.country-flag');
        const arrowContainer = container.querySelector('.country-arrow');

        input.addEventListener('click', e => { 
            e.stopPropagation(); 
            clearFieldError(input); 
            toggleDropdown(true, ul, input, flagContainer, arrowContainer); 
        });

        input.addEventListener('input', () => { 
            clearFieldError(input); 
            filterCountries(input, ul, flagContainer, arrowContainer); 
        });

        input.addEventListener('blur', () => setTimeout(() => { 
            if (ul && !ul.classList.contains('hidden')) 
                toggleDropdown(false, ul, input, flagContainer, arrowContainer); 
        }, 150));

        // Permette di cliccare la freccia per aprire/chiudere il dropdown
        if (arrowContainer) {
            arrowContainer.addEventListener('click', e => {
                e.stopPropagation();
                const isOpen = !ul.classList.contains('hidden');
                toggleDropdown(!isOpen, ul, input, flagContainer, arrowContainer);
            });
        }
    });

    function setFlag(country, code, flagContainer, arrowContainer) {
        if (!flagContainer) return;
        flagContainer.innerHTML = `
            <div class="flex items-center gap-[10px]">
                <img src="https://flagcdn.com/w40/${code}.png"
                     alt="Flag of ${country}"
                     class="w-5 h-4 rounded-sm object-cover translate-x-[-3px]">
                <span class="country-name">${country}</span>
            </div>
        `;
        flagContainer.style.opacity = 1;
        flagContainer.classList.remove('hidden');

        if (arrowContainer) {
            arrowContainer.classList.remove('hidden');
            arrowContainer.style.marginLeft = '10px';
        }
    }

    function toggleDropdown(show, ul, input, flagContainer, arrowContainer) {
        if (!ul) return;
        if (show) {
            ul.classList.remove('hidden');
            if (input) filterCountries(input, ul, flagContainer, arrowContainer);
            arrowContainer?.classList.add('open');
        } else {
            ul.classList.add('hidden');
            arrowContainer?.classList.remove('open');
        }
    }

    function filterCountries(input, ul, flagContainer, arrowContainer) {
        if (!input || !ul) return;
        const filter = input.value.toLowerCase();

        if (!filter.trim()) {
            if (flagContainer) {
                flagContainer.innerHTML = '';
                flagContainer.classList.add('hidden');
            }
        }

        ul.innerHTML = '';
        const countriesToShow = !filter.trim()
            ? allCountries.slice(0, 250)
            : allCountries.filter(c => c.name.toLowerCase().includes(filter));

        countriesToShow.forEach(c => {
            const li = document.createElement('li');
            li.className = 'px-4 py-2 m-2 hover:bg-black bg-antracite cursor-pointer flex items-center gap-2 rounded-lg';
            li.innerHTML = `<img src="https://flagcdn.com/w40/${c.code}.png" alt="Flag of ${c.name}" class="w-5 h-4 rounded-sm object-cover"><span>${c.name}</span>`;
            li.addEventListener('mousedown', e => {
                e.preventDefault();
                input.value = c.name;
                setFlag(c.name, c.code, flagContainer, arrowContainer);
                input.dispatchEvent(new Event('input',{bubbles:true}));
                toggleDropdown(false, ul, input, flagContainer, arrowContainer);
                input.focus();
            });
            ul.appendChild(li);
        });

        if (countriesToShow.length === 0) {
            const li = document.createElement('li');
            li.className = 'px-4 py-2 m-2 text-sm text-gray-400';
            li.textContent = lang==='it'?'Nessun paese trovato':'No countries found';
            ul.appendChild(li);
        }
    }

    // ===== ERROR HANDLING =====
    function createErrorMessageNode(text) { const el = document.createElement('div'); el.className='error-message'; el.textContent=text; return el; }
    function clearFieldError(input) { if (!input) return; input.classList.remove('error'); const next=input.nextElementSibling; if(next && next.classList.contains('error-message')) next.remove(); }
    function setFieldError(input, key) { if(!input) return; clearFieldError(input); input.classList.add('error'); const msgText=errorMessages[key]?errorMessages[key][lang]:(lang==='it'?'Campo obbligatorio':'Required field'); input.insertAdjacentElement('afterend', createErrorMessageNode(msgText)); }
    function validateEmail(value){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value); }
    function validatePhone(value){ if(!value) return false; const cleaned=value.trim(); const basic=/^[+]?[\d\s().-]{6,}$/; if(!basic.test(cleaned)) return false; const digits=cleaned.replace(/\D/g,''); return digits.length>=5; }

    form.querySelectorAll('input, textarea').forEach(input => input.addEventListener('input', () => clearFieldError(input)));

    // ===== MULTI-CHECKBOX BARCHE =====
    form.querySelectorAll('[data-name="contact[boat-selection]"] label').forEach(label => {
        const checkbox = label.querySelector("input[type=checkbox]");
        const icon = label.querySelector("span");
        label.addEventListener('click', e => {
            e.preventDefault();
            if(!checkbox) return;
            checkbox.checked=!checkbox.checked;
            if(checkbox.checked){
                label.classList.add("bg-white","text-black");
                label.classList.remove("bg-antracite","text-white");
                icon?.classList.remove("hidden");
            } else {
                label.classList.add("bg-antracite","text-white");
                label.classList.remove("bg-white","text-black");
                icon?.classList.add("hidden");
            }
            const hiddenBoat=$('#contact-form-boat-selection');
            if(hiddenBoat){
                const selected=Array.from(form.querySelectorAll('.multi-checkbox:checked')).map(cb=>cb.value);
                hiddenBoat.value=selected.join(', ');
                hiddenBoat.dispatchEvent(new Event('change',{bubbles:true}));
            }
        });
    });

    // ===== CAMPI CONDIZIONALI RADIO =====
    const conditionalRadios = ['contact[boat-question]'];
    conditionalRadios.forEach(name => {
        const radios = $$(`input[name="${name}"]`);
        radios.forEach(radio => {
            radio.dataset.wasChecked = radio.checked ? "true" : "false";
            radio.addEventListener('change', () => {
                radios.forEach(r => {
                    const targetId = r.dataset.target;
                    if(targetId){
                        const target = document.getElementById(targetId);
                        if(target) target.classList.add('hidden');
                    }
                });
                if(radio.checked && radio.dataset.target){
                    const target=document.getElementById(radio.dataset.target);
                    if(target) target.classList.remove('hidden');
                }
            });
        });
    });

    document.addEventListener('click', e=>{
        const radio=e.target;
        if(radio.matches && radio.matches('input[type="radio"]')){
            if(radio.checked && radio.dataset.wasChecked==="true"){ radio.checked=false; radio.dataset.wasChecked="false"; radio.dispatchEvent(new Event('change',{bubbles:true})); }
            else{ const group=document.querySelectorAll(`input[name="${radio.name}"]`); group.forEach(r=>r.dataset.wasChecked="false"); radio.dataset.wasChecked="true"; }
        }
    });

    // ===== SUBMIT FORM =====
    submitButton.addEventListener('click', e => {
        e.preventDefault();
        form.querySelectorAll('.error-message').forEach(el=>el.remove());
        form.querySelectorAll('.error').forEach(el=>el.classList.remove('error'));
        let hasError=false;
        const requiredInputs = Array.from(form.querySelectorAll('[required]'));
        requiredInputs.forEach(input=>{
            const name=input.name; const value=(input.value||'').trim();
            if(!value){ hasError=true; setFieldError(input,name); return; }
            if(name==='contact[email]'&&!validateEmail(value)){ hasError=true; setFieldError(input,name); }
            if(name==='contact[phone]'&&!validatePhone(value)){ hasError=true; setFieldError(input,name); }
        });
        if(hasError) return;

        const tags=['news']; if(marketingCheckbox?.checked) tags.push('marketing'); if(profilingCheckbox?.checked) tags.push('profiling');
        const boats=Array.from(form.querySelectorAll('.multi-checkbox:checked')).map(cb=>cb.value);
        boats.forEach(b=>tags.push(b.replace(/\s+/g,'-')));
        if(tagsInput) tagsInput.value=[...new Set(tags)].join(',');
        const noteLines=[]; if(boats.length) noteLines.push("Selected Boats: "+boats.join(", ")); if(noteInput) noteInput.value=noteLines.join("\n");

        const formData=new FormData(form);
        fetch(form.action,{method:"POST",body:formData,headers:{"Accept":"application/json"}})
            .then(res=>res.ok?showThankYouPopup():res.json().then(err=>alert(lang==='it'?"Errore: "+JSON.stringify(err):"Error: "+JSON.stringify(err))))
            .catch(err=>alert(lang==='it'?"Si è verificato un errore durante l'invio.":"An error occurred while submitting."));
    });

    // ===== POPUP RINGRAZIAMENTO =====
    const thankYouPopup=document.getElementById("thankyou-popup");
    const closeTyBtns=[document.getElementById("news-form-ty-close"),document.getElementById("news-form-ty-close-btn")];

    function showThankYouPopup(){ if(!thankYouPopup) return; thankYouPopup.classList.remove("hidden"); thankYouPopup.classList.add("flex","items-center","justify-center","backdrop-blur-xl","bg-[#101010]/60"); document.body.style.overflow="hidden"; }
    function hideThankYouPopup(){ if(!thankYouPopup) return; thankYouPopup.classList.add("hidden"); thankYouPopup.classList.remove("flex","items-center","justify-center","backdrop-blur-xl","bg-[#101010]/60"); document.body.style.overflow=""; }

    closeTyBtns.forEach(btn=>btn?.addEventListener("click",hideThankYouPopup));
    if(thankYouPopup){
        thankYouPopup.addEventListener("click",e=>{
            const content=thankYouPopup.querySelector(".popup-content");
            if(!content.contains(e.target)) hideThankYouPopup();
        });
    }
});
</script>

