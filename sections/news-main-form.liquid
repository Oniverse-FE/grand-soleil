<div class="flex flex-col gap-3 lg:gap-4 text-white px-4 md:px-12 lg:px-24 py-30 lg:py-40 pt-0 lg:pt-0">
    <!-- link to all news -->
    <div class="flex text-white uppercase font-semibold text-sm leading-5 lg:text-[16px] lg:leading-[22px] mb-[96px] md:mb-[160px] lg:mb-[128px] group-form animation-form">
        <a href="{{ section.settings.link-to-news-page.url }}" class="font-semibold text-sm leading-5 lg:text-[16px] lg:leading-[22px] uppercase text-white body-semibold w-fit relative">
            <span class="mb-[6px]">{{ section.settings.link-to-news-label }}</span>
            <span class="underline-form cta-underline-form"></span>
        </a>
        </div>

    <div class="flex flex-col lg:flex-row justify-between w-full gap-10 lg:gap-20">
        <div class="flex flex-col gap-0 lg:gap-10 w-full md:w-[437px] lg:w-5/12">
        <div class="flex h6 uppercase text-[36px] leading-[42px] md:text-[56px] md:leading-[62px]">
            {{ section.settings.news-intro-title }}
        </div>
            <div class="flex body-regular text-[16px] leading-[22px] md:text-[18px] md:leading-[24px] w-full">
                {{ section.settings.news-intro-text }}
            </div>
            <div class="flex flex-col gap-2">
                {% for block in section.blocks %}
                <div class="flex justify-between bg-antracite rounded-[10px] py-2.5 px-4 w-full gap-12">
                    <div class="flex body-regular text-[14px] leading-[20px] lg:text-[16px] lg:leading-[22px]">
                        {{ block.settings.news-line-type }}
                    </div>
                    <div class="flex text-right body-semibold text-[14px] leading-[20px] lg:text-[16px] lg:leading-[22px]">
                        {{ block.settings.news-line-value }}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        <div class="lg:w-1/2">
        {% form 'customer', id: 'news_form' %}

        <div id="news-form-box"
            class="flex flex-col overflow-y-auto overflow-visible rounded-xl lg:px-8 lg:py-8 py-6 px-4 gap-16"
            style="background-color: {{ section.settings.news-form-bg-color }}; color: {{ section.settings.news-form-text-color }}">

            <div class="flex flex-col gap-12">
                <div class="flex flex-col gap-6">
                        <div class="flex flex-col">
                            <div class="flex justify-between">
                                <div class="body-medium text-[18px] leading-[24px] lg:text-xl">{{ section.settings.news-form-title }}</div>
                            </div>
                        </div>

                        <div class="flex justify-end text-[12px] leading-[18px] md:text-[14px] md:leading-[20px] body-regular">
                            {{ section.settings.news-form-required-text }}
                        </div>
                        <div class="flex flex-col gap-1">
                            <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">
                                {{ section.settings.news-fname-label}}{% if section.settings.news-fname-required
                                == true %}*{%
                                endif %}
                            </div>
                            <input class="body-regular placeholder-[#D6CBC9] text-white text-[16px] leading-[22px] py-1 border-b-1 border-white"
                                type="text" id="news-form-first-name" name="contact[first_name]"
                                placeholder="{{- section.settings.news-fname-placeholder }}" {% if
                                section.settings.news-fname-required==true %} required {% endif %}>
                        </div>

                        <div class="flex flex-col gap-1">
                            <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">
                                {{ section.settings.news-lname-label}}{% if section.settings.news-lname-required
                                == true %}*{%
                                endif %}
                            </div>
                            <input class="body-regular placeholder-[#D6CBC9] text-white text-[16px] leading-[22px] py-1 border-b-1 border-white"
                                type="text" id="news-form-last-name" name="contact[last_name]"
                                placeholder="{{- section.settings.news-lname-placeholder }}" {% if
                                section.settings.news-lname-required==true %} required {% endif %}>
                        </div>
                        <div id="phone-fields-phone" class="flex flex-row gap-4 lg:gap-6 my-6 w-full">
                                <div class="flex flex-col gap-1 w-[47px]">
                                    <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">{{
                                        section.settings.news-prefix-label  }}</div>
                                    <input
                                        class="input-field body-regular text-white placeholder-[#D6CBC9] text-[16px] leading-[22px] py-1 border-b-1 border-white"
                                        type="text" id="phone-prefix-phone" name="contact[phone-prefix-phone]"
                                        placeholder="{{ section.settings.news-prefix-placeholder }}" {% if
                                section.settings.news-phone-required==true %} required {% endif %}>
                                </div>
                                <div class="flex flex-col gap-1 w-full relative">
                                    <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">{{
                                        section.settings.news-phone-label }}</div>
                                    <input
                                        class="input-field body-regular text-white placeholder-[#D6CBC9] text-[16px] leading-[22px] py-1 border-b-1 border-white"
                                        type="tel" id="phone-number-phone" name="contact[phone-number-phone]"
                                        placeholder="{{ section.settings.news-phone-placeholder }}" {% if
                                section.settings.news-phone-required==true %} required {% endif %}>
                                </div>
                            </div>

                        <div class="flex flex-col gap-1">
                            <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">
                                {{ section.settings.news-mail-label}}{% if section.settings.news-mail-required ==
                                true %}*{%
                                endif %}
                            </div>
                            <input class="body-regular placeholder-[#D6CBC9] text-white text-[16px] leading-[22px] py-1 border-b-1 border-white"
                                type="email" id="news-form-mail" name="contact[email]"
                                placeholder="{{- section.settings.news-mail-placeholder }}" {% if
                                section.settings.news-mail-required==true %} required {% endif %}>
                        </div>
                </div>
                <div class="body-regular text-[#D6CBC9] text-[16px] leading-[22px] flex flex-col gap-4">
                    <div class="flex ">
                        {{ section.settings.news-boat-sel-label }}{% if section.settings.news-boat-sel-required ==
                        true %}*{%
                        endif %}
                    </div>
                    {% assign options = section.settings.options | split: ',' %}
                    <div class="flex flex-wrap gap-2" data-name="contact[boat-selection]">
                        {% for option in options %}
                        {% assign clean_option = option | strip %}
                        <label
                            class="flex gap-1 py-1.5 px-3 bg-[#f8f8f8] border-1 border-white cursor-pointer relative text-white transition-all body-regular text-[16px] leading-[22px] bg-antracite rounded-4xl">
                            <input type="checkbox" class="multi-checkbox" value="{{ clean_option }}" hidden>
                            {{ clean_option }}
                            <span class=" hidden cursor-pointer">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="size-5 text-black">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                </svg>
                            </span>
                        </label>
                        {% endfor %}
                    </div>

                    <input type="hidden" name="contact[boat-selection]" id="news-form-boat-selection" {% if
                        section.settings.news-boat-sel-required %} required {% endif %}>
                </div>

                <div class="body-regular text-[16px] leading-[22px] flex flex-col gap-4">
                    <div class="flex text-[#D6CBC9]">
                        {{ section.settings.news-boat-q-label }}{% if section.settings.news-boat-q-required ==
                        true %}*{%
                        endif %}
                    </div>

                    <div class="flex flex-col gap-2">
                        <div class="flex flex-col gap-2">
                            <div class="flex gap-2 justify-start items-center">
                                <input type="radio"
                                    class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                    id="boat-y" name="contact[boat-question]" value="vd" data-target="boat-y-fields">
                                <label for="boat-y">{{ section.settings.news-boat-q-affermative-label }}</label>
                            </div>
                            <div id="boat-y-fields" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                                <div class="flex flex-col gap-1 w-full">
                                    <div class="flex text-[#D6CBC9] body-regular text-[12px] leading-[18px]">{{
                                        section.settings.news-form-boat-q-model-label }}</div>
                                    <input
                                        class="body-regular text-white text-[16px] placeholder-[#D6CBC9] leading-[22px] border-b-1 py-1 border-white"
                                        type="text" id="boat-y-model" name="contact[boat-y-model]"
                                        placeholder="{{ section.settings.news-form-boat-q-model-placeholder }}">
                                </div>
                                <div class="flex flex-col gap-1 relative w-full">
                                    <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">{{
                                        section.settings.news-form-boat-q-port-label }}</div>
                                    <input
                                        class="body-regular text-white text-[16px] placeholder-[#D6CBC9] leading-[22px] border-b-1 py-1 border-white pr-10 country-input"
                                        type="text" name="contact[boat-y-port-country]" id="boat-y-port-country"
                                        placeholder="{{ section.settings.news-form-boat-q-port-placeholder}}"
                                        autocomplete="off">
                                    <div
                                        class="country-flag absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none">
                                    </div>
                                    <div class="country-arrow absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none transition-transform duration-300">
                                        <svg class="transform transition-transform duration-300" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M4 8L10.5858 14.5858C11.3668 15.3668 12.6332 15.3668 13.4142 14.5858L20 8" stroke="white" stroke-linecap="round"/>
                                        </svg>
                                    </div>
                                    <ul
                                        class="countryList absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <div class="flex gap-2 justify-start items-center">
                                <input type="radio"
                                    class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                    id="boat-o" name="contact[boat-question]" value="other" data-target="boat-o-fields">
                                <label for="boat-o">{{ section.settings.news-boat-q-other-label }}</label>
                            </div>
                            <div id="boat-o-fields" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                                <div class="flex flex-col gap-1 w-full">
                                    <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">{{
                                        section.settings.news-form-boat-q-model-label }}</div>
                                    <input
                                        class="body-regular text-white text-[16px] placeholder-[#D6CBC9] leading-[22px] py-1 border-b-1 border-white"
                                        type="text" id="boat-o-model" name="contact[boat-o-model]"
                                        placeholder="{{ section.settings.news-form-boat-q-model-placeholder}}">
                                </div>
                                <div class="flex flex-col gap-1 relative w-full">
                                    <div class="flex body-regular text-[#D6CBC9] text-[12px] leading-[18px]">{{
                                        section.settings.news-form-boat-q-port-label}}</div>
                                    <input
                                        class="body-regular text-white text-[16px] placeholder-[#D6CBC9] leading-[22px] py-1 border-b-1 border-white pr-10 country-input"
                                        type="text" name="contact[boat-o-port-country]" id="boat-o-port-country"
                                        placeholder="{{ section.settings.news-form-boat-q-port-placeholder}}"
                                        autocomplete="off">
                                    <div
                                        class="country-flag absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none">
                                    </div>
                                    <div class="country-arrow absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none transition-transform duration-300">
                                        <svg class="transform transition-transform duration-300" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M4 8L10.5858 14.5858C11.3668 15.3668 12.6332 15.3668 13.4142 14.5858L20 8" stroke="white" stroke-linecap="round"/>
                                        </svg>
                                    </div>
                                    <ul
                                        class="countryList absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="flex gap-2 justify-start items-center">
                            <input type="radio"
                                class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                id="boat-n" name="contact[boat-question]" value="no" data-target="">
                            <label for="boat-n">{{ section.settings.news-boat-q-negative-label }}</label>
                        </div>
                    </div>
                </div>

            </div>
            <div class="flex flex-col gap-6 text-[18px]">
                <div class="flex items-center h-auto gap-4">
                    <input style="aspect-ratio:1/1" type="checkbox"
                        class="w-6 h-6 rounded-sm appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                        id="news-form-marketingConsent">
                    <label class="w-auto" id="news-form-profilingLabel">
                        {{ section.settings.news-form-markConsLabel }}
                        <u><a id="news-form-shortMarketing">{{ section.settings.news-form-privacy-label | default:
                                "Privacy
                                Policy"
                                }}</a></u>
                    </label>
                </div>
                <div class="flex items-center h-auto gap-4">
                    <input style="aspect-ratio:1/1" type="checkbox"
                        class="appearance-none w-6 h-6 rounded-sm border-1 border-white bg-transparent checked:bg-white transition-all duration-200 disabled:border-[#ACACAC]"
                        id="news-form-profilingConsent" disabled>
                    <label class="text-white transition-colors duration-200" id="news-form-profilingLabel">
                        {{ section.settings.news-form-profConsLabel }}
                        <u><a id="news-form-shortProfiling">{{ section.settings.news-form-privacy-label | default:
                                "Privacy
                                Policy"
                                }}</a></u>
                    </label>
                </div>
                <u><a href="{{ section.settings.news-privacy-url }}">{{ section.settings.news-form-privacy-label |
                    default: "Privacy
                    Policy" }}</a></u>
            </div>

            <div class="flex body-medium h-[42px] justify-center tk-aktiv-grotesk">
                <button id="news-form-submit" aria-label="{{ section.settings.news-form-submit-button-text }}" type="submit" class="news-submit-btn w-full px-7 py-3.5 rounded-4xl text-[16px] leading-[14px] font-semibold w-[300px] transition-all duration-300"
                        style="color: {{ section.settings.news-form-button-text-color }};background-color: {{ section.settings.news-form-button-background-color }};border: 1px solid {{ section.settings.news-form-button-border-color }};">
                            {{ section.settings.news-form-submit-button-text }}
                </button>
            </div>

            <input type="hidden" name="contact[tags]" id="CustomerTags">
            <input type="hidden" name="contact[note]" id="CustomerNote">
            <input type="hidden" id="eventHandle" value="">
            <input type="hidden" id="eventTitle" value="">


        </div>
        {% endform %}
        </div>
    </div>
</div>
<div id="thankyou-popup" class="fixed inset-0 top-0 left-0 flex justify-center items-center w-screen h-screen bg-black/50 z-50 hidden transition-opacity duration-300">
    <div class="popup-content fixed inset-0 flex items-center justify-center">
        <div class="flex flex-col w-full max-w-[720px] h-fit items-center justify-start lg:justify-center bg-[#292929] text-white py-6 px-6 gap-6 lg:mx-0 lg:px-14 lg:py-10 lg:gap-10 rounded-xl">
            <div class="flex flex-row justify-between w-full">
                <div class="hidden lg:flex size-6"></div>
                <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">
                    {{ section.settings.news-form-ty-title }}
                </h6>
                <button id="news-form-ty-close" aria-label="Chiudi">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                            fill="white" />
                    </svg>
                </button>
            </div>
            <div class="text-start lg:text-center">
                {{ section.settings.news-form-ty-text }}
            </div>
            <div>
                <button class="w-[342px] lg:w-[234px] py-3.5 px-7 body-semibold text-[16px] leading-[14px] bg-white text-black rounded-4xl" id="news-form-ty-close-btn">
                    {{ section.settings.news-form-ty-btn-label }}
                </button>
            </div>
        </div>
    </div>
</div>

<div id="news-form-marketing-overlay"
    class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
    <div
        class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
        <div class="flex flex-row justify-between">
            <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.news-form-marketing-title }}
            </h6>
            <button id="news-form-marketing-close" aria-label="Chiudi">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                        fill="white" />
                </svg>
            </button>
        </div>
        <div>
            {{ section.settings.news-form-marketing-text }} <u><a href="{{ section.settings.news-form-privacy-page }}">{{
                    section.settings.news-form-privacy-label | default:
                    "Privacy Policy" }}</a></u>
        </div>
    </div>
</div>

<div id="news-form-profiling-overlay"
    class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
    <div
        class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
        <div class="flex justify-between">
            <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.news-form-profiling-title }}
            </h6>
            <button id="news-form-profiling-close" aria-label="Chiudi">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                        fill="white" />
                </svg>
            </button>
        </div>
        <div>
            {{ section.settings.news-form-profiling-text }} <u><a href="{{ section.settings.news-form-privacy-page }}">{{
                    section.settings.privacy-label | default:
                    "Privacy Policy" }}</a></u>
        </div>
    </div>
</div>

<style>
    #countryList::-webkit-scrollbar {
        display: none;
    }
    #news-form-profilingConsent:disabled + #news-form-profilingLabel {
        color: #ACACAC;
    }
    #countryList {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    #news-form-box input[type="text"],
    #news-form-box input[type="email"],
    #news-form-box input[type="phone"],
    #news-form-box input[type="tel"] {
        border-bottom: 1px solid white;
        background: transparent;
        color: white;
        transition: border-color 0.3s ease;
    }

    #news-form-box input[type="text"]:focus,
    #news-form-box input[type="email"]:focus,
    #news-form-box input[type="phone"]:focus,
    #news-form-box input[type="tel"]:focus {
        outline: none;
        border-bottom: 1px solid #F76C00;
    }

    #news-form-box .error {
        border-bottom: 1px solid #FF575C !important;
    }

    .error-message {
        color: #FF575C;
        font-size: 12px;
        margin-top: 4px;
        line-height: 18px;
    }

    #news-form-box .textarea-wrapper:focus-within {
        border-bottom: 1px solid #F76C00;
    }

    #news-form-box textarea:focus {
        outline: none;
    }

    .country-arrow.open svg {
        transform: rotate(180deg) !important;
    }

    .country-name {
        display:none;
    }

    .country-arrow {
        margin-left: 10px !important;
        cursor: pointer;
        transition: transform 0.2s ease;
    }
    .country-flag{
        right: 28px !important;
    }

    @media (max-width: 1024px) {
        .popup-content{
            margin-inline: 16px !important;
        }
    }
    .news-submit-btn {
        transition: all 0.3s ease;
    }

    .news-submit-btn:hover {
        filter: brightness(1.1);
        opacity: 75%;
    }
    .group-form a {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .underline-form {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 1px;
        width: 100%;
        background-color: white;
        opacity: 0;
        transform: translateX(-100%);
        transition: transform 2s ease;
    }
    .cta-underline-form {
        position: absolute;
        bottom: 0;
