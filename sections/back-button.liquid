<div class="bg_gs bg_gsp px-4 md:px-40 lg:px-[64px] xl:px-[128px]" 
     style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  
  <a href="{{ section.settings.back_url | default: '#' }}" 
     class="group inline-flex items-center gap-4 no-underline transition-all">
    
    <span class="flex items-center justify-center transform transition-transform ">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M22 12H2L11 22V16" stroke="#EBEFF2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>

    <span class="link-md_gs md:link-md_gs text-color_gs">
      {{ section.settings.label }}
    </span>
    
  </a>
</div>

{% schema %}
{
  "name": "Back button",
  "settings": [
    {
      "type": "url",
      "id": "back_url",
      "label": "Pagina di destinazione"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Testo del link",
      "default": "Torna indietro"
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Superiore",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferiore",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Back button",
      "category" : "Article"
    }
  ]
}
{% endschema %}