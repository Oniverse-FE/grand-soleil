{%- style -%}
  #form-{{ section.id }} input, 
  #form-{{ section.id }} textarea, 
  #form-{{ section.id }}-dropdownButton {    
    border-radius: 50px;
    border: 0.5px solid #EBEFF2;
    background-color: transparent !important;
    color: #EBEFF2 !important;
  }

  #form-{{ section.id }} input:focus, 
  #form-{{ section.id }} textarea:focus {
    border-color: #EBEFF2 !important;
    outline: none;
  }

  #form-{{ section.id }} .field-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cta-disabled {
    border-radius: 50px;
    border: 0.5px solid var(--GS-Stroke-Stroke, rgba(235, 239, 242, 0.64));
    background: var(--System-Disabled, #76787B);
  }
  .disabled-label{
    color:#666666;
  }
{%- endstyle -%}

<div class="bg_gs py-24 lg:py-32 px-4 lg:px-24">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
        
        <div class="w-full lg:w-1/3">
            <h2 class="heading-lg_gs mb-4 text-white">
                {{ section.settings.generic-form-title }}
            </h2>
            <div class="body-lg_gs text-gray-300">
                {{ section.settings.generic-form-text }}
            </div>
        </div>

        <div class="w-full lg:w-2/3">
            {% form 'contact', id: 'contact-form' %}
                <div id="form-{{ section.id }}" class="flex flex-col gap-10 bg-form_gs px-4 py-6 md:p-10">
                    
                    <div class="flex flex-wrap gap-y-6 lg:gap-x-4">
                        {% for block in section.blocks %}
                            {%- capture width_class -%}
                                {% case block.settings.field_width %}
                                    {% when 'third' %}
                                        w-full lg:w-[calc(25%-12px)]
                                    {% when 'two-thirds' %}
                                        w-full lg:w-[calc(75%-8px)]
                                    {% when 'half' %}
                                        w-full lg:w-[calc(50%-8px)]
                                    {% else %}
                                        w-full
                                {% endcase %}
                            {%- endcapture -%}

                            {% case block.type %}
                                {% when 'text' %}
                                    <div class="{{ width_class }} field-container" {{ block.shopify_attributes }}>
                                        <label class="caption text-color_gs">
                                            {{ block.settings.form-textfield-label }}{% if block.settings.form-textfield-required %}*{% endif %}
                                        </label>
                                        <input 
                                            type="{{ block.settings.form-textfield-type }}" 
                                            name="contact[{{ block.settings.form-textfield-type-code }}]" 
                                            id="form-{{ section.id }}-{{ block.id }}"
                                            class="w-full px-6 py-3 caption text-color_gs fields_gs"
                                            placeholder="{{ block.settings.form-textfield-placeholder }}"
                                            {% if block.settings.form-textfield-required %}required{% endif %}
                                        />
                                    </div>

                                {% when 'selection' %}
                                    <div class="{{ width_class }} field-container relative" {{ block.shopify_attributes }}>
                                        <label class="caption text-color_gs">
                                            {{ block.settings.form-selection-label | default: "Seleziona" }}{% if block.settings.form-selection-required %}*{% endif %}
                                        </label>
                                        <button type="button" id="form-{{ section.id }}-dropdownButton-{{ block.id }}" class="dropdown-trigger w-full px-6 py-3 text-left flex justify-between items-center rounded-[50px] border-[0.5px] border-[#EBEFF2]">
                                            <span class="dropdown-selected-text">{{ block.settings.form-selection-placeholder }}</span>
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
                                        </button>
                                        
                                        <ul id="dropdownOptions-{{ block.id }}" class="dropdown-menu absolute hidden bg-[#1a1a1a] border border-white w-full mt-[85px] z-50 max-h-60 overflow-auto rounded-xl">
                                            {% assign options = block.settings.form-selection-options | split: ',' %}
                                            {% for option in options %}
                                                <li class="px-4 py-2 hover:bg-white hover:text-black cursor-pointer text-white" data-value="{{ option | strip }}">
                                                    {{ option | strip }}
                                                </li>
                                            {% endfor %}
                                        </ul>
                                        <input type="hidden" name="contact[scelta-{{ forloop.index }}]" class="dropdown-hidden-input" {% if block.settings.form-selection-required %}required{% endif %}>
                                    </div>

                                {% when 'textarea' %}
                                    <div class="w-full field-container" {{ block.shopify_attributes }}>
                                        <label class="caption text-color_gs">
                                            {{ block.settings.form-message-placeholder }}{% if block.settings.form-message-required %}*{% endif %}
                                        </label>
                                        <textarea  
                                            id="form-{{ section.id }}-message"
                                            name="contact[body]" 
                                            class="w-full px-6 py-4 min-h-[120px] !rounded-[25px]"
                                            maxlength="{{ block.settings.form-message-max-size }}"
                                            {% if block.settings.form-message-required %}required{% endif %}
                                        ></textarea>
                                        <div class="text-[10px] text-right text-gray-400">
                                            <span id="form-{{ section.id }}-char-count">0</span> / {{ block.settings.form-message-max-size }}
                                        </div>
                                    </div>
                            {% endcase %}
                        {% endfor %}
                    </div>

                    <div class="flex flex-col gap-6 text-sm">
                        <div class="flex items-start gap-4">
                            <input type="checkbox" class="mt-1 w-5 h-5 border-white bg-transparent appearance-none border checked:bg-white checked:border-transparent transition-all" id="marketingConsent-{{ section.id }}" name="contact[accepts_marketing]">
                            <label for="marketingConsent-{{ section.id }}" class="body-md_gs text-color_gs cursor-pointer">
                                {{ section.settings.form-markConsLabel }} <u><a href="javascript:void(0)" id="shortMarketing-{{ section.id }}">Policy</a></u>
                            </label>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <input type="checkbox" class="mt-1 w-5 h-5 border-white bg-transparent appearance-none border checked:bg-white disabled:opacity-30 transition-all" id="profilingConsent-{{ section.id }}" name="contact[accepts_profiling]" disabled>
                            <label id="profilingLabel-{{ section.id }}" for="profilingConsent-{{ section.id }}" class="body-md_gs disabled-label transition-colors">
                                {{ section.settings.form-profConsLabel }} <u><a href="javascript:void(0)" id="shortProfiling-{{ section.id }}">Policy</a></u>
                            </label>
                        </div>
                    </div>

                    <div class="flex items-end justify-end">
                        <button type="submit" class="w-full lg:w-max px-12 py-4 rounded-full link-lg_gs text-data_gs transition-opacity cta-disabled">
                            {{ section.settings.form-submit-button-text }}
                        </button>
                    </div>
                </div>
            {% endform %}
        </div>
    </div>
</div>

<div id="marketing-overlay-{{ section.id }}" class="fixed inset-0 flex justify-center items-center bg-black/80 z-[100] opacity-0 pointer-events-none transition-opacity duration-300 p-4">
    <div class="bg-[#1a1a1a] border border-white p-8 max-w-2xl max-h-[80vh] overflow-y-auto">
        <div class="flex justify-between mb-6">
            <h3 class="text-xl font-bold">{{ section.settings.form-marketing-title }}</h3>
            <button id="marketing-close-{{ section.id }}" class="text-2xl text-white">&times;</button>
        </div>
        <p class="text-sm leading-relaxed text-gray-300">{{ section.settings.form-marketing-text }}</p>
    </div>
</div>

<div id="profiling-overlay-{{ section.id }}" class="fixed inset-0 flex justify-center items-center bg-black/80 z-[100] opacity-0 pointer-events-none transition-opacity duration-300 p-4">
    <div class="bg-[#1a1a1a] border border-white p-8 max-w-2xl max-h-[80vh] overflow-y-auto">
        <div class="flex justify-between mb-6">
            <h3 class="text-xl font-bold">{{ section.settings.form-profiling-title }}</h3>
            <button id="profiling-close-{{ section.id }}" class="text-2xl text-white">&times;</button>
        </div>
        <p class="text-sm leading-relaxed text-gray-300">{{ section.settings.form-profiling-text }}</p>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const sectionId = "{{ section.id }}";

    // Dropdown Logic (Migliorata per più dropdown)
    document.querySelectorAll('.dropdown-trigger').forEach(btn => {
        btn.onclick = (e) => {
            e.stopPropagation();
            const menu = btn.nextElementSibling;
            menu.classList.toggle('hidden');
        };
    });

    document.querySelectorAll('.dropdown-menu li').forEach(li => {
        li.onclick = function() {
            const container = this.closest('.field-container');
            container.querySelector('.dropdown-selected-text').innerText = this.dataset.value;
            container.querySelector('.dropdown-hidden-input').value = this.dataset.value;
            this.parentElement.classList.add('hidden');
        }
    });

    document.onclick = () => document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));

    // Char Count
    const txt = document.getElementById(`form-${sectionId}-message`);
    const count = document.getElementById(`form-${sectionId}-char-count`);
    if(txt && count) { txt.oninput = () => count.innerText = txt.value.length; }

    // Overlays
    const setupOverlay = (triggerId, overlayId, closeId) => {
        const trigger = document.getElementById(triggerId);
        const overlay = document.getElementById(overlayId);
        const close = document.getElementById(closeId);
        if(!trigger || !overlay) return;
        trigger.onclick = () => { overlay.classList.remove('opacity-0', 'pointer-events-none'); overlay.classList.add('opacity-100'); };
        close.onclick = () => { overlay.classList.add('opacity-0', 'pointer-events-none'); overlay.classList.remove('opacity-100'); };
    };
    setupOverlay(`shortMarketing-${sectionId}`, `marketing-overlay-${sectionId}`, `marketing-close-${sectionId}`);
    setupOverlay(`shortProfiling-${sectionId}`, `profiling-overlay-${sectionId}`, `profiling-close-${sectionId}`);

    // Consent
    const mkt = document.getElementById(`marketingConsent-${sectionId}`);
    const prof = document.getElementById(`profilingConsent-${sectionId}`);
    const profLabel = document.getElementById(`profilingLabel-${sectionId}`);
    if(mkt && prof) {
        mkt.onchange = () => {
            prof.disabled = !mkt.checked;
            profLabel.className = mkt.checked ? 'text-color_gs transition-colors' : 'disabled-label transition-colors';
            if(!mkt.checked) prof.checked = false;
        };
    }
});
</script>

{% schema %}
{
    "name": "Generic form",
    "settings": [
        { "type": "text", "id": "generic-form-title", "label": "Title", "default": "Facci una domanda" },
        { "type": "textarea", "id": "generic-form-text", "label": "Text", "default": "Compila il modulo." },
        { "type": "text", "id": "form-markConsLabel", "label": "Marketing Consent Text" },
        { "type": "text", "id": "form-profConsLabel", "label": "Profiling Consent Text" },
        { "type": "text", "id": "form-marketing-title", "label": "Mkt Title", "default": "Marketing" },
        { "type": "textarea", "id": "form-marketing-text", "label": "Mkt Text" },
        { "type": "text", "id": "form-profiling-title", "label": "Prof Title", "default": "Profiling" },
        { "type": "textarea", "id": "form-profiling-text", "label": "Prof Text" },
        { "type": "color", "id": "form-button-background-color", "label": "Button BG", "default": "#ffffff" },
        { "type": "color", "id": "form-button-text-color", "label": "Button Text", "default": "#000000" },
        { "type": "text", "id": "form-submit-button-text", "label": "Submit Label", "default": "Invia" }
    ],
    "blocks": [
        {
            "name": "Textfield",
            "type": "text",
            "settings": [
                {
                    "type": "select",
                    "id": "field_width",
                    "label": "Larghezza campo",
                    "options": [
                        { "value": "full", "label": "Intera riga (100%)" },
                        { "value": "half", "label": "Metà riga (50%)" },
                        { "value": "third", "label": "Un quarto (25%)" },
                        { "value": "two-thirds", "label": "Tre quarti (75%)" }
                    ],
                    "default": "full"
                },
                { "type": "select", "id": "form-textfield-type", "label": "Tipo", "options": [{"value":"text","label":"Testo"},{"value":"email","label":"Email"},{"value":"tel","label":"Tel"}]},
                { "type": "select", "id": "form-textfield-type-code", "label": "Tag", "options": [{"value":"first_name","label":"Nome"},{"value":"last_name","label":"Cognome"},{"value":"email","label":"Email"},{"value":"phone","label":"Tel"}]},
                { "type": "text", "id": "form-textfield-label", "label": "Label" },
                { "type": "text", "id": "form-textfield-placeholder", "label": "Placeholder" },
                { "type": "checkbox", "id": "form-textfield-required", "label": "Obbligatorio", "default": false }
            ]
        },
        {
            "name": "Selections",
            "type": "selection",
            "settings": [
                {
                    "type": "select",
                    "id": "field_width",
                    "label": "Larghezza campo",
                    "options": [
                        { "value": "full", "label": "Intera riga (100%)" },
                        { "value": "half", "label": "Metà riga (50%)" },
                        { "value": "third", "label": "Un terzo (33%)" },
                        { "value": "two-thirds", "label": "Due terzi (66%)" }
                    ],
                    "default": "full"
                },
                { "type": "text", "id": "form-selection-label", "label": "Label" },
                { "type": "text", "id": "form-selection-placeholder", "label": "Default" },
                { "type": "textarea", "id": "form-selection-options", "label": "Opzioni (virgola)" },
                { "type": "checkbox", "id": "form-selection-required", "label": "Obbligatorio", "default": false }
            ]
        },
        {
            "name": "Messaggio",
            "type": "textarea",
            "settings": [
                { "type": "text", "id": "form-message-placeholder", "label": "Label", "default": "Messaggio" },
                { "type": "number", "id": "form-message-max-size", "label": "Max", "default": 500 },
                { "type": "checkbox", "id": "form-message-required", "label": "Obbligatorio", "default": true }
            ]
        }
    ],
    "presets": [ { "name": "Generic form Black" } ]
}
{% endschema %}