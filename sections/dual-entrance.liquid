<section class="relative h-dvh w-full overflow-hidden bg-black section-{{ section.id }}">
  
  {% comment %} Logo Centrale Fisso {% endcomment %}
  {% if section.settings.center_logo != blank %}
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 pointer-events-none w-[231px] md:w-[270px] lg:w-[271px]">
      <img src="{{ section.settings.center_logo | image_url: width: 600 }}" alt="Main Logo" class="w-full h-auto drop-shadow-2xl">
    </div>
  {% endif %}

  <div class="flex flex-col md:flex-row w-full h-full relative">
    
    {% for block in section.blocks %}
      <div 
        class="entrance-column relative flex-[1_1_0%] h-full transition-all duration-700 ease-[cubic-bezier(0.33,1,0.68,1)] group overflow-hidden md:hover:flex-[2.5_2.5_0%]" 
        {{ block.shopify_attributes }}
      >
        
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="column-link absolute inset-0 z-[25] block"></a>
        {% endif %}

        {% comment %} Background Media {% endcomment %}
        <div class="absolute inset-0 w-full h-full pointer-events-none">
          {%- if block.settings.video_url != blank -%}
            {{ block.settings.video_url | video_tag: 
                loop: true, 
                muted: true, 
                controls: false, 
                playsinline: true,
                preload: "auto",
                class: 'hover-video absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105' 
            }}
          {%- endif -%}
          
          {%- if block.settings.image != blank -%}
            <img 
              src="{{ block.settings.image | image_url: width: 2000 }}" 
              alt="{{ block.settings.image.alt }}"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 {% if block.settings.video_url != blank %}opacity-0{% endif %}"
            >
          {%- endif -%}
        </div>

        <div class="absolute inset-0 z-10 bg-black/30 group-hover:bg-black/10 transition-colors duration-500"></div>

        {% comment %} CONTENUTO CENTRATO: Logo e CTA sempre visibili {% endcomment %}
        <div class="absolute inset-0 z-40 flex flex-col items-center justify-center pointer-events-none p-2">
          <div class="flex flex-col items-center w-full max-w-[90%]">
            {% if block.settings.inner_image != blank %}
              <img src="{{ block.settings.inner_image | image_url: width: 400 }}" 
                   alt="Brand Logo" 
                   class="w-[231px] md:w-[270px] lg:w-[271px] h-auto object-contain drop-shadow-2xl mb-4 md:mb-8 transition-transform duration-700">
            {% endif %}

            {% if block.settings.button_label != blank %}
              <div class="inline-block px-4 py-2 md:px-8 md:py-3 link-lg cta_dual-entrance group-hover:cta-hover_dual-entrance whitespace-nowrap">
                {{ block.settings.button_label }}
              </div>
            {% endif %}
          </div>
        </div>

        {% comment %} Pulsante Play/Pause {% endcomment %}
        <div class="absolute bottom-6 left-6 z-[45] pointer-events-none">
          {% if block.settings.video_url != blank %}
            <button class="video-control-btn pointer-events-auto hidden items-center justify-center w-10 h-10 rounded-full border border-white/50 bg-black/20 backdrop-blur-sm">
              <span class="play-svg">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="pause-svg hidden">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
              </span>
            </button>
          {% endif %}
        </div>

      </div>
    {% endfor %}

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const container = document.querySelector('.section-{{ section.id }}');
  const columns = container.querySelectorAll('.entrance-column');
  const isMobile = () => window.innerWidth < 768;

  columns.forEach(col => {
    const video = col.querySelector('.hover-video');
    const btn = col.querySelector('.video-control-btn');
    const link = col.querySelector('.column-link');

    if (video) video.currentTime = 0.001;

    const playVideo = (v, b) => {
      if (!v) return;
      v.play();
      if (b) {
        b.style.display = 'flex';
        b.querySelector('.play-svg').classList.add('hidden');
        b.querySelector('.pause-svg').classList.remove('hidden');
      }
    };

    const pauseVideo = (v, b) => {
      if (!v) return;
      v.pause();
      if (b) {
        b.querySelector('.play-svg').classList.remove('hidden');
        b.querySelector('.pause-svg').classList.add('hidden');
      }
    };

    col.addEventListener('mouseenter', () => { if (!isMobile()) playVideo(video, btn); });
    col.addEventListener('mouseleave', () => { if (!isMobile()) pauseVideo(video, btn); });

    if (link) {
      link.addEventListener('click', function(e) {
        if (isMobile()) {
          if (!col.classList.contains('is-expanded')) {
            e.preventDefault();
            columns.forEach(c => {
              c.classList.remove('is-expanded');
              const v = c.querySelector('.hover-video');
              const b = c.querySelector('.video-control-btn');
              pauseVideo(v, b);
              if(b) b.style.display = 'none';
            });
            col.classList.add('is-expanded');
            playVideo(video, btn);
          }
        }
      });
    }

    if (btn) {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        video.paused ? playVideo(video, btn) : pauseVideo(video, btn);
      });
    }
  });
});
</script>

<style>
  .entrance-column { 
    will-change: flex; 
    transition: flex 0.7s cubic-bezier(0.33, 1, 0.68, 1);
  }
  
  @media (max-width: 767px) {
    .entrance-column.is-expanded { flex: 4 4 0% !important; }
    .entrance-column:not(.is-expanded) { flex: 1 1 0% !important; }
    
    /* Assicuriamoci che il testo non scatti o scompaia */
    .entrance-column .z-40 {
      opacity: 1 !important;
      display: flex !important;
    }
  }
</style>

{% schema %}
{
  "name": "Dual entrance",
  "max_blocks": 3,
  "settings": [
    {
      "type": "image_picker",
      "id": "center_logo",
      "label": "Logo Centrale Fisso"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Colonna",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Immagine fallback / Poster" },
        { "type": "video", "id": "video_url", "label": "Video" },
        { "type": "image_picker", "id": "inner_image", "label": "Logo Interno" },
        { "type": "text", "id": "button_label", "label": "Testo Bottone", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link Colonna" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dual entrance",
      "blocks": [
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}