<div class="bg_gs bg_gsp flex simple-text flex-col justify-start text-white gap-3 lg:gap-6 py-[128px] md:py-[160px] lg:py-[200px] px-4 md:px-10 lg:px-[198px]" 
     style="--padding-bottom-mobile: {{ section.settings.padding_block_mobile }}px; --padding-bottom-desktop: {{ section.settings.padding_block }}px; --padding-top-mobile: {{ section.settings.padding_block_top }}px; --padding-top-desktop: {{ section.settings.padding_top }}px;">
    
    <div class="flex pretitle-lg_gs pretitle-lg_gsp text-blue_gs text-truffle_gsp">
        {{ section.settings.simple-intro-title }}
    </div>

    <div id="reveal-text-{{ section.id }}" class="reveal-container quote-lg_gs quote-lg_gsp text-color_gs text-color_gsp">
         {{ section.settings.simple-intro-text }}
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const container = document.getElementById("reveal-text-{{ section.id }}");
  if (!container) return;

  // 1. Pulizia e divisione in parole
  const text = container.innerText.trim();
  const words = text.split(/\s+/);
  container.innerHTML = ""; 

  // 2. Creazione degli span per ogni parola
  const wordSpans = words.map(word => {
    const span = document.createElement("span");
    span.classList.add("reveal-word");
    span.innerText = word;
    container.appendChild(span);
    return span;
  });

  // 3. Logica di scroll sequenziale (Intersection Observer + Scroll Percentage)
  const handleScroll = () => {
    const rect = container.getBoundingClientRect();
    const windowHeight = window.innerHeight;
    
    // Calcoliamo quanto del container è visibile (da 0 a 1)
    // Inizia quando il top del box tocca l'80% della pagina
    // Finisce quando il fondo del box tocca il 20% della pagina
    const start = windowHeight * 0.8;
    const end = windowHeight * 0.2;
    const progress = Math.min(Math.max((start - rect.top) / (start - end), 0), 1);
    
    // Determiniamo quante parole devono essere bianche in base al progresso
    const wordsToLight = Math.floor(progress * wordSpans.length);
    
    wordSpans.forEach((span, index) => {
      if (index <= wordsToLight && progress > 0) {
        span.classList.add("active");
      } else {
        span.classList.remove("active");
      }
    });
  };

  window.addEventListener("scroll", handleScroll);
  handleScroll(); // Esegui subito per check posizione iniziale
});
</script>

{% schema %}
{
  "name": "Subtile & Text Scroll",
  "settings": [
    {
      "type": "text",
      "id": "simple-intro-title",
      "label": "Subtitle"
    },
    {
      "type": "textarea",
      "id": "simple-intro-text",
      "label": "Text"
    }
  ],
  "presets": [
    {
      "name": "Subtile & Text Scroll",
      "category": "Common sections"
    }
  ]
}
{% endschema %}