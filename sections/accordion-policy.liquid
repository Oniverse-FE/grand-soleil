<div class="flex flex-col gap-4 lg:gap-6 lg:gap-8 px-4 md:px-12 lg:px-24">

  {% for block in section.blocks %}
    {% assign main_index = forloop.index %}
    {% assign main_type = block.settings.service_type %}
    {% assign main_list = block.settings.service_list %}

    <!-- Accordion principale -->
    <div class="flex flex-col w-full">
      <div id="service-type-{{ main_index }}" class="flex flex-row px-4 py-[10px] lg:px-8 lg:py-6 bg-antracite rounded-[4px] justify-between items-center body-medium cursor-pointer service-toggle" data-index="{{ main_index }}">
        <div class="text-white">{{ main_type }}</div>
        <div class="flex justify-center items-center">
          <svg class="size-6 icon-plus" data-index="{{ main_index }}" viewBox="0 0 24 24" fill="none">
            <path d="M4 12H20" stroke="white" stroke-linecap="round"/>
            <path d="M12 20V4" stroke="white" stroke-linecap="round"/>
          </svg>
          <svg class="size-6 icon-minus hidden" data-index="{{ main_index }}" viewBox="0 0 24 24" fill="none">
            <path d="M4 12H20" stroke="white" stroke-linecap="round"/>
          </svg>
        </div>
      </div>

      <!-- Contenitore principale -->
      <div class="service-list bg-antracite text-white text-sm -mt-1 rounded-b-[4px]" id="service-list-{{ main_index }}" data-index="{{ main_index }}">
        <div class="service-list-inner px-4 py-[10px] lg:px-8 lg:py-6">
          <div class="lg:columns-2 pb-2">
            {{ main_list | newline_to_br }}
          </div>

          {% assign sub_accordions = "2,3,4,5,6,7,8" | split: "," %}
          <div class="grid lg:grid-cols-2 gap-4">
            {% for sub in sub_accordions %}
              {% assign key_type = "service_type" | append: sub %}
              {% assign key_list = "service_list" | append: sub %}
              {% assign type = block.settings[key_type] %}
              {% assign list = block.settings[key_list] %}

              {% if type != blank and list != blank %}
                <div class="flex flex-col w-full">
                  <div id="service-type{{ sub }}-{{ main_index }}" class="flex flex-row px-4 py-[10px] lg:px-8 lg:py-6 bg-[#4D565A] rounded-[4px] justify-between items-center body-medium cursor-pointer service-toggle" data-index="{{ main_index }}-{{ sub }}">
                    <div class="text-white">{{ type }}</div>
                    <div class="flex justify-center items-center">
                      <svg class="size-6 icon-plus" data-index="{{ main_index }}-{{ sub }}" viewBox="0 0 24 24" fill="none">
                        <path d="M4 12H20" stroke="white" stroke-linecap="round"/>
                        <path d="M12 20V4" stroke="white" stroke-linecap="round"/>
                      </svg>
                      <svg class="size-6 icon-minus hidden" data-index="{{ main_index }}-{{ sub }}" viewBox="0 0 24 24" fill="none">
                        <path d="M4 12H20" stroke="white" stroke-linecap="round"/>
                      </svg>
                    </div>
                  </div>

                  <div class="service-list bg-[#4D565A] text-white text-sm -mt-1 rounded-b-[4px]" id="service-list{{ sub }}-{{ main_index }}" data-index="{{ main_index }}-{{ sub }}">
                    <div class="service-list-inner px-4 py-[10px] lg:px-8 lg:py-6">
                      {{ list | newline_to_br }}
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endfor %}

</div>

<style>
  /* Contenitori accordion */
  .service-list {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.5s ease, opacity 0.5s ease;
  }

  .service-list.open {
    max-height: 1000px;
    opacity: 1;
  }

  /* Wrapper interno per padding */
  .service-list-inner {
    padding: 0; /* inizialmente 0 */
    visibility: hidden;
  }

  .service-list.open .service-list-inner {
    padding: 14px 16px ; /* padding visibile solo quando aperto */
    visibility: visible;
  }

@media screen and (min-width: 768px) {
    .service-list.open .service-list-inner {
    padding: 24px 32px ; /* padding visibile solo quando aperto */
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const mainToggles = document.querySelectorAll('.service-toggle[data-index]:not([data-index*="-"])');
  const subToggles = document.querySelectorAll('.service-toggle[data-index*="-"]');

  function openAccordion(toggle, list) {
    list.classList.add('open');
    list.style.maxHeight = "0px"; 
    list.offsetHeight; 
    requestAnimationFrame(() => {
      list.style.maxHeight = list.scrollHeight + "px";
    });
    list.addEventListener('transitionend', function handleOpen(e) {
      if (e.propertyName === 'max-height') {
        list.style.maxHeight = 'none';
        list.removeEventListener('transitionend', handleOpen);
      }
    });
    toggle.querySelector('.icon-plus').classList.add('hidden');
    toggle.querySelector('.icon-minus').classList.remove('hidden');
  }

  function closeAccordion(toggle, list) {
    list.style.maxHeight = list.scrollHeight + "px";
    list.offsetHeight;
    requestAnimationFrame(() => {
      list.style.maxHeight = "0px";
    });
    list.addEventListener('transitionend', function handleClose(e) {
      if (e.propertyName === 'max-height') {
        list.classList.remove('open');
        list.style.maxHeight = null;
        list.removeEventListener('transitionend', handleClose);
      }
    });
    toggle.querySelector('.icon-plus').classList.remove('hidden');
    toggle.querySelector('.icon-minus').classList.add('hidden');
  }

  // Main accordion
  mainToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const index = toggle.dataset.index;
      const list = document.querySelector(`.service-list[data-index="${index}"]`);
      if (!list) return;

      const isOpen = list.classList.contains('open');

      // Chiudi tutti gli altri main + sub
      mainToggles.forEach(otherToggle => {
        const otherIndex = otherToggle.dataset.index;
        const otherList = document.querySelector(`.service-list[data-index="${otherIndex}"]`);
        if (otherList && otherList !== list && otherList.classList.contains('open')) {
          closeAccordion(otherToggle, otherList);

          const otherSubToggles = document.querySelectorAll(`.service-toggle[data-index^="${otherIndex}-"]`);
          otherSubToggles.forEach(subToggle => {
            const subList = document.querySelector(`.service-list[data-index="${subToggle.dataset.index}"]`);
            if (subList && subList.classList.contains('open')) closeAccordion(subToggle, subList);
          });
        }
      });

      // Toggle cliccato
      if (isOpen) {
        closeAccordion(toggle, list);
      } else {
        openAccordion(toggle, list);
      }
    });
  });

  // Sub accordion
  subToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const index = toggle.dataset.index;
      const list = document.querySelector(`.service-list[data-index="${index}"]`);
      if (!list) return;

      const mainIndex = index.split('-')[0];
      const isOpen = list.classList.contains('open');

      // Chiudi solo altri sub dello stesso main
      subToggles.forEach(otherToggle => {
        const otherIndex = otherToggle.dataset.index;
        if (otherIndex.startsWith(mainIndex) && otherIndex !== index) {
          const otherList = document.querySelector(`.service-list[data-index="${otherIndex}"]`);
          if (otherList && otherList.classList.contains('open')) closeAccordion(otherToggle, otherList);
        }
      });

      // Toggle cliccato
      if (isOpen) {
        closeAccordion(toggle, list);
      } else {
        openAccordion(toggle, list);
      }
    });
  });
});
</script>

