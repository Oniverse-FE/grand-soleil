{%- assign current_theme = 'gs' -%}
{%- if template contains 'gsp' or product.tags contains 'gsp' or page.template_suffix contains 'gsp' or collection.handle contains 'gsp' -%}
  {%- assign current_theme = 'gsp' -%}
{%- endif -%}

<script>
  (function() {
    // Imposta il tema iniziale basato sulla pagina Shopify corrente
    const initialTheme = '{{ current_theme }}';
    document.documentElement.className = initialTheme;
  })();
</script>

<div class="fixed top-4 md:top-6 left-0 w-full flex justify-center items-center pointer-events-none z-[9999]">
  <header id="main-header" 
          class="w-full md:max-w-[704px] lg:max-w-[768px] mx-6 md:mx-auto pointer-events-auto transition-all duration-500 ease-in-out overflow-hidden rounded-[24px] border border-transparent shadow-lg">
    
    <div class="px-6 py-5 flex justify-between items-center relative z-10">
      <div class="flex-1">
        <button id="burger-trigger" class="flex flex-col gap-1 group outline-none cursor-pointer">
          <span class="w-[20px] h-[1px] bg-current rounded-[4px] transition-all duration-300 group-[.active]:rotate-45 group-[.active]:translate-y-0.5"></span>
          <span class="w-[20px] h-[1px] bg-current rounded-[4px] transition-all duration-300 group-[.active]:-rotate-45 group-[.active]:-translate-y-1"></span>
        </button>
      </div>

      <div class="flex-none flex justify-center items-center">
        <a href="/" class="block relative" style="width: {{ section.settings.logo_width }}px;">
          {% if section.settings.logo_gs != blank %}
            <img src="{{ section.settings.logo_gs | image_url: width: 300 }}" alt="Logo GS" class="logo-gs h-auto w-full transition-opacity duration-500">
          {% endif %}
          {% if section.settings.logo_gsp != blank %}
            <img src="{{ section.settings.logo_gsp | image_url: width: 300 }}" alt="Logo GSP" class="logo-gsp h-auto w-full transition-opacity duration-500 absolute inset-0">
          {% endif %}
        </a>
      </div>

      <div class="flex-1 text-right">
        <button id="panel-open" class="cursor-pointer body-sm_gs body-sm_gsp">
          {{ section.settings.right_label }}
        </button>
      </div>
    </div>

    <div id="dropdown-wrapper" class="overflow-y-auto max-h-0 transition-all duration-700 ease-in-out">
      
      <div id="menu-overlay" class="hidden px-8 py-8 flex flex-col gap-10  md:h-[720px]">
        <div class="main-nav-wrapper">
          <ul class="nav-links gs-only space-y-5 menu-md_gs">
            {% for link in linklists[section.settings.menu_gs].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
          <ul class="nav-links gsp-only space-y-5 menu-md_gsp">
            {% for link in linklists[section.settings.menu_gsp].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>

        <div class="secondary-nav-wrapper border-t border-[var(--border-color)] pt-8">
          <ul class="flex flex-row flex-wrap gap-x-4 gs-only menu-xs_gs">
            {% for link in linklists[section.settings.menu_gs_secondary].links %}
              <li><a href="{{ link.url }}" class="underline transition-opacity">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
          <ul class="flex flex-row flex-wrap gap-x-6 gap-y-3 gsp-only menu-xs_gsp">
            {% for link in linklists[section.settings.menu_gsp_secondary].links %}
              <li><a href="{{ link.url }}" class="underline transition-opacity">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <div id="right-panel" class="hidden flex-col">
        <div class="px-6">
          <div class="flex flex-wrap gap-2 py-8 items-center gs-only">
            {% for block in section.blocks %}
              {% if block.type == 'chip' %}
                <a href="{{ block.settings.link }}" 
                   class="custom-chip px-6 py-4 rounded-[50px] link-md_gs link-md_gsp {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" 
                   {{ block.shopify_attributes }}>
                  {{ block.settings.title }}
                </a>
              {% endif %}
            {% endfor %}
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-8">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'text' %}
                  <div id="{{ block.settings.id_gamme }}" class="col-span-2 pt-4 pb-2 flex flex-col gap-2 {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" {{ block.shopify_attributes }}>
                    <div class="menu-md_gs menu-md_gsp">{{ block.settings.title_gamme }}</div>
                    {% if block.settings.link_gamme != blank %}
                      <a href="{{ block.settings.url_gamme }}" class="body-sm_gs body-sm_gsp underline underline-offset-4">{{ block.settings.link_gamme }}</a>
                    {% endif %}
                  </div>
                {% when 'card' %}
                  <a href="{{ block.settings.link }}" 
                     class="col-span-1 p-4 rounded-[16px] custom-card group flex flex-col {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" 
                     {{ block.shopify_attributes }}>
                    <div class="flex flex-row justify-between items-start pb-6">
                      <div class="flex flex-col gap-1">
                        <h4 class="menu-model_gsp menu-model_gs">{{ block.settings.title }}</h4>
                        <p class="menu-model_gsp menu-model_gs">{{ block.settings.description }}</p>
                      </div>
                      <span class="bg-[#05090D] p-3 rounded-full shrink-0">
                        <svg width="14" height="15" viewBox="0 0 16 17" fill="none"><path d="M0.749779 15.5994L14.8919 1.45725L1.45689 0.750146L5.69953 4.99279" stroke="#EBEFF2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    </div>
                    {% if block.settings.image != blank %}
                      <div class="aspect-[4/3] overflow-hidden rounded-[8px] bg-[#80808020] mt-auto">
                        <img src="{{ block.settings.image | image_url: width: 600 }}" class="w-full h-full object-cover transition-transform" loading="lazy">
                      </div>
                    {% endif %}
                  </a>
              {% endcase %}
            {% endfor %}
          </div>
        </div>

        <div class="px-6 py-6 border-t border-transparent mt-auto sticky bottom-0 bg-inherit">
          <div class="relative w-full h-[59px] rounded-full p-1 flex items-center bg-[#EBEFF2] transition-colors duration-500">
            <input type="radio" id="toggle-gs" name="theme-toggle" value="gs" class="peer/gs hidden">
            <label for="toggle-gs" class="flex-1 text-center z-10 cursor-pointer transition-colors peer-checked/gs:text-[#EBEFF2] font-medium text-[#101C26]">{{ section.settings.toggle_label_gs }}</label>

            <input type="radio" id="toggle-gsp" name="theme-toggle" value="gsp" class="peer/gsp hidden">
            <label for="toggle-gsp" class="flex-1 text-center z-10 cursor-pointer text-[#05090D] transition-colors peer-checked/gsp:text-[#FAF9F7] font-medium">{{ section.settings.toggle_label_gsp }}</label>
            
            <div id="toggle-slider" class="absolute top-1 left-1 w-[calc(50%-4px)] h-[51px] bg-[#101C26] rounded-full shadow transition-all duration-500 peer-checked/gsp:translate-x-full peer-checked/gsp:bg-[#282624]"></div>
          </div>
        </div>
      </div>
    </div>
  </header>
</div>

<div id="panel-overlay" class="fixed inset-0 z-[9990] bg-black/10 opacity-0 pointer-events-none transition-opacity duration-700 backdrop-blur-sm"></div>

<style>
  :root { --transition-speed: 0.4s; }
  
  /* Logiche visibilità */
  .gs .gsp-only { display: none !important; }
  .gsp .gs-only { display: none !important; }

  /* Gestione Loghi dinamici */
  .logo-gs, .logo-gsp { transition: opacity var(--transition-speed) ease; }
  .gs .logo-gsp { opacity: 0; pointer-events: none; }
  .gsp .logo-gs { opacity: 0; pointer-events: none; }
  .gs .logo-gs { opacity: 1; }
  .gsp .logo-gsp { opacity: 1; }

  /* Variabili Colore */
  html.gs, body.gs {
    --bg-color: #101C26;
    --text-color: #EBEFF2;
    --border-color: rgba(235, 239, 242, 0.2);
    --card: #101C26;
  }
  html.gsp, body.gsp {
    --bg-color: #FAF9F7;
    --text-color: #141312;
    --border-color: rgba(20, 19, 18, 0.1);
    --card: #D4CCC1;
  }

  #main-header {
    background-color: var(--bg-color);
    color: var(--text-color);
    border-color: var(--border-color);
    backdrop-filter: blur(20px);
    transition: background-color var(--transition-speed), border-color var(--transition-speed), color var(--transition-speed);
  }

  .custom-chip {
    border: 1px solid var(--border-color);
    color: inherit;
    transition: all 0.3s ease;
  }
  .custom-chip:hover {
    background-color: var(--text-color);
    color: var(--bg-color);
  }

  .custom-card {
    color: inherit;
    background-color: var(--card);
    border: 1px solid var(--border-color);
  }

  #panel-overlay.active { opacity: 1; pointer-events: auto; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const html = document.documentElement;
  const body = document.body;
  const dropdown = document.getElementById('dropdown-wrapper');
  const menuLeft = document.getElementById('menu-overlay');
  const menuRight = document.getElementById('right-panel');
  const burgerBtn = document.getElementById('burger-trigger');
  const openRight = document.getElementById('panel-open');
  const overlay = document.getElementById('panel-overlay');
  const radios = document.querySelectorAll('input[name="theme-toggle"]');
  
  // Il tema "reale" della pagina Shopify corrente
  const pageTheme = '{{ current_theme }}';

  // Sincronizza il toggle grafico
  const syncToggle = (theme) => {
    const radioToSelect = document.querySelector(`input[name="theme-toggle"][value="${theme}"]`);
    if (radioToSelect) radioToSelect.checked = true;
  };
  
  syncToggle(pageTheme);

  const updateThemeUI = (theme) => {
    html.className = theme;
    body.className = theme;
  };

  const toggleDropdown = (type) => {
    const isLeftOpen = !menuLeft.classList.contains('hidden');
    const isRightOpen = !menuRight.classList.contains('hidden');
    const isOpen = dropdown.style.maxHeight !== '0px' && dropdown.style.maxHeight !== '';

    if (isOpen && ((type === 'left' && isLeftOpen) || (type === 'right' && isRightOpen))) {
      closeAll();
    } else {
      menuLeft.classList.toggle('hidden', type !== 'left');
      menuRight.classList.toggle('hidden', type !== 'right');
      burgerBtn.classList.toggle('active', type === 'left');
      dropdown.style.maxHeight = '85vh';
      overlay.classList.add('active');
    }
  };

  const closeAll = () => {
    dropdown.style.maxHeight = '0px';
    overlay.classList.remove('active');
    burgerBtn.classList.remove('active');
    
    // RESET: Torna al tema della pagina originale alla chiusura del menu
    setTimeout(() => {
      updateThemeUI(pageTheme);
      syncToggle(pageTheme);
    }, 400); 
  };

  burgerBtn.addEventListener('click', () => toggleDropdown('left'));
  openRight.addEventListener('click', () => toggleDropdown('right'));
  overlay.addEventListener('click', closeAll);

  radios.forEach(radio => {
    radio.addEventListener('change', (e) => updateThemeUI(e.target.value));
  });
});
</script>

{% schema %}
{
  "name": "Floating Header Total",
  "settings": [
    { "type": "header", "content": "Loghi" },
    { "type": "image_picker", "id": "logo_gs", "label": "Logo GS" },
    { "type": "image_picker", "id": "logo_gsp", "label": "Logo GSP" },
    { "type": "range", "id": "logo_width", "min": 50, "max": 200, "step": 10, "default": 100, "unit": "px", "label": "Larghezza Logo" },
    { "type": "header", "content": "Menu Burger" },
    { "type": "link_list", "id": "menu_gs", "label": "Menu GS" },
    { "type": "link_list", "id": "menu_gsp", "label": "Menu GSP" },
    { "type": "link_list", "id": "menu_gs_secondary", "label": "Menu Secondario GS (Orizzontale)"},
    { "type": "link_list", "id": "menu_gsp_secondary", "label": "Menu Secondario GSP (Orizzontale)"},
    { "type": "header", "content": "Pannello Destra" },
    { "type": "text", "id": "right_label", "label": "Etichetta Bottone", "default": "DISCOVER" },
    { "type": "header", "content": "Etichette Toggle" },
    { "type": "text", "id": "toggle_label_gs", "label": "Testo GS", "default": "GS MODE" },
    { "type": "text", "id": "toggle_label_gsp", "label": "Testo GSP", "default": "GSP MODE" }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Chip (Link)",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo", "default": "Design" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "visibility",
          "label": "Mostra in:",
          "options": [
            { "value": "both", "label": "Entrambi" },
            { "value": "gs", "label": "Solo GS" },
            { "value": "gsp", "label": "Solo GSP" }
          ],
          "default": "both"
        }
      ]
    },
    {
      "type": "card",
      "name": "Card Progetto",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Immagine" },
        { "type": "text", "id": "title", "label": "Titolo", "default": "Project Title" },
        { "type": "text", "id": "description", "label": "Descrizione", "default": "Short description." },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "visibility",
          "label": "Mostra in:",
          "options": [
            { "value": "both", "label": "Entrambi" },
            { "value": "gs", "label": "Solo GS" },
            { "value": "gsp", "label": "Solo GSP" }
          ],
          "default": "both"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "id_gamme", "label": "Id" },
        { "type": "text", "id": "title_gamme", "label": "Titolo", "default": "Prestazioni al massimo livello" },
        { "type": "text", "id": "link_gamme", "label": "Label" },
        { "type": "url", "id": "url_gamme", "label": "Link" },
        {
          "type": "select",
          "id": "visibility",
          "label": "Mostra in:",
          "options": [
            { "value": "both", "label": "Entrambi" },
            { "value": "gs", "label": "Solo GS" },
            { "value": "gsp", "label": "Solo GSP" }
          ],
          "default": "both"
        }
      ]
    }
  ]
}
{% endschema %}