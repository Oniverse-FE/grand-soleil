{%- assign current_theme = 'gs' -%}
{%- if template contains 'gsp' or product.tags contains 'gsp' or page.template_suffix contains 'gsp' or collection.handle contains 'gsp' -%}
  {%- assign current_theme = 'gsp' -%}
{%- endif -%}

<script>
  (function() {
    const initialTheme = '{{ current_theme }}';
    document.documentElement.className = initialTheme;
  })();
</script>

<div class="fixed top-0 md:top-6 left-0 w-full flex justify-center items-center pointer-events-none z-[9998]">
  <header id="main-header" class="w-full md:max-w-[704px] lg:max-w-[768px] md:mx-6 md:mx-auto pointer-events-auto transition-all duration-500 ease-in-out overflow-hidden md:rounded-[24px] md:shadow-lg border-b md:border border-[var(--border-color)]">
    
    <div class="px-6 py-4 flex justify-between items-center relative z-[1001]">
      <div class="flex-1">
        <button id="burger-trigger" class="flex flex-col gap-1 group outline-none cursor-pointer">
          <span class="w-[20px] h-[1px] bg-current rounded-[4px] transition-all duration-300 group-[.active]:rotate-45 group-[.active]:translate-y-0.5"></span>
          <span class="w-[20px] h-[1px] bg-current rounded-[4px] transition-all duration-300 group-[.active]:-rotate-45 group-[.active]:-translate-y-1"></span>
        </button>
      </div>

      <div class="flex-none flex justify-center items-center">
          {% if section.settings.logo_gs != blank %}
             <a href="/pages/grand-soleil" class="logo-gs relative w-[155px] h-[28px]">
            <img src="{{ section.settings.logo_gs | image_url: width: 300 }}" 
                alt="Logo GS" 
                class="logo-gs h-auto w-full transition-opacity duration-500">
            </a>
          {% endif %}
          {% if section.settings.logo_gsp != blank %}
             <a href="/pages/grand-soleil-plus" class="logo-gsp relative w-[155px] h-[28px]">
            <img src="{{ section.settings.logo_gsp | image_url: width: 300 }}" 
                alt="Logo GSP" 
                class="logo-gsp h-auto w-full transition-opacity duration-500 absolute inset-0">
                  </a>
          {% endif %}

      </div>

      <div class="flex-1 text-right">
        <button id="panel-open" class="cursor-pointer body-sm_gs body-sm_gsp">
          {{ section.settings.right_label }}
        </button>
      </div>
    </div>

    <div id="dropdown-wrapper" class="overflow-y-auto max-h-0 transition-all duration-700 ease-in-out relative z-[1000]">
      
      <div id="menu-overlay" class="hidden px-8 py-8 flex flex-col gap-10 md:min-h-[500px]">
        <div class="main-nav-wrapper">
          <ul class="nav-links gs-only space-y-4 menu-md_gs">
            {% for link in linklists[section.settings.menu_gs].links %}
              <li class="menu-item-has-children">
                <div class="flex gap-4 items-center cursor-pointer group">
                  <a href="{{ link.url }}" class="flex">{{ link.title }}</a>
                  {% if link.links != blank %}
                    <span class="submenu-trigger bg-[#101C26] rounded-full transition-transform duration-300 p-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="7" height="7" viewBox="0 0 7 7" fill="none">
                        <path d="M3.25 0C3.38807 -6.03528e-09 3.5 0.111929 3.5 0.25V2.99805H6.25C6.38796 2.99805 6.49982 3.11013 6.5 3.24805C6.5 3.38612 6.38807 3.49805 6.25 3.49805H3.5V6.25C3.5 6.38807 3.38807 6.5 3.25 6.5C3.11193 6.5 3 6.38807 3 6.25V3.49805H0.25C0.111929 3.49805 -6.03527e-09 3.38612 0 3.24805C0.000175831 3.11013 0.112037 2.99805 0.25 2.99805H3V0.25C3 0.111929 3.11193 2.57833e-07 3.25 0Z" fill="#EBEFF2"/>
                      </svg>
                    </span>
                  {% endif %}
                </div>
                {% if link.links != blank %}
                  <ul class="submenu overflow-hidden max-h-0 transition-all duration-500 ease-in-out pl-4 space-y-2 pt-0">
                    {% for childlink in link.links %}
                      <li><a href="{{ childlink.url }}" class="opacity-70 hover:opacity-100 body-sm_gs">{{ childlink.title }}</a></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>

          <ul class="nav-links gsp-only space-y-4 menu-md_gsp">
            {% for link in linklists[section.settings.menu_gsp].links %}
              <li class="menu-item-has-children">
                <div class="flex gap-4 items-center cursor-pointer group">
                  <a href="{{ link.url }}" class="flex">{{ link.title }}</a>
                  {% if link.links != blank %}
                    <span class="submenu-trigger bg-[#282624] rounded-full transition-transform duration-300 p-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="7" height="7" viewBox="0 0 7 7" fill="none">
                        <path d="M3.25 0C3.38807 -6.03528e-09 3.5 0.111929 3.5 0.25V2.99805H6.25C6.38796 2.99805 6.49982 3.11013 6.5 3.24805C6.5 3.38612 6.38807 3.49805 6.25 3.49805H3.5V6.25C3.5 6.38807 3.38807 6.5 3.25 6.5C3.11193 6.5 3 6.38807 3 6.25V3.49805H0.25C0.111929 3.49805 -6.03527e-09 3.38612 0 3.24805C0.000175831 3.11013 0.112037 2.99805 0.25 2.99805H3V0.25C3 0.111929 3.11193 2.57833e-07 3.25 0Z" fill="#EBEFF2"/>
                      </svg>
                    </span>
                  {% endif %}
                </div>
                {% if link.links != blank %}
                  <ul class="submenu overflow-hidden max-h-0 transition-all duration-500 ease-in-out pl-4 space-y-2 pt-0">
                    {% for childlink in link.links %}
                      <li><a href="{{ childlink.url }}" class="opacity-70 hover:opacity-100 body-sm_gsp">{{ childlink.title }}</a></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>

        <div class="secondary-nav-wrapper border-t border-[var(--border-color)] pt-8">
          <ul class="flex flex-row flex-wrap gap-x-4 gs-only menu-xs_gs">
            {% for link in linklists[section.settings.menu_gs_secondary].links %}
              <li><a href="{{ link.url }}" class="underline">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
          <ul class="flex flex-row flex-wrap gap-x-6 gap-y-3 gsp-only menu-xs_gsp">
            {% for link in linklists[section.settings.menu_gsp_secondary].links %}
              <li><a href="{{ link.url }}" class="underline">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <div id="right-panel" class="hidden flex-col">
        <div class="px-6">
          <div class="chips-container flex flex-wrap gap-2 items-center pb-2">
            {% for block in section.blocks %}
              {% if block.type == 'chip' %}
                <button data-target="{{ block.settings.id_target }}"
                   class="custom-chip px-6 py-4 rounded-[50px] transition-all duration-300 link-md_gs link-md_gsp {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" 
                   {{ block.shopify_attributes }}>
                  {{ block.settings.title }}
                </button>
              {% endif %}
            {% endfor %}
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-8 pb-10">
            {% assign active_section_id = "" %}
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'text' %}
                  {% assign active_section_id = block.settings.id_gamme %}
                  <div id="{{ block.settings.id_gamme }}" data-observer-target="{{ block.settings.id_gamme }}" class="scroll-section col-span-1 md:col-span-2 pt-0 pb-2 flex flex-col gap-2 {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" {{ block.shopify_attributes }}>
                    <div class="menu-md_gs menu-md_gsp">{{ block.settings.title_gamme }}</div>
                    {% if block.settings.link_gamme != blank %}
                      <a href="{{ block.settings.url_gamme }}" class="body-sm_gs body-sm_gsp underline underline-offset-4">{{ block.settings.link_gamme }}</a>
                    {% endif %}
                  </div>
                {% when 'card' %}
                  <a href="{{ block.settings.link }}" data-observer-target="{{ active_section_id }}" class="scroll-section col-span-1 p-4 rounded-[16px] custom-card group flex flex-col {% if block.settings.visibility == 'gs' %}gs-only{% elsif block.settings.visibility == 'gsp' %}gsp-only{% endif %}" {{ block.shopify_attributes }}>
                    <div class="flex flex-row justify-between items-start pb-6">
                      <div class="flex flex-col gap-1">
                        <h4 class="menu-model_gsp menu-model_gs">{{ block.settings.title }}</h4>
                        <p class="menu-model_gsp menu-model_gs">{{ block.settings.description }}</p>
                      </div>
                      <span class="shrink-0 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 bg-[#05090D] rounded-full p-3">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                              <g clip-path="url(#clip0_3323_3339)">
                                  <path d="M5.07107 21.2169L19.2132 7.07481L5.77817 6.3677L10.0208 10.6103" stroke="#FAF9F7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </g>
                              <defs>
                                  <clipPath id="clip0_3323_3339">
                                  <rect width="24" height="24" fill="white"/>
                                  </clipPath>
                              </defs>
                          </svg>
                      </span>
                    </div>
                    {% if block.settings.image != blank %}
                    <div class="relative aspect-[4/3] overflow-hidden rounded-[8px] bg-[#80808020] mt-auto">
                      {% if block.settings.label_coming_soon != blank %}
                        <div class="absolute bottom-3 left-3 px-3 py-[6px] z-[10] rounded-[50px] pointer-events-none link-sm_gs link-sm_gsp coming-soon_gs coming-soon_gsp bg-black/50 text-white text-xs">
                          {{ block.settings.label_coming_soon }}
                        </div>
                      {% endif %}
                      <img src="{{ block.settings.image | image_url: width: 600 }}" 
                          class="w-full h-full object-cover transition-transform group-hover:scale-105 duration-700" 
                          loading="lazy">
                    </div>
                  {% endif %}
                  </a>
              {% endcase %}
            {% endfor %}
          </div>
        </div>

        <div class="px-6 py-6 border-t border-transparent mt-auto sticky bottom-0 bg-inherit z-30">
          <div class="relative w-full h-[59px] rounded-full p-1 flex items-center bg-[#EBEFF2]">
            <input type="radio" id="toggle-gs" name="theme-toggle" value="gs" class="peer/gs hidden">
            <label for="toggle-gs" class="flex-1 text-center z-10 cursor-pointer transition-colors peer-checked/gs:text-[#EBEFF2] font-medium text-[#101C26]">{{ section.settings.toggle_label_gs }}</label>
            
            <input type="radio" id="toggle-gsp" name="theme-toggle" value="gsp" class="peer/gsp hidden">
            <label for="toggle-gsp" class="flex-1 text-center z-10 cursor-pointer text-[#05090D] transition-colors peer-checked/gsp:text-[#FAF9F7] font-medium">{{ section.settings.toggle_label_gsp }}</label>
            
            <div id="toggle-slider" class="absolute top-1 left-1 w-[calc(50%-4px)] h-[51px] bg-[#101C26] rounded-full transition-all duration-500 pointer-events-none peer-checked/gsp:translate-x-full peer-checked/gsp:bg-[#282624]"></div>
          </div>
        </div>
      </div>
    </div>
  </header>
</div>

<div id="panel-overlay" class="fixed inset-0 z-[9990] bg-black/10 opacity-0 pointer-events-none transition-opacity duration-700 backdrop-blur-sm"></div>

<style>
  :root { --transition-speed: 0.4s; }
  .gs .gsp-only, .gsp .gs-only { display: none !important; }

  html.gs, body.gs { --bg-color: #101C26; --text-color: #EBEFF2; --border-color: rgba(235, 239, 242, 0.2); --card: #101C26; }
  html.gsp, body.gsp { --bg-color: #FAF9F7; --text-color: #141312; --border-color: rgba(20, 19, 18, 0.1); --card: #D4CCC1; }

  #main-header { background-color: var(--bg-color); color: var(--text-color); border-color: var(--border-color); backdrop-filter: blur(20px); transition: background-color var(--transition-speed); }

  @media (max-width: 767px) {
    #main-header.is-open { height: 100vh !important; max-width: 100% !important; top: 0 !important; border-radius: 0 !important; margin: 0 !important; }
    #dropdown-wrapper { height: calc(100vh - 70px); }
  }

  .submenu-trigger.active { transform: rotate(45deg); }
  .submenu.open { max-height: 500px; padding-top: 1rem; padding-bottom: 1rem; }

  .chips-container { position: sticky; top: 0; z-index: 40; background-color: var(--bg-color); padding-block: 32px; transition: background-color var(--transition-speed); }
  .custom-chip { border: 1px solid var(--border-color); color: inherit; background: transparent; }
  .custom-chip.is-active { background-color: var(--text-color); color: var(--bg-color); border-color: var(--text-color); }
  .custom-card { background-color: var(--card); border: 1px solid var(--border-color); }
  #panel-overlay.active { opacity: 1; pointer-events: auto; }
  #dropdown-wrapper::-webkit-scrollbar { display: none; }
  #dropdown-wrapper { -ms-overflow-style: none; scrollbar-width: none; }

  .logo-gsp { display: none; }
  .logo-gs { display: block; }
  .gsp .logo-gsp { display: block; }
  .gsp .logo-gs { display: none; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const header = document.getElementById('main-header');
  const dropdown = document.getElementById('dropdown-wrapper');
  const menuLeft = document.getElementById('menu-overlay');
  const menuRight = document.getElementById('right-panel');
  const burgerBtn = document.getElementById('burger-trigger');
  const openRight = document.getElementById('panel-open');
  const overlay = document.getElementById('panel-overlay');
  const radios = document.querySelectorAll('input[name="theme-toggle"]');
  const pageTheme = '{{ current_theme }}';

  // --- SINCRONIZZAZIONE INIZIALE ---
  // Imposta il radio button corretto in base al tema della pagina al caricamento
  const initialRadio = document.querySelector(`input[name="theme-toggle"][value="${pageTheme}"]`);
  if (initialRadio) initialRadio.checked = true;

  // --- FISARMONICA ---
  document.querySelectorAll('.menu-item-has-children').forEach(item => {
    const trigger = item.querySelector('.submenu-trigger');
    const submenu = item.querySelector('.submenu');
    if(trigger) {
      item.querySelector('.flex').addEventListener('click', (e) => {
        const isPlus = e.target.classList.contains('submenu-trigger');
        if(isPlus || e.currentTarget.querySelector('a').getAttribute('href') === '#') {
          e.preventDefault();
          trigger.classList.toggle('active');
          submenu.classList.toggle('open');
        }
      });
    }
  });

  // --- INTERSECTION OBSERVER ---
  const observedElements = document.querySelectorAll('.scroll-section');
  const chips = document.querySelectorAll('.custom-chip');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const targetId = entry.target.getAttribute('data-observer-target');
        if (targetId) chips.forEach(chip => chip.classList.toggle('is-active', chip.getAttribute('data-target') === targetId));
      }
    });
  }, { root: dropdown, threshold: [0.1, 0.5], rootMargin: "-20% 0px -70% 0px" });

  observedElements.forEach(el => observer.observe(el));

  // --- NAV CLICK ---
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const target = document.getElementById(chip.getAttribute('data-target'));
      if (target) dropdown.scrollTo({ top: target.offsetTop - 110, behavior: 'smooth' });
    });
  });

  // --- LOGICA DI CHIUSURA ---
  const updateThemeUI = (theme) => { 
    document.documentElement.className = theme; 
    document.body.className = theme; 
  };

  const closeAll = () => {
    dropdown.style.maxHeight = '0px';
    overlay.classList.remove('active');
    burgerBtn.classList.remove('active');
    header.classList.remove('is-open');
    document.body.style.overflow = '';

    setTimeout(() => {
      menuLeft.classList.add('hidden');
      menuRight.classList.add('hidden');
      
      // Ripristina tema e toggle alla chiusura
      updateThemeUI(pageTheme);
      const r = document.querySelector(`input[name="theme-toggle"][value="${pageTheme}"]`);
      if(r) r.checked = true;
    }, 700);
  };

  // --- TRIGGER APERTURA ---
  const openMenu = (side) => {
    const isMobile = window.innerWidth < 768;
    
    if (side === 'left') {
        menuRight.classList.add('hidden');
        menuLeft.classList.remove('hidden');
    } else {
        menuLeft.classList.add('hidden');
        menuRight.classList.remove('hidden');
    }

    setTimeout(() => {
      header.classList.add('is-open');
      dropdown.style.maxHeight = isMobile ? '100vh' : '85vh';
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      if(side === 'left') burgerBtn.classList.add('active');
    }, 10);
  }

  burgerBtn.addEventListener('click', () => {
    if(!menuLeft.classList.contains('hidden') && dropdown.style.maxHeight !== '0px') {
      closeAll();
    } else {
      openMenu('left');
    }
  });

  openRight.addEventListener('click', () => {
    if(!menuRight.classList.contains('hidden') && dropdown.style.maxHeight !== '0px') {
      closeAll();
    } else {
      openMenu('right');
    }
  });

  overlay.addEventListener('click', closeAll);
  
  // Cambio tema dinamico nel pannello
  radios.forEach(radio => radio.addEventListener('change', (e) => updateThemeUI(e.target.value)));
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "header", "content": "Loghi" },
    { "type": "image_picker", "id": "logo_gs", "label": "Logo GS" },
    { "type": "image_picker", "id": "logo_gsp", "label": "Logo GSP" },
    { "type": "range", "id": "logo_width", "min": 50, "max": 200, "step": 10, "default": 100, "unit": "px", "label": "Larghezza Logo" },
    { "type": "header", "content": "Menu Burger" },
    { "type": "link_list", "id": "menu_gs", "label": "Menu GS" },
    { "type": "link_list", "id": "menu_gsp", "label": "Menu GSP" },
    { "type": "link_list", "id": "menu_gs_secondary", "label": "Menu Secondario GS"},
    { "type": "link_list", "id": "menu_gsp_secondary", "label": "Menu Secondario GSP"},
    { "type": "header", "content": "Pannello Destra" },
    { "type": "text", "id": "right_label", "label": "Etichetta Bottone", "default": "DISCOVER" },
    { "type": "text", "id": "toggle_label_gs", "label": "Testo GS", "default": "GS MODE" },
    { "type": "text", "id": "toggle_label_gsp", "label": "Testo GSP", "default": "GSP MODE" }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Chip (Ancora)",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo Chip", "default": "Design" },
        { "type": "text", "id": "id_target", "label": "ID Destinazione" },
        { "type": "select", "id": "visibility", "label": "Mostra in:", "options": [{"value": "both", "label": "Entrambi"}, {"value": "gs", "label": "Solo GS"}, {"value": "gsp", "label": "Solo GSP"}], "default": "both" }
      ]
    },
    {
      "type": "text",
      "name": "Text (Gamme)",
      "settings": [
        { "type": "text", "id": "id_gamme", "label": "ID Unico Sezione" },
        { "type": "text", "id": "title_gamme", "label": "Titolo", "default": "Prestazioni" },
        { "type": "text", "id": "link_gamme", "label": "Testo Link" },
        { "type": "url", "id": "url_gamme", "label": "URL Link" },
        { "type": "select", "id": "visibility", "label": "Mostra in:", "options": [{"value": "both", "label": "Entrambi"}, {"value": "gs", "label": "Solo GS"}, {"value": "gsp", "label": "Solo GSP"}], "default": "both" }
      ]
    },
    {
      "type": "card",
      "name": "Card Progetto",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Immagine" },
        { "type": "text", "id": "title", "label": "Titolo" },
        { "type": "text", "id": "description", "label": "Descrizione" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text","id": "label_coming_soon","label": "Testo Coming Soon","default": "Coming Soon"},
        { "type": "select", "id": "visibility", "label": "Mostra in:", "options": [{"value": "both", "label": "Entrambi"}, {"value": "gs", "label": "Solo GS"}, {"value": "gsp", "label": "Solo GSP"}], "default": "both" }
      ]
    }
  ]
}
{% endschema %}