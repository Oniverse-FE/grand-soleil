        {
          "type": "checkbox",
          "id": "contact-bg-transparent",
          "label": "Contact button transparent background",
          "default": false
        },
        {
            "type": "color",
            "id": "contact-bg-color",
            "label": "Contact button background color",
            "default": "#ffffff"
        },
        {
            "type": "color",
            "id": "contact-border-color",
            "label": "Contact button border color",
            "default": "#ffffff"
        },
        {
            "type": "text",
            "id": "contact-label",
            "label": "Contact button label",
            "default": "Contattaci"
        },
        {
            "type": "url",
            "id": "contact-link",
            "label": "Contact button link"
        },
        {
            "type": "checkbox",
            "id": "header-link-caps",
            "label": "Header large menù link in uppercase",
            "default": true
        },
        {
