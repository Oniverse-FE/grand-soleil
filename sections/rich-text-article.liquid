<div class="bg_gs bg_gsp rich-text-{{ section.id }} flex flex-col px-4 md:px-8 lg:px-10 xl:px-[128px] gap-10 lg:gap-12">
    <div class="flex flex-col gap-3 lg:gap-6 
        {% if section.settings.alignment_mobile == 'center' %} items-center text-center {% else %} items-start text-left {% endif %}
        {% if section.settings.alignment_desktop == 'center' %} md:items-center md:text-center {% else %} md:items-start md:text-left {% endif %}">
        
        {%- if section.settings.rta_subtitle != blank -%}
          <div class="flex pretitle-sm_gs pretitle-sm_gsp md:pretitle-lg_gs md:pretitle-lg_gsp text-blue_gs text-truffle_gsp">
              {{ section.settings.rta_subtitle }}
          </div>
        {%- endif -%}

        {%- if section.settings.rta_h1title != blank -%}
          <h1 class="flex heading-md_gs heading-md_gsp md:title_gs md:title_gsp text-color_gs text-color_gsp">
              {{ section.settings.rta_h1title }}
          </h1>
        {%- endif -%}

        {%- if section.settings.rta_title != blank -%}
          <div class="flex heading-sm_gs heading-sm_gsp md:heading-md_gs md:heading-md_gsp text-color_gs text-color_gsp">
              {{ section.settings.rta_title }}
          </div>
        {%- endif -%}

        {%- if section.settings.rta_text1 != blank -%}
          <div class="body-md_gs body-md_gsp md:body-lg_gs md:body-lg_gsp text-color_gs text-color_gsp lg:max-w-[872px]">
              {{ section.settings.rta_text1 | newline_to_br }}
          </div>
        {%- endif -%}

        {%- comment -%} Sezione Bottoni {%- endcomment -%}
        {% if section.settings.rta-cta_link != blank or section.settings.rta_modal_label != blank %}
          <div class="flex flex-col md:flex-row flex-wrap gap-4 w-full 
              {% if section.settings.alignment_mobile == 'center' %} justify-center {% else %} justify-start {% endif %}
              {% if section.settings.alignment_desktop == 'center' %} md:justify-center {% else %} md:justify-start {% endif %}">
            
            {%- if section.settings.rta-cta_link != blank -%}
              <a id="cta-link-{{ section.id }}"
                  href="{{ section.settings.rta-cta_link }}"
                  class="cta-button w-full md:w-fit text-center px-7 py-3.5 link-lg_gs link-lg_gsp cta-truffle_gsp cta-101C26_gs transition-all duration-300">
                {{ section.settings.rta-cta_label }}
              </a>
            {%- endif -%}

            {%- if section.settings.rta_modal_label != blank -%}
              <button type="button"
                  id="{{ section.settings.rta_modal_id }}"
                  class="cta-button w-full md:w-fit text-center px-7 py-3.5 link-lg_gs link-lg_gsp cta-truffle_gsp cta-blue_gs transition-all duration-300">
                {{ section.settings.rta_modal_label }}
              </button>
            {%- endif -%}
          </div>
        {% endif %}
     </div>
</div>

{% render 'modale-hall-of-fame' %}
<style>
  .rich-text-{{ section.id }} {
    padding-top: {{ section.settings.pt_mobile }}px;
    padding-bottom: {{ section.settings.pb_mobile }}px;
  }
  @media screen and (min-width: 768px) {
    .rich-text-{{ section.id }} {
      padding-top: {{ section.settings.pt_tablet }}px;
      padding-bottom: {{ section.settings.pb_tablet }}px;
    }
  }
  @media screen and (min-width: 1024px) {
    .rich-text-{{ section.id }} {
      padding-top: {{ section.settings.pt_desktop }}px;
      padding-bottom: {{ section.settings.pb_desktop }}px;
    }
  }
  /* Stile minimo per rendere il bottone modale coerente */
  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
  }
</style>

