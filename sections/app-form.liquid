<script>
        document.addEventListener('DOMContentLoaded', function () {
            // Find the form robustly
            const form = document.getElementById('booking_form') ||
                document.querySelector('form[action*="/contact"]') ||
                document.querySelector('form[action*="/customer"]');

            if (!form) {
                console.warn('Form not found. Check that the form has the id "booking_form" or "ask_to_Pardo_form" or that there is a form with an action containing "/contact".');
                return;
            }

            // Helper for scoped queries
            const $ = sel => form.querySelector(sel);
            const $$ = sel => Array.from(form.querySelectorAll(sel));

            // Hidden fields (scoped to the form)
            const tagsInput = document.getElementById('CustomerTags');
            const noteInput = document.getElementById('CustomerNote');

            // Elements used
            const bookingCallToActions = document.querySelectorAll('.booking-cta');
            const appointmentWrapper = document.getElementById('appointment-form-wrapper');
            const appointmentBox = document.getElementById('appointment-form-box');
            const closeButton = document.getElementById('appointment-form-close');
            const submitButton = document.getElementById('appointment-form-submit');
            const formWrapper = document.getElementById('appointment-form-wrapper');
            const marketingLink = document.getElementById('app-form-shortMarketing');
            const profilingLink = document.getElementById('app-form-shortProfiling');
            const marketingOverlay = document.getElementById('app-form-marketing-overlay');
            const profilingOverlay = document.getElementById('app-form-profiling-overlay');
            const marketingCloseButton = document.getElementById('app-form-marketing-close');
            const profilingCloseButton = document.getElementById('app-form-profiling-close');

            // Function to show an overlay and hide the form
            function showOverlay(overlay) {
                formWrapper.classList.add('opacity-0', 'pointer-events-none');
                overlay.classList.remove('opacity-0', 'pointer-events-none');
            }

            // Function to hide an overlay and show the form
            function hideOverlay(overlay) {
                overlay.classList.add('opacity-0', 'pointer-events-none');
                formWrapper.classList.remove('opacity-0', 'pointer-events-none');
            }

            function closeForm(){
                appointmentBox?.classList.remove('opacity-100', 'translate-y-0');
                appointmentBox?.classList.add('opacity-0', 'translate-y-10');

                setTimeout(() => {
                    appointmentWrapper?.classList.add('opacity-0', 'pointer-events-none', 'hidden');
                    appointmentWrapper?.classList.remove('opacity-100');
                    document.body.classList.remove('no-scroll');
                    const dateList = $('#dateList') || document.getElementById('dateList') || $('#date-list') || document.getElementById('date-list');
                    if (dateList) dateList.classList.add('hidden');
                }, 300);
            }

            // Listener for links
            if (marketingLink) {
                marketingLink.addEventListener('click', (e) => {
                    e.preventDefault();
                    showOverlay(marketingOverlay);
                });
            }

            if (profilingLink) {
                profilingLink.addEventListener('click', (e) => {
                    e.preventDefault();
                    showOverlay(profilingOverlay);
                });
            }

            // Listener for close buttons
            if (marketingCloseButton) {
                marketingCloseButton.addEventListener('click', () => {
                    hideOverlay(marketingOverlay);
                });
            }

            if (profilingCloseButton) {
                profilingCloseButton.addEventListener('click', () => {
                    hideOverlay(profilingOverlay);
                });
            }

            // ----------------------
            // Open/close overlay
            // ----------------------
            bookingCallToActions.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();

                    // Reset possible date input
                    const dateInput = $('input[name="contact[appointment_date]"]') || document.getElementById('app-form-date');
                    const dateList = $('#dateList') || document.getElementById('dateList') || $('#date-list') || document.getElementById('date-list');

                    if (dateList) dateList.innerHTML = "";
                    if (dateInput) dateInput.value = "";

                    // Populate date list if data-start / data-end are present on the anchor
                    const start = btn.getAttribute('data-start');
                    const end = btn.getAttribute('data-end');
                    if (start && end && dateList) populateDateList(dateList, dateInput, start, end);

                    // Save handle and title
                    form.dataset.eventHandle = btn.getAttribute('data-handle') || "";
                    form.dataset.eventTitle = btn.getAttribute('data-title') || "";

                    // Show overlay
                    appointmentWrapper?.classList.remove('hidden', 'opacity-0', 'pointer-events-none');
                    appointmentWrapper?.classList.add('opacity-100');
                    document.body.classList.add('no-scroll');

                    setTimeout(() => {
                        appointmentBox?.classList.remove('opacity-0', 'translate-y-10');
                        appointmentBox?.classList.add('opacity-100', 'translate-y-0');
                    }, 50);
                });
            });

            closeButton?.addEventListener('click', function () {
                closeForm();
            });

            document.querySelectorAll('#appointment-form-box input[name="contact[boat-question]"]').forEach(radio => {
                radio.addEventListener('change', e => {
                    // Hide all extra groups
                    document.querySelectorAll('#boat-y-fields, #boat-o-fields').forEach(el => el.classList.add('hidden'));

                    // Show the corresponding one (only if defined)
                    const targetId = e.target.dataset.target;
                    if (targetId) {
                        document.getElementById(targetId).classList.remove('hidden');
                    }
                });
            });

            // ----------------------
            // Submit: build tags + note
            // ----------------------
            submitButton.addEventListener('click', function (e) {
                e.preventDefault();

                form.querySelectorAll(".border-red").forEach(el => el.classList.remove("border-red"));

                if (!form.checkValidity()) {
                    form.reportValidity();
                    return; // blocca submit
                }

                // === COSTRUZIONE TAGS ===
                const tags = [];
                tags.push('event');
                if (form.dataset.eventHandle) tags.push(form.dataset.eventHandle);

                const marketing = document.getElementById('app-form-marketingConsent');
                const profiling = document.getElementById('app-form-profilingConsent');

                if (marketing?.checked) tags.push('marketing');
                if (profiling?.checked) tags.push('profiling');

                const boats = Array.from(form.querySelectorAll('.multi-checkbox:checked')).map(cb => cb.value);
                boats.forEach(b => tags.push(b.replace(/\s+/g, '-')));

                if (tagsInput) tagsInput.value = Array.from(new Set(tags)).join(',');

                // === COSTRUZIONE NOTE ===
                const noteLines = [];
                if (form.dataset.eventTitle) noteLines.push("Event: " + form.dataset.eventTitle);

                const countryValue = (form.querySelector('input[name="contact[country]"]') || document.getElementById('app-form-country'))?.value;
                if (countryValue) noteLines.push("Country: " + countryValue);

                const appointmentValue = (form.querySelector('input[name="contact[appointment_date]"]') || document.getElementById('app-form-date'))?.value;
                if (appointmentValue) noteLines.push("Appointment Date: " + appointmentValue);

                const boatSelected = form.querySelector("input[name='contact[boat-question]']:checked");
                if (boatSelected) {
                    const label = boatSelected.nextElementSibling ? boatSelected.nextElementSibling.innerText.trim() : boatSelected.value;
                    noteLines.push("Boat Question: " + label);

                    const targetId = boatSelected.dataset.target;
                    if (targetId) {
                        const extraFields = document.getElementById(targetId);
                        if (extraFields) {
                            const modelInput = extraFields.querySelector("input[id='" + targetId.replace("-fields","-model") + "']");
                            const portInput  = extraFields.querySelector("input[id='" + targetId.replace("-fields","-port-country") + "']");

                            if (modelInput?.value) noteLines.push("Boat Model: " + modelInput.value);
                            if (portInput?.value) noteLines.push("Port Country: " + portInput.value);
                        }
                    }
                }

                const buySelected = form.querySelector("input[name='contact[buy-question]']:checked");
                if (buySelected) {
                    const label = buySelected.nextElementSibling ? buySelected.nextElementSibling.innerText.trim() : buySelected.value;
                    noteLines.push("Purchase Intent: " + label);
                }

                if (boats.length) noteLines.push("Selected Boats: " + boats.join(", "));

                const messageValue = (form.querySelector('#app-form-message') || form.querySelector('textarea[name="contact[message]"]'))?.value;
                if (messageValue) noteLines.push("Message: " + messageValue);

                const contactPref = form.querySelector("input[name='contact[contact-question]']:checked");
                if (contactPref) {
                    const label = contactPref.nextElementSibling ? contactPref.nextElementSibling.innerText.trim() : contactPref.value;
                    noteLines.push("Preferred Contact: " + label);

                    const targetId = "phone-fields-" + contactPref.value;
                    const phoneFields = document.getElementById(targetId);
                    if (phoneFields) {
                        const prefixInput = phoneFields.querySelector("input[name='contact[phone-prefix-" + contactPref.value + "]']");
                        const numberInput = phoneFields.querySelector("input[name='contact[phone-number-" + contactPref.value + "]']");

                        if (prefixInput?.value) noteLines.push("Phone Prefix: " + prefixInput.value);
                        if (numberInput?.value) noteLines.push("Phone Number: " + numberInput.value);
                    }
                }

                if (noteInput) noteInput.value = noteLines.join("\n");

                // === INVIO AJAX A SHOPIFY ===
                const formData = new FormData(form);

                fetch(form.action, {
                    method: "POST",
                    body: formData,
                    headers: { "Accept": "application/json" }
                })
                .then(response => {
                    appointmentBox?.classList.add('opacity-0', 'pointer-events-none', 'hidden');
                    document.getElementById("thankyou-popup").classList.remove("hidden");
                })
                .catch(err => {
                    console.error(err);
                    appointmentBox?.classList.add('opacity-0', 'pointer-events-none', 'hidden');
                    document.getElementById("thankyou-popup").classList.remove("hidden");
                });
            });


            // === CHIUSURA POPUP ===
            document.getElementById("app-form-ty-close").addEventListener("click", function() {
                document.getElementById("thankyou-popup").classList.add("hidden");
                closeForm();
            });

            document.getElementById("app-form-ty-close-btn").addEventListener("click",function(){
                document.getElementById("thankyou-popup").classList.add("hidden");
                closeForm();
            });
            // ----------------------
            // Multi-select boat selection: update real hidden field
            // ----------------------
            // Scope to the form
            form.querySelectorAll('[data-name="contact[boat-selection]"] label').forEach(label => {
                const checkbox = label.querySelector("input[type=checkbox]");
                // Note: The original code references a 'span' for an icon, which is not in this mock HTML. The logic is preserved.
                const icon = label.querySelector("span"); 

                label.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (!checkbox) return;
                    checkbox.checked = !checkbox.checked;

                    if (checkbox.checked) {
                        label.classList.add("bg-white", "text-black");
                        label.classList.remove("bg-antracite", "text-white");
                        if (icon) icon.classList.remove("hidden");
                    } else {
                        label.classList.add("bg-antracite", "text-white");
                        label.classList.remove("bg-white", "text-black");
                        if (icon) icon.classList.add("hidden");
                    }

                    // Update the specific hidden field created in the markup
                    const hiddenBoat = $('#app-form-boat-selection') || document.getElementById('app-form-boat-selection');
                    if (hiddenBoat) {
                        const selected = Array.from(form.querySelectorAll('.multi-checkbox:checked')).map(cb => cb.value);
                        hiddenBoat.value = selected.join(', ');
                        // Fire change event if necessary
                        hiddenBoat.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                });
            });


            // ----------------------
            // Textarea counter (e.g., app-form-message)
            // ----------------------
            (function setupTextAreaCounter() {
                const textarea = form.querySelector('#app-form-message') || form.querySelector('textarea[name="contact[message]"]');
                const counter = document.getElementById('app-message-counter') || form.querySelector('.char-counter');
                if (!textarea || !counter) return;
                const maxLength = parseInt(textarea.getAttribute('maxlength')) || 250;
                const update = () => {
                    textarea.style.height = 'auto';
                    textarea.style.height = textarea.scrollHeight + 'px';
                    counter.textContent = `${textarea.value.length} / ${maxLength}`;
                };
                textarea.addEventListener('input', update);
                update();
            })();


            // ----------------------
            // Date helpers (same logic already present, but scoped)
            // ----------------------
            function formatDateDDMMYYYY(date) {
                const d = date.getDate().toString().padStart(2, "0");
                const m = (date.getMonth() + 1).toString().padStart(2, "0");
                const y = date.getFullYear();
                return `${d}/${m}/${y}`;
            }

            function parseDateFlexible(val) {
                if (!val) return null;
                const iso = new Date(val);
                if (!isNaN(iso)) return iso;
                const m = /^(\d{2})\/(\d{2})\/(\d{4})$/.exec(val);
                if (m) {
                    const d = new Date(parseInt(m[3], 10), parseInt(m[2], 10) - 1, parseInt(m[1], 10));
                    return isNaN(d) ? null : d;
                }
                return null;
            }

            function getDateRange(start, end) {
                const s = parseDateFlexible(start);
                const e = parseDateFlexible(end);
                if (!s || !e) return [];
                s.setHours(0, 0, 0, 0);
                e.setHours(0, 0, 0, 0);
                const out = [];
                let cur = new Date(s);
                while (cur <= e) {
                    out.push(new Date(cur));
                    cur.setDate(cur.getDate() + 1);
                }
                return out;
            }

            function populateDateList(ul, input, start, end) {
                if (!ul) return;
                ul.innerHTML = "";
                const dates = getDateRange(start, end);
                dates.forEach(date => {
                    const formatted = formatDateDDMMYYYY(date);
                    const li = document.createElement("li");
                    li.textContent = formatted;
                    li.className = "px-4 py-2 m-2 hover:bg-black bg-antracite cursor-pointer flex items-center gap-2 rounded-lg";
                    li.onmousedown = (evt) => {
                        evt.preventDefault();
                        if (input) input.value = formatted;
                        ul.querySelectorAll("li").forEach(el => el.classList.remove("bg-black"));
                        li.classList.add("bg-black");
                        window.toggleDateDropdown(false);
                    };
                    ul.appendChild(li);
                });
                ul.classList.add("hidden");
            }

            // Global toggleDateDropdown (used by the inline onclick in the markup)
            window.toggleDateDropdown = function (show) {
                const ul = $('#dateList') || document.getElementById('dateList') || $('#date-list') || document.getElementById('date-list');
                if (!ul) return;
                if (show && ul.children.length) ul.classList.remove('hidden');
                else ul.classList.add('hidden');
            };

            window.hideDateDropdown = function () { setTimeout(() => window.toggleDateDropdown(false), 200); };


            // ----------------------
            // Country list (fetch + filter) - maintains same logic but uses form scope
            // ----------------------
            let allCountries = [];
            // Fetches a list of countries from a public API
            fetch('https://raw.githubusercontent.com/mledoze/countries/master/countries.json')
                .then(res => res.json())
                .then(data => {
                    allCountries = data.map(c => ({
                        name: c.name.common,
                        code: c.cca2.toLowerCase()
                    }));
                })
                .catch(err => console.error("Error loading countries:", err));

            const countryInputs = document.querySelectorAll('.country-input');

            countryInputs.forEach(input => {
                const container = input.closest('.flex.flex-col.gap-1.relative');
                if (!container) return;

                const ul = container.querySelector('.countryList');
                const flagContainer = container.querySelector('.country-flag');

                input.addEventListener('input', () => filterCountries(input, ul, flagContainer));
                input.addEventListener('focus', () => toggleDropdown(true, ul, input, flagContainer));
                input.addEventListener('blur', () => hideDropdown(ul));
            });

            function setFlag(country, code, flagContainer) {
                if (!flagContainer) return;
                const flagUrl = `https://flagcdn.com/w40/${code}.png`;
                flagContainer.innerHTML = `<img src="${flagUrl}" alt="Flag of ${country}" class="w-5 h-4 rounded-sm object-cover">`;
            }

            function toggleDropdown(show, ul, input, flagContainer) {
                if (show && allCountries.length) {
                    ul.classList.remove('hidden');
                    filterCountries(input, ul, flagContainer);
                } else {
                    ul.classList.add('hidden');
                }
            }

            function hideDropdown(ul) {
                setTimeout(() => toggleDropdown(false, ul), 200);
            }

            function filterCountries(input, ul, flagContainer) {
                const filter = input.value.toLowerCase();
                ul.innerHTML = '';

                let countriesToShow;
                if (!filter.trim()) {
                    // If input is empty, show the first 10 countries
                    countriesToShow = allCountries.slice(0, 10);
                    if (flagContainer) flagContainer.innerHTML = '';
                } else {
                    // If input has text, filter the countries
                    countriesToShow = allCountries.filter(c => c.name.toLowerCase().includes(filter));
                }

                countriesToShow.forEach(c => {
                    const li = document.createElement('li');
                    li.className = 'px-4 py-2 m-2 hover:bg-black bg-antracite cursor-pointer flex items-center gap-2 rounded-lg';
                    const flagUrl = `https://flagcdn.com/w40/${c.code}.png`;
                    li.innerHTML = `<img src="${flagUrl}" alt="Flag of ${c.name}" class="w-5 h-4 rounded-sm object-cover"><span>${c.name}</span>`;

                    li.addEventListener('mousedown', (event) => {
                        event.preventDefault();
                        input.value = c.name;
                        setFlag(c.name, c.code, flagContainer);
                        toggleDropdown(false, ul);
                    });
                    ul.appendChild(li);
                });
            }

            const phoneFieldsPhone = document.getElementById('phone-fields-phone');
            const phoneFieldsBoth = document.getElementById('phone-fields-both');
            const radioButtons = document.querySelectorAll('input[name="contact[contact-question]"]');

            radioButtons.forEach(radio => {
                radio.addEventListener('change', (event) => {
                    // Hide both phone field blocks
                    phoneFieldsPhone.classList.add('hidden');
                    phoneFieldsBoth.classList.add('hidden');

                    // Show the correct field block based on the selected option
                    const selectedValue = event.target.value;
                    if (selectedValue === 'phone') {
                        phoneFieldsPhone.classList.remove('hidden');
                    } else if (selectedValue === 'both') {
                        phoneFieldsBoth.classList.remove('hidden');
                    }
                });
            });

            // --- DONE ---
            // Initializes the profiling checkbox state (depends on the marketing checkbox)
            const marketingCheckbox = $('#app-form-marketingConsent') || document.getElementById('app-form-marketingConsent');
            const profilingCheckbox = $('#app-form-profilingConsent') || document.getElementById('app-form-profilingConsent');
            if (marketingCheckbox && profilingCheckbox) {
                const updateProfilingState = () => {
                    if (marketingCheckbox.checked) {
                        profilingCheckbox.disabled = false;
                    } else {
                        profilingCheckbox.disabled = true;
                        profilingCheckbox.checked = false;
                    }
                };
                updateProfilingState();
                marketingCheckbox.addEventListener('change', updateProfilingState);
            }
        });
</script>
