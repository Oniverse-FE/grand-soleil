<!-- UNICO contenitore con overlay -->
<div id="appointment-form-wrapper"
    class="fixed top-0 left-0 flex justify-center items-center w-screen h-screen bg-black/50 z-50 opacity-0 pointer-events-none transition-opacity duration-300">

    {% form 'customer', id: 'booking_form' %}

    <!-- Box form animato da sotto -->
    <div id="appointment-form-box"
        class="flex flex-col overflow-y-auto overflow-visible max-h-[80vh] opacity-0 translate-y-10 transition-all duration-300 max-w-[720px] w-screen bg-white rounded-xl lg:px-10 py-8 px-4 gap-10"
        style="background-color: {{ section.settings.appointment-form-bg-color }}; color: {{ section.settings.appointment-form-text-color }}">

        <!-- Header con titolo e X e testo-->
        <div class="flex flex-col gap-6">
            <div class="flex justify-between">
                <div class="body-medium text-xl">{{ section.settings.appointment-form-title }}</div>
                <div id="appointment-form-close" class="cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                        stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="flex justify-end text-[12px] leading-[18px] md:text-[14px] md:leading-[20px] body-regular">
            {{ section.settings.appointment-form-required-text }}
        </div>
        <div class="flex flex-col gap-12">
            <!-- personal info + date -->
            <div class="flex flex-col gap-6">
                <div class="grid grid-cols-1 gap-5 lg:grid-cols-2 lg:gap-4">
                    <div class="flex flex-col gap-1">
                        <div class="flex body-regular text-[12px] leading-[18px]">
                            {{ section.settings.app-fname-label}}{% if section.settings.app-fname-required == true %}*{%
                            endif %}
                        </div>
                        <input class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white"
                            type="text" id="app-form-first-name" name="contact[first_name]"
                            placeholder="{{- section.settings.app-fname-placeholder }}" {% if
                            section.settings.app-fname-required==true %} required {% endif %}>
                    </div>

                    <div class="flex flex-col gap-1">
                        <div class="flex body-regular text-[12px] leading-[18px]">
                            {{ section.settings.app-lname-label}}{% if section.settings.app-lname-required == true %}*{%
                            endif %}
                        </div>
                        <input class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white"
                            type="text" id="app-form-last-name" name="contact[last_name]"
                            placeholder="{{- section.settings.app-lname-placeholder }}" {% if
                            section.settings.app-lname-required==true %} required {% endif %}>
                    </div>

                    <div class="flex flex-col gap-1 relative">
                        <div class="flex body-regular text-[12px] leading-[18px]">
                            {{ section.settings.app-country-label}}{% if section.settings.app-country-required == true
                            %}*{% endif %}
                        </div>
                        <input
                            class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pr-10 country-input"
                            type="text" name="contact[country]" id="app-form-country" autocomplete="off"
                            placeholder="{{- section.settings.app-country-placeholder }}" {% if
                            section.settings.app-country-required==true %} required {% endif %}>
                        <div id="country-flag"
                            class="country-flag absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none">
                        </div>
                        <ul id="countryList"
                            class="countryList absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                        </ul>
                    </div>

                    <div class="flex flex-col gap-1">
                        <div class="flex body-regular text-[12px] leading-[18px]">
                            {{ section.settings.app-mail-label}}{% if section.settings.app-mail-required == true %}*{%
                            endif %}
                        </div>
                        <input class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white"
                            type="email" id="app-form-mail" name="contact[email]"
                            placeholder="{{- section.settings.app-mail-placeholder }}" {% if
                            section.settings.app-mail-required==true %} required {% endif %}>
                    </div>
                </div>
                <div class="flex flex-col gap-1 relative">
                    <div class="flex body-regular text-[12px] leading-[18px]">
                        {{ section.settings.app-date-label }}{% if section.settings.app-date-required == true %}*{%
                        endif %}
                    </div>
                    <input class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pr-10"
                        type="text" name="contact[appointment_date]" id="app-form-date"
                        onclick="toggleDateDropdown(true)" onblur="hideDateDropdown()" autocomplete="off"
                        placeholder="{{ section.settings.app-date-placeholder }}" {% if
                        section.settings.app-date-required==true %} required {% endif %}>
                    <ul id="dateList"
                        class="absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                    </ul>
                </div>
            </div>
            <!-- boat question-->
            <div class="body-regular text-[16px] leading-[22px] flex flex-col gap-4">
                <div class="flex">
                    {{ section.settings.app-boat-q-label }}{% if section.settings.app-boat-q-required == true %}*{%
                    endif %}
                </div>

                <div class="flex flex-col gap-2">
                    <!-- Boat Yes -->
                    <div class="flex flex-col gap-2">
                        <div class="flex gap-2 justify-start items-center">
                            <input type="radio"
                                class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                id="boat-y" name="contact[boat-question]" value="vd" data-target="boat-y-fields">
                            <label for="boat-y">{{ section.settings.app-boat-q-affermative-label }}</label>
                        </div>
                        <!-- Campi extra per boat-y -->
                        <div id="boat-y-fields" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                            <!-- Model -->
                            <div class="flex flex-col gap-1 w-full">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-boat-q-model-label }}</div>
                                <input
                                    class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white"
                                    type="text" id="boat-y-model" name="contact[boat-y-model]"
                                    placeholder="{{ section.settings.app-form-boat-q-model-placeholder }}">
                            </div>
                            <!-- Port country -->
                            <div class="flex flex-col gap-1 relative w-full">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-boat-q-port-label }}</div>
                                <input
                                    class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pr-10 country-input"
                                    type="text" name="contact[boat-y-port-country]" id="boat-y-port-country"
                                    placeholder="{{ section.settings.app-form-boat-q-port-placeholder}}" autocomplete="off">
                                <div class="country-flag absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none">
                                </div>
                                <ul
                                    class="countryList absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Boat Other -->
                    <div class="flex flex-col gap-2">
                        <div class="flex gap-2 justify-start items-center">
                            <input type="radio"
                                class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                id="boat-o" name="contact[boat-question]" value="other" data-target="boat-o-fields">
                            <label for="boat-o">{{ section.settings.app-boat-q-other-label }}</label>
                        </div>
                        <!-- Campi extra per boat-o -->
                        <div id="boat-o-fields" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                            <!-- Model -->
                            <div class="flex flex-col gap-1 w-full">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-boat-q-model-label }}</div>
                                <input
                                    class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white"
                                    type="text" id="boat-o-model" name="contact[boat-o-model]"
                                    placeholder="{{ section.settings.app-form-boat-q-model-placeholder}}">
                            </div>
                            <!-- Port country -->
                            <div class="flex flex-col gap-1 relative w-full">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-boat-q-port-label}}</div>
                                <input
                                    class="body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pr-10 country-input"
                                    type="text" name="contact[boat-o-port-country]" id="boat-o-port-country"
                                    placeholder="{{ section.settings.app-form-boat-q-port-placeholder}}" autocomplete="off">
                                <div class="country-flag absolute right-0 bottom-0 pb-2 mr-2 z-50 pointer-events-none">
                                </div>
                                <ul
                                    class="countryList absolute top-full mt-1 bg-antracite border border-gray-300 max-h-60 overflow-y-auto overflow-x-hidden w-full rounded-md shadow-md hidden z-50">
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Boat No -->
                    <div class="flex gap-2 justify-start items-center">
                        <input type="radio"
                            class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                            id="boat-n" name="contact[boat-question]" value="no" data-target="">
                        <label for="boat-n">{{ section.settings.app-boat-q-negative-label }}</label>
                    </div>
                </div>
            </div>
            <!-- Buy question -->
            <div class="body-regular text-[16px] leading-[22px] flex flex-col gap-4">
                <div class="flex">
                    {{ section.settings.app-buy-q-label }}{% if section.settings.app-buy-q-required == true %}*{% endif
                    %}
                </div>
                <div class="flex flex-col gap-2">
                    <div class="flex gap-2 justify-start items-center">
                        <input type="radio"
                            class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                            id="buy-y" name="contact[buy-question]" value="y" data-target="y">
                        <label for="buy-y"> {{ section.settings.app-buy-q-affermative-label }}</label>
                    </div>
                    <div class="flex gap-2 justify-start items-center">
                        <input type="radio"
                            class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                            id="buy-n" name="contact[buy-question]" value="no" data-target="no">
                        <label for="buy-y"> {{ section.settings.app-buy-q-negative-label }}</label>
                    </div>
                </div>
            </div>
            <!-- Boat selection -->
            <div class="body-regular text-[16px] leading-[22px] flex flex-col gap-4">
                <div class="flex">
                    {{ section.settings.app-boat-sel-label }}{% if section.settings.app-boat-sel-required == true %}*{%
                    endif %}
                </div>
                {% assign options = section.settings.options | split: ',' %}
                <div class="flex flex-wrap gap-2" data-name="contact[boat-selection]">
                    {% for option in options %}
                    {% assign clean_option = option | strip %}
                    <label
                        class="flex gap-1 py-1.5 px-3 bg-[#f8f8f8] border-1 border-white cursor-pointer relative text-white transition-all body-regular text-[16px] leading-[22px] bg-antracite rounded-4xl">
                        <input type="checkbox" class="multi-checkbox" value="{{ clean_option }}" hidden>
                        {{ clean_option }}
                        <span class=" hidden cursor-pointer">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="size-5 text-black">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                            </svg>
                        </span>
                    </label>
                    {% endfor %}
                </div>

                <!-- Campo nascosto per raccogliere le selezioni -->
                <input type="hidden" name="contact[boat-selection]" id="app-form-boat-selection" {% if
                    section.settings.app-boat-sel-required %} required {% endif %}>
            </div>

            <!-- message -->
            <div
                class="body-regular text-[16px] leading-[22px] flex flex-col gap-4 border-b-1 border-white textarea-wrapper">
                <div class="flex">
                    {{ section.settings.app-message-label }}{% if section.settings.app-message-required == true %}*{%
                    endif %}
                </div>
                <textarea id="app-form-message" class="overflow-y-hidden resize-none min-h-[20px]" name="contact[message]"
                    placeholder="{{ section.settings.app-message-placeholder }}" {% if
                    section.settings.app-message-required==true %} required {% endif %}
                    maxlength="{{ section.settings.app-message-max-lenght | default: 250 }}"></textarea>
                <div class="char-counter flex justify-end" id="app-message-counter">0 / {{
                    section.settings.app-message-max-lenght | default: 250 }}</div>
            </div>

            <!-- contact question -->
            <div class="body-regular text-[16px] leading-[22px] flex flex-col gap-4">
                <div class="flex">
                    {{ section.settings.app-contact-q-label }}{% if section.settings.app-contact-q-required == true
                    %}*{% endif %}
                </div>
                <div class="flex flex-col gap-2">
                    <div class="flex gap-2 justify-start items-center">
                        <input type="radio"
                            class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                            id="contact-mail" name="contact[contact-question]" value="mail" data-target="mail">
                        <label for="contact-mail"> {{ section.settings.app-contact-q-mail-label }}</label>
                    </div>

                    <!-- Opzione Telefono e relativi campi -->
                    <div>
                        <div class="flex gap-2 justify-start items-center">
                            <input type="radio"
                                class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                id="contact-phone" name="contact[contact-question]" value="phone" data-target="phone">
                            <label for="contact-phone"> {{ section.settings.app-contact-q-phone-label }}</label>
                        </div>
                        <div id="phone-fields-phone" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                            <!-- Prefisso telefonico -->
                            <div class="flex flex-col gap-1 w-full md:w-[67px]">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-contact-q-prefix-label }}</div>
                                <input
                                    class="input-field body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pb-2"
                                    type="text" id="phone-prefix-phone" name="contact[phone-prefix-phone]"
                                    placeholder="{{ section.settings.app-form-contact-q-prefix-placeholder }}">
                            </div>
                            <!-- Numero di telefono -->
                            <div class="flex flex-col gap-1 w-full relative">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-contact-q-phone-label }}</div>
                                <input
                                    class="input-field body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pb-2"
                                    type="tel" id="phone-number-phone" name="contact[phone-number-phone]"
                                    placeholder="{{ section.settings.app-form-contact-q-phone-placeholder }}">
                            </div>
                        </div>
                    </div>

                    <!-- Opzione Entrambi e relativi campi -->
                    <div>
                        <div class="flex gap-2 justify-start items-center">
                            <input type="radio"
                                class="size-5 rounded-full appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                                id="contact-both" name="contact[contact-question]" value="both" data-target="both">
                            <label for="contact-both"> {{ section.settings.app-contact-q-both-label }}</label>
                        </div>
                        <div id="phone-fields-both" class="hidden flex flex-col md:flex-row gap-6 my-4 w-full">
                            <!-- Prefisso telefonico -->
                            <div class="flex flex-col gap-1 w-full md:w-[67px]">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-contact-q-prefix-label }}</div>
                                <input
                                    class="input-field body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pb-2"
                                    type="text" id="phone-prefix-both" name="contact[phone-prefix-both]"
                                    placeholder="{{ section.settings.app-form-contact-q-prefix-placeholder }}">
                            </div>
                            <!-- Numero di telefono -->
                            <div class="flex flex-col gap-1 w-full relative">
                                <div class="flex body-regular text-[12px] leading-[18px]">{{ section.settings.app-form-contact-q-phone-label }}</div>
                                <input
                                    class="input-field body-regular text-white text-[16px] leading-[22px] border-b-1 border-white pb-2"
                                    type="tel" id="phone-number-both" name="contact[phone-number-both]"
                                    placeholder="{{ section.settings.app-form-contact-q-phone-placeholder }}">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Consensi -->
        <div class="flex flex-col gap-6 text-[18px]">
            <div class="flex items-center h-auto gap-4">
                <input style="aspect-ratio:1/1" type="checkbox"
                    class="w-6 h-6 rounded-sm appearance-none border-1 border-white bg-transparent checked:bg-white transition-all duration-200"
                    id="app-form-marketingConsent">
                <label class="w-auto" id="app-form-profilingLabel">
                    {{ section.settings.app-form-markConsLabel }}
                    <u><a id="app-form-shortMarketing">{{ section.settings.app-form-privacy-label | default: "Privacy
                            Policy"
                            }}</a></u>
                </label>
            </div>
            <div class="flex items-center h-auto gap-4">
                <input style="aspect-ratio:1/1" type="checkbox"
                    class="appearance-none w-6 h-6 rounded-sm border-1 border-white bg-transparent checked:bg-white transition-all duration-200 disabled:border-[#ACACAC]"
                    id="app-form-profilingConsent" disabled>
                <label class="text-white transition-colors duration-200" id="app-form-profilingLabel">
                    {{ section.settings.app-form-profConsLabel }}
                    <u><a id="app-form-shortProfiling">{{ section.settings.app-form-privacy-label | default: "Privacy
                            Policy"
                            }}</a></u>
                </label>
            </div>
        </div>

        <u><a href="{{ section.settings.appointment-privacy-url }}">{{ section.settings.app-form-privacy-label |
                default: "Privacy
                Policy" }}</a></u>

        <div class="flex body-medium justify-center tk-aktiv-grotesk">
            <button id="appointment-form-submit" aria-label="{{ section.settings.appointment-form-submit-button-text }}"
                type="submit" class="w-full px-7 py-3.5 rounded-4xl text-[16px] font-semibold w-[300px]"
                style="color:{{ section.settings.appointment-form-button-text-color }};background-color:{{ section.settings.appointment-form-button-background-color }};">
                {{ section.settings.appointment-form-submit-button-text }}
            </button>
        </div>

        <input type="hidden" name="contact[tags]" id="CustomerTags">
        <input type="hidden" name="contact[note]" id="CustomerNote">
        <input type="hidden" id="eventHandle" value="">
        <input type="hidden" id="eventTitle" value="">


    </div>
    {% endform %}

    <!-- Popup nascosto -->
    <!-- Overlay -->
    <div id="thankyou-popup" class="fixed inset-0 flex items-center justify-center hidden">
        <div class="flex flex-col w-full max-w-[720px] h-fit items-center justify-center bg-[#292929] text-white px-14 py-10 gap-10 rounded-xl">
            <div class="flex flex-row justify-between w-full">
                <div class="flex size-6"></div>
                <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">
                    {{ section.settings.app-form-ty-title }}
                </h6>
                <button id="app-form-ty-close" aria-label="Chiudi">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path fill-rule="evenodd" clip-rule="evenodd"
                            d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                            fill="white" />
                    </svg>
                </button>
            </div>
            <div class="text-center">
                {{ section.settings.app-form-ty-text }}
            </div>
            <div>
                <button class="w-full lg:w-[234px] py-3.5 px-7 body-semibold text-[16px] leading-[14px] bg-white text-black rounded-4xl" id="app-form-ty-close-btn">
                    {{ section.settings.app-form-ty-btn-label }}
                </button>
            </div>
        </div>
    </div>
</div>

<div id="app-form-marketing-overlay"
    class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
    <div
        class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
        <div class="flex flex-row justify-between">
            <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.app-form-marketing-title }}
            </h6>
            <button id="app-form-marketing-close" aria-label="Chiudi">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
                        fill="white" />
                </svg>
            </button>
        </div>
        <div>
            {{ section.settings.app-form-marketing-text }} <u><a href="{{ section.settings.app-form-privacy-page }}">{{
                    section.settings.app-form-privacy-label | default:
                    "Privacy Policy" }}</a></u>
        </div>
    </div>
</div>

<div id="app-form-profiling-overlay"
    class="fixed top-0 left-0 flex justify-center items-end lg:items-center w-full h-full bg-black/70 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ">
    <div
        class="flex flex-col max-h-[80vh] overflow-y-auto md:overflow-visible bg-[#292929] text-white px-10 py-8 w-xl gap-10 rounded-xl">
        <div class="flex justify-between">
            <h6 class="tk-aktiv-grotesk h6 text-[20px] body-medium">{{ section.settings.app-form-profiling-title }}
            </h6>
            <button id="app-form-profiling-close" aria-label="Chiudi">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M4.14645 19.1464C3.95118 19.3417 3.95118 19.6583 4.14645 19.8536C4.34171 20.0488 4.65829 20.0488 4.85355 19.8536L12 12.7071L19.1464 19.8536C19.3417 20.0488 19.6583 20.0488 19.8536 19.8536C20.0488 19.6583 20.0488 19.3417 19.8536 19.1464L12.7071 12L19.8536 4.85355C20.0488 4.65829 20.0488 4.34171 19.8536 4.14645C19.6583 3.95118 19.3417 3.95118 19.1464 4.14645L12 11.2929L4.85355 4.14645C4.65829 3.95118 4.34171 3.95118 4.14645 4.14645C3.95118 4.34171 3.95118 4.65829 4.14645 4.85355L11.2929 12L4.14645 19.1464Z"
