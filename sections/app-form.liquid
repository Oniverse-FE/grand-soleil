<style>
    .no-scroll {
        overflow: hidden;
        width: 100%;
        position: fixed;
    }

    #appointment-form-box::-webkit-scrollbar,
    #countryList::-webkit-scrollbar,
    #dateList::-webkit-scrollbar {
        display: none;
    }

    #appointment-form-box,
    #countryList,
    #dateList {
        -ms-overflow-style: none;
        /* IE e Edge vecchi */
        scrollbar-width: none;
        /* Firefox */
    }

    #appointment-form-box input[type="text"]:focus,
    #appointment-form-box input[type="email"]:focus,
    #appointment-form-box input[type="tel"]:focus {
        outline: none;
        /* niente bordo blu default */
        border-bottom: 1px solid #F76C00;
        /* bordo arancione al focus */
    }

    #appointment-form-box .textarea-wrapper:focus-within {
        border-bottom: 1px solid #F76C00;
    }

    #appointment-form-box textarea:focus {
        outline: none;
        /* rimuove il bordo blu default */
