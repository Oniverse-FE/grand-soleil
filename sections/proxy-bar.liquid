<div class="w-full h-auto flex items-center justify-center fixed z-40 left-0 bottom-0 right-0 proxy-bar_gs proxy-bar_gsp py-3 md:py-4 px-4 md:px-[64px]">
  <div class="flex flex-row w-full h-[42px] lg:h-[56px]">
    
    <div class="arrow-icon flex md:hidden w-[158px] flex-row items-center gap-10 badge-overlay cursor-pointer cta-border-light_gs cta-border-dark_gsp py-1 px-4">
      <p class="body-sm_gs body-sm_gsp">
        {{ section.settings.cta_text | default: "Overview" }}
      </p>
      <div class="arrow-wrapper bg-blue_gs bg-truffle_gsp py-2 pl-4 pr-2 rounded-full transition-transform duration-300">
        {% if template contains 'gsp' %}{% render 'gs-arrow-bottom-white' %}{% else %}{% render 'gs-arrow-bottom-black' %}{% endif %}
      </div>
    </div>

    <div class="flex w-full justify-end md:justify-between items-center">
      <ul class="desktop-menu flex w-[76vw] flex-row items-center ">
        <li><a href="#{{ section.settings.id_item_1 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp">{{ section.settings.item_1 | default: "Design" }}</a></li>
        <li><a href="#{{ section.settings.id_item_2 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp">{{ section.settings.item_2 | default: "Top view" }}</a></li>
        <li><a href="#{{ section.settings.id_item_3 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp">{{ section.settings.item_3 | default: "Technical feature" }}</a></li>
        <li><a href="#{{ section.settings.id_item_4 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp">{{ section.settings.item_4 | default: "General Arrangement" }}</a></li>
        <li><a href="#{{ section.settings.id_item_5 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp">{{ section.settings.item_5 | default: "Gallery" }}</a></li>
      </ul>
      <a class="link-lg_gs link-lg_gsp cta-proxybar_gs cta-proxybar_gsp px-6 py-3 md:py-4 w-[158px] flex justify-center items-center px-3 lg:px-4" href="{{ section.settings.find_dealer_link }}">
        {{ section.settings.find_dealer | default: "Find a dealer" }}
      </a>
    </div>
  </div>
</div>

<div class="fixed inset-x-0 bottom-[75px] z-0 flex justify-start pointer-events-none lg:hidden">
  <div class="container-ancor-links pointer-events-auto w-full mx-4 h-auto flex flex-col items-start justify-start border-proxybar_gs border-proxybar_gsp px-4 py-6 proxy-bar_gs proxy-bar_gsp gap-y-6 transform translate-y-full opacity-0 transition-all duration-300 ease-in-out">
    <ul class="w-full flex flex-col items-start justify-start gap-y-6">
      <a href="#{{ section.settings.id_item_1 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp"> {{ section.settings.item_1 | default: "Design" }} </a>
      <a href="#{{ section.settings.id_item_2 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp"> {{ section.settings.item_2 | default: "Top view" }} </a>
      <a href="#{{ section.settings.id_item_3 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp"> {{ section.settings.item_3 | default: "Technical feature" }} </a>
      <a href="#{{ section.settings.id_item_4 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp"> {{ section.settings.item_4 | default: "General Arrangement" }} </a>
      <a href="#{{ section.settings.id_item_5 }}" class="px-3 body-md_gs body-md_gsp text-color_gs text-color_gsp"> {{ section.settings.item_5 | default: "Gallery" }} </a>
    </ul>
  </div>
</div>

<style>
/* Animazione rotazione freccia tramite classe attiva */
.badge-overlay.is-active .arrow-wrapper {
  transform: rotate(180deg);
}

.cta-box-gradient { position: relative; overflow: hidden; }
.cta-box-gradient.dealer { background-color: #423C3B; transition: background-color 0.8s ease-in-out; }
.cta-box-gradient.pardo { background-color: #262322; transition: background-color 0.8s ease-in-out; }
.cta-box-gradient::before {
  content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 200%;
  background: linear-gradient(180deg, transparent 0%, rgba(66,60,59,0.3) 50%, rgba(38,35,34,0.7) 100%);
  opacity: 0; transition: top 0.8s ease-in-out, opacity 0.8s ease-in-out; z-index: 0;
}
.cta-box-gradient a { position: relative; z-index: 999; }
.cta-box-gradient.pardo::before { background: linear-gradient(180deg, transparent 0%, rgba(38,35,34,0.3) 50%, rgba(66,60,59,0.7) 100%); }
.cta-box-gradient:hover::before { top: 0; opacity: 1; }
.cta-box-gradient.dealer:hover { background-color: #262322; }
.cta-box-gradient.pardo:hover { background-color: #423C3B; }

/* Pallino desktop */
@media (min-width: 1024px) {
  ul.desktop-menu li { position: relative; }
  ul.desktop-menu li::after {
    content: ''; position: absolute; bottom: -3px; left: 50%; transform: translateX(-50%);
    width: 4px; height: 4px; background-color: white; border-radius: 50%; opacity: 0; transition: opacity 0.3s ease;
  }
  ul.desktop-menu li:hover::after, ul.desktop-menu li.active::after { opacity: 1; }
}

@media (max-width: 1024px) { .desktop-menu { display: none; } }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const containerLinks = document.querySelector('.container-ancor-links');
  const badgeOverlay = document.querySelector('.badge-overlay');
  const desktopLinks = document.querySelectorAll('ul.desktop-menu li');
  const allAnchorLinks = document.querySelectorAll('.desktop-menu a, .container-ancor-links a');

  // Funzione scroll con offset
  const scrollToSection = (targetId) => {
    const targetElement = document.getElementById(targetId);
    if (targetElement) {
      const offset = window.innerWidth >= 1024 ? 40 : 80;
      const elementPosition = targetElement.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({
        top: elementPosition - offset,
        behavior: 'smooth'
      });
    }
  };

  // Toggle menu mobile migliorato
  const toggleMenu = () => {
    const isOpened = containerLinks.classList.contains('translate-y-0');
    
    if (isOpened) {
      // Chiudi
      containerLinks.classList.replace('translate-y-0', 'translate-y-full');
      containerLinks.classList.replace('opacity-100', 'opacity-0');
      badgeOverlay.classList.remove('is-active'); // Toglie rotazione
    } else {
      // Apri
      containerLinks.classList.replace('translate-y-full', 'translate-y-0');
      containerLinks.classList.replace('opacity-0', 'opacity-100');
      badgeOverlay.classList.add('is-active'); // Attiva rotazione
    }
  };

  if (badgeOverlay) {
    // Ora l'intero blocco risponde al click
    badgeOverlay.addEventListener('click', (e) => {
      e.preventDefault();
      toggleMenu();
    });
  }

  // Gestione click link
  allAnchorLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        const targetId = href.substring(1);
        scrollToSection(targetId);

        if (containerLinks.classList.contains('translate-y-0')) {
          toggleMenu();
        }
      }
    });
  });

  // Pallino attivo desktop
  desktopLinks.forEach(li => {
    li.addEventListener('click', () => {
      desktopLinks.forEach(l => l.classList.remove('active'));
      li.classList.add('active');
    });
  });
});
</script>

