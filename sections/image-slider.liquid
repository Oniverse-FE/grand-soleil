<div id="{{ section.settings.id }}" class="section-container-{{ section.id }} bg_gs bg_gsp relative flex flex-col {% if section.settings.image-slider-title != blank %} gap-4 lg:gap-6 {% endif %}">
  
  {% if section.settings.image-slider-title != blank %}
    <div class="flex flex-row relative w-full justify-between px-4 md:px-12 lg:px-24">
      <div class="flex h6 justify-start heading-sm_gs heading-sm_gsp md:heading-md_gs md:heading-md_gsp text-color_gs text-color_gsp">
        {{ section.settings.image-slider-title }}
      </div>
    </div>
  {% endif %}
  
  <div id="scroll-container-{{ section.id }}" 
       class="slider-container-{{ section.id }} flex flex-nowrap overflow-x-auto overflow-y-hidden gap-2 lg:gap-4 cursor-grab scrollbar-hide w-full max-w-full">
       
    {% for block in section.blocks %}
      <div class="slider-item-{{ section.id }} relative">
        <img src="{{ block.settings.image-slider-image | img_url: 'master' }}"
             alt="{{ block.settings.image-slider-image-alt }}"
             data-title="{{ block.settings.image-slider-image-title }}"
             class="w-image-el pointer-events-none">
             
        {% if block.settings.image-slider-overlay %}
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);"></div>
        {% endif %}
        
        {% if block.settings.image-slider-image-title != blank %}
          <div class="flex absolute bottom-4 left-6 lg:left-8 heading-sm_gs heading-sm_gsp text-color_gs text-EBEFF2_gsp">
            {{ block.settings.image-slider-image-title }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <div class="flex flex-row justify-between items-center px-4 md:px-12 lg:px-24 mt-6 lg:mt-10">
      <div class="body-sm_gs body-sm_gsp md:body-md_gs md:body-md_gsp text-color_gs text-color_gsp">
          <span id="current-slide-{{ section.id }}">01</span>
          <span class="mx-2">-</span>
          <span id="total-slides-{{ section.id }}">0{{ section.blocks.size }}</span>
      </div>

      <div class="flex gap-2 lg:gap-4">
          <button class="prev-{{ section.id }} pt-3 flex justify-center items-center transition">
              {% if template contains 'gsp' %}{% render 'gs-arrow-left-black' %}{% else %}{% render 'gs-arrow-left-white' %}{% endif %}
          </button>
          <button class="next-{{ section.id }} pb-3 flex justify-center items-center transition">
              {% if template contains 'gsp' %}{% render 'gs-arrow-right-black' %}{% else %}{% render 'gs-arrow-right-white' %}{% endif %}
          </button>
      </div>
  </div>
</div>

<style>
  .section-container-{{ section.id }} {
    padding-top: {{ section.settings.pt_mobile }}px;
    padding-bottom: {{ section.settings.pb_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-container-{{ section.id }} {
      padding-top: {{ section.settings.pt_tablet }}px;
      padding-bottom: {{ section.settings.pb_tablet }}px;
    }
  }

  @media screen and (min-width: 1024px) {
    .section-container-{{ section.id }} {
      padding-top: {{ section.settings.pt_desktop }}px;
      padding-bottom: {{ section.settings.pb_desktop }}px;
    }
  }

  .slider-container-{{ section.id }} {
      scroll-snap-type: x mandatory;
      user-select: none;
      display: flex;
  }

  .slider-item-{{ section.id }} {
      flex: 0 0 auto;
      width: {{ section.settings.width-mobile }};
      aspect-ratio: 4 / 5;
      scroll-snap-align: start;
      position: relative;
      border-radius: 16px;
      overflow: hidden;
  }

  .w-image-el {
      width: 100%;
      height: 100%;
      object-fit: cover;
  }

  .slider-container-{{ section.id }}::before,
  .slider-container-{{ section.id }}::after {
      content: "";
      flex: 0 0 auto;
  }
  .slider-container-{{ section.id }}::before { width: 16px; }
  .slider-container-{{ section.id }}::after { width: 16px; }

  @media (min-width: 1024px) {
      .slider-item-{{ section.id }} {
          width: {{ section.settings.width-desktop }};
          aspect-ratio: 4 / 3;
      }
      .slider-container-{{ section.id }}::before { width: 64px; }
      .slider-container-{{ section.id }}::after { width: 64px; }
  }

  .arrow-disabled {
    opacity: 0.2;
    pointer-events: none;
    cursor: default;
  }

  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  #lightbox-{{ section.id }}.visible { display: flex; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('scroll-container-{{ section.id }}');
    if (!slider) return;

    const images = Array.from(slider.querySelectorAll('img'));
    const currentNumEl = document.getElementById('current-slide-{{ section.id }}');
    const prevBtn = document.querySelector('.prev-{{ section.id }}');
    const nextBtn = document.querySelector('.next-{{ section.id }}');

    const formatNum = (num) => num.toString().padStart(2, '0');
    const getGap = () => window.innerWidth >= 1024 ? 16 : 8; 

    const updateSliderUI = () => {
        const scrollLeft = slider.scrollLeft;
        const maxScrollLeft = slider.scrollWidth - slider.clientWidth;
        const firstItem = slider.querySelector('.slider-item-{{ section.id }}');
        
        if (!firstItem) return;

        // 1. Aggiorna Contatore
        const index = Math.round(scrollLeft / (firstItem.offsetWidth + getGap()));
        currentNumEl.textContent = formatNum(Math.max(0, Math.min(index, images.length - 1)) + 1);

        // 2. Gestione Stato Frecce (Disabilita all'inizio e alla fine)
        // Usiamo un margine di tolleranza di 5px per evitare problemi con arrotondamenti browser
        if (scrollLeft <= 5) {
            prevBtn.classList.add('arrow-disabled');
        } else {
            prevBtn.classList.remove('arrow-disabled');
        }

        if (scrollLeft >= maxScrollLeft - 5) {
            nextBtn.classList.add('arrow-disabled');
        } else {
            nextBtn.classList.remove('arrow-disabled');
        }
    };

    // Inizializza lo stato al caricamento
    updateSliderUI();

    slider.addEventListener('scroll', updateSliderUI);

    nextBtn.addEventListener('click', () => {
        const firstItem = slider.querySelector('.slider-item-{{ section.id }}');
        slider.scrollBy({ left: firstItem.offsetWidth + getGap(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
        const firstItem = slider.querySelector('.slider-item-{{ section.id }}');
        slider.scrollBy({ left: -(firstItem.offsetWidth + getGap()), behavior: 'smooth' });
    });

    // Drag to scroll
    let isDown = false, startX, scrollLeft;
    slider.addEventListener('mousedown', (e) => {
        isDown = true;
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
    });
    slider.addEventListener('mouseleave', () => isDown = false);
    slider.addEventListener('mouseup', () => isDown = false);
    slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
    });
});
</script>

{% schema %}
{
  "name": "Slider",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "id", "label": "Id section", "default": "slider" },
    { "type": "text", "id": "image-slider-title", "label": "Title (optional)" },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "pt_mobile", "label": "Top Mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "pt_tablet", "label": "Top Tablet", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "pt_desktop", "label": "Top Desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Mobile", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "pb_tablet", "label": "Bottom Tablet", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Desktop", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "header", "content": "Widths" },
    {
      "type": "select",
      "id": "width-desktop",
      "label": "Width desktop",
      "options": [
        { "value": "511px", "label": "Small" },
        { "value": "932px", "label": "Big" }
      ],
      "default": "932px"
    },
    {
      "type": "select",
      "id": "width-mobile",
      "label": "Width mobile",
      "options": [
        { "value": "327px", "label": "Small" },
        { "value": "100%", "label": "Full Width" }
      ],
      "default": "327px"
    }
  ],
  "blocks": [
    {
      "type": "image-slider-image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image-slider-image", "label": "Image" },
        { "type": "text", "id": "image-slider-image-alt", "label": "Alt text" },
        { "type": "text", "id": "image-slider-image-title", "label": "Title" },
        { "type": "checkbox", "id": "image-slider-overlay", "label": "Overlay Gradient", "default": false }
      ]
    }
  ],
  "presets": [ { "name": "Slider", "category": "Media Sections" } ]
}
{% endschema %}