<div class="flex px-4 md:px-12 lg:px-24 pt-6 lg:pt-10">
    {% assign current_path = request.path %}
    {% assign selected_label = '' %}
    {% assign menu_links = linklists.vandutch-center.links %}
    {% assign dropdown_id = 'dropdown-menu-' | append: section.id %}
    {% assign button_id = 'menu-button-' | append: section.id %}

    {% for link in menu_links %}
        {% if link.url == current_path or link.url == request.url %}
            {% assign selected_label = link.title %}
        {% endif %}
    {% endfor %}

    <div class="relative inline-block text-left">
        <!-- Bottone selezionato -->
        <button type="button" 
                class="inline-flex gap-4 justify-between w-auto rounded-md text-white text-sm font-medium focus:outline-none transition-colors duration-200 px-6 py-3 lg:px-6 lg:py-3" 
                id="{{ button_id }}" 
                aria-expanded="false" 
                aria-haspopup="true">
            <div class="text-[16px] lg:text-[18px] text-white">
                {{ selected_label }}
            </div>
            <svg class="h-6 w-6 transition-transform duration-200 text-white" 
                 xmlns="http://www.w3.org/2000/svg" 
                 viewBox="0 0 24 24" 
                 fill="none" 
                 stroke="currentColor" 
                 stroke-width="1" 
                 stroke-linecap="round" 
                 stroke-linejoin="round"
                 id="{{ button_id }}-icon">
                <path d="M4 8L10.5858 14.5858C11.3668 15.3668 12.6332 15.3668 13.4142 14.5858L20 8" />
            </svg>
        </button>

        <!-- Dropdown panel -->
        <div class="origin-top-left absolute mt-2 hidden z-20 w-full" id="{{ dropdown_id }}">
            <div class="bg-antracite rounded-md flex flex-col gap-6 p-6 min-w-full text-white" 
                 role="menu" 
                 aria-orientation="vertical" 
                 aria-labelledby="{{ button_id }}">
                {% for link in menu_links %}
                    {% unless link.url == current_path or link.url == request.url %}
                        <a href="{{ link.url }}" 
                           class="block text-[16px] lg:text-[18px] text-white hover:bg-ebony" 
                           role="menuitem">
                            {{ link.title }}
                        </a>
                    {% endunless %}
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const button = document.getElementById("{{ button_id }}");
    const dropdown = document.getElementById("{{ dropdown_id }}");
    const icon = document.getElementById("{{ button_id }}-icon");

    if (button && dropdown && icon) {
        button.addEventListener("click", () => {
            const isHidden = dropdown.classList.toggle("hidden");
            button.setAttribute("aria-expanded", !isHidden);

            if (!isHidden) {
                button.classList.add("bg-antracite");
                icon.classList.add("rotate-180");
            } else {
                button.classList.remove("bg-antracite");
                icon.classList.remove("rotate-180");
            }
        });

        document.addEventListener("click", (e) => {
            if (!button.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add("hidden");
                button.classList.remove("bg-antracite");
                icon.classList.remove("rotate-180");
                button.setAttribute("aria-expanded", false);
            }
        });
    }
});
</script>

{% schema %}
{
    "name": "VD Center Selector",
    "settings": [],
    "presets": [
        {
            "name": "VD Center Selector",
            "category": "VD Centers Sections"
        }
    ]
}
{% endschema %}