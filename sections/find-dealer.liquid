{%- liquid
  # Mappatura allineamento testo
  assign text_align = section.settings.fd-content_alignment
  
  # Mappatura allineamento flex per i contenitori
  assign flex_align = 'items-start'
  if text_align == 'center'
    assign flex_align = 'items-center'
  elsif text_align == 'right'
    assign flex_align = 'items-end'
  endif
-%}

<div class="bg-white_gs bg-truffle_gsp gap-text flex flex-col py-8 md:py-[96px] px-4 md:px-8 lg:px-[64px] {{ text_align | prepend: 'text-' }}">
    
    <div class="flex flex-col gap-4 md:gap-6 {{ flex_align }}">
        <div class="heading-lg_gs heading-lg_gsp text-05090D_gs text-FAF9F7_gsp">
            {{ section.settings.fd-title }}
        </div>
        
        {%- if section.settings.fd-text1 != blank -%}
            <div class="md:w-[466px] lg:w-[828px] body-lg_gs body-lg_gsp text-05090D_gs text-FAF9F7_gsp">
                {{ section.settings.fd-text1 | newline_to_br }}
            </div>
        {%- endif -%}
    </div>

    <div class="flex flex-row md:flex-col gap-4 mt-8 md:mt-[48px]">
        <div class="flex flex-wrap w-full gap-4 justify-{{ section.settings.fd-cta_position }}">
            {% if section.settings.fd-cta_link != blank %}
              <a id="cta-1-{{ section.id }}"
                  href="{{ section.settings.fd-cta_link }}"
                  class="cta-button w-full text-center lg:w-fit px-7 py-3.5 link-lg_gs link-lg_gsp cta-white_gsp cta-101C26_gs transition-all duration-300">
                {{ section.settings.fd-cta_label }}
              </a>
            {% endif %}
            
            {% if section.settings.fd-cta_link2 != blank %}
              <a id="cta-2-{{ section.id }}"
                  href="{{ section.settings.fd-cta_link2 }}"
                  class="cta-button w-full text-center lg:w-fit px-6 py-4 link-lg_gs link-lg_gsp cta-border-light_gsp cta-border-dark_gs transition-all duration-300">
                {{ section.settings.fd-cta_label2 }}
              </a>
            {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Find a dealer",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "select",
      "id": "fd-content_alignment",
      "label": "Content alignment",
      "options": [
        { "label": "Left", "value": "left" },
        { "label": "Center", "value": "center" },
        { "label": "Right", "value": "right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "fd-cta_position",
      "label": "CTA position",
      "options": [
        { "label": "Left", "value": "start" },
        { "label": "Center", "value": "center" },
        { "label": "Right", "value": "end" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "fd-title",
      "label": "Title",
      "default": "Find a dealer"
    },
    {
      "type": "textarea",
      "id": "fd-text1",
      "label": "First text area"
    },
    {
      "type": "header",
      "content": "CTA Buttons"
    },
    {
      "type": "text",
      "id": "fd-cta_label",
      "label": "Button 1 label"
    },
    {
      "type": "url",
      "id": "fd-cta_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "fd-cta_label2",
      "label": "Button 2 label"
    },
    {
      "type": "url",
      "id": "fd-cta_link2",
      "label": "Button 2 link"
    }
  ],
  "presets": [
    {
      "name": "Find a dealer",
      "category": "Common sections"
    }
  ]
}
{% endschema %}