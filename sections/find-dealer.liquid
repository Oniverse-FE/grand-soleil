{%- liquid
  # Mappatura allineamento testo responsive
  assign align_mobile = section.settings.fd-content_alignment_mobile
  assign align_desktop = section.settings.fd-content_alignment
  assign text_classes = 'text-' | append: align_mobile | append: ' md:text-' | append: align_desktop

  # Mappatura allineamento flex per i contenitori (Mobile)
  case align_mobile
    when 'left'
      assign flex_mobile = 'items-start'
    when 'center'
      assign flex_mobile = 'items-center'
    when 'right'
      assign flex_mobile = 'items-end'
  endcase

  # Mappatura allineamento flex per i contenitori (Desktop)
  case align_desktop
    when 'left'
      assign flex_desktop = 'md:items-start'
    when 'center'
      assign flex_desktop = 'md:items-center'
    when 'right'
      assign flex_desktop = 'md:items-end'
  endcase

  assign flex_classes = flex_mobile | append: ' ' | append: flex_desktop
-%}

<div class="bg-white_gs bg-truffle_gsp flex flex-col py-8 md:py-[96px] px-4 md:px-8 lg:px-[64px] {{ text_classes }}">
    
    <div class="flex flex-col gap-4 md:gap-6 {{ flex_classes }}">
        <div class="w-full heading-md_gs heading-md_gsp md:heading-lg_gs md:heading-lg_gsp text-05090D_gs text-FAF9F7_gsp">
            {{ section.settings.fd-title }}
        </div>
        
        {%- if section.settings.fd-text1 != blank -%}
            <div class="w-full md:max-w-[466px] lg:max-w-[828px] body-md_gs body-md_gsp md:body-lg_gs md:body-lg_gsp text-05090D_gs text-FAF9F7_gsp">
                {{ section.settings.fd-text1 | newline_to_br }}
            </div>
        {%- endif -%}
    </div>

    <div class="flex flex-col gap-4 mt-8 md:mt-[48px]">
        <div class="flex flex-wrap w-full gap-4 justify-{{ section.settings.fd-cta_position }}">
            {% if section.settings.fd-cta_link != blank %}
              <a id="cta-1-{{ section.id }}"
                  href="{{ section.settings.fd-cta_link }}"
                  class="cta-button w-full text-center lg:w-fit px-7 py-3.5 link-lg_gs link-lg_gsp cta-white_gsp cta-101C26_gs transition-all duration-300">
                {{ section.settings.fd-cta_label }}
              </a>
            {% endif %}
            
            {% if section.settings.fd-cta_label2 != blank %}
              <button id="openModalInfo"
                  class="cta-button w-full text-center lg:w-fit px-6 py-4 link-lg_gs link-lg_gsp cta-border-light_gsp cta-border-dark_gs transition-all duration-300">
                {{ section.settings.fd-cta_label2 }}
              </button>
            {% endif %}
        </div>
    </div>
</div>

