<div class="bg_gs bg_gsp flex flex-col px-4 md:px-12 lg:px-[128px] py-8 md:py-20 lg:py-[96px]">
    <!-- title -->
    <div class="heading-lg_gs heading-lg_gsp text-color_gs text-color_gsp text-center pb-8 lg:pb-[56px]">
        {{ section.settings.event-slider-title }}
    </div>

    <!-- slider -->
    <div class="flex flex-col w-full justify-center items-start gap-6 lg:gap-8 bg-dark_gs bg-beige_gsp text-color_gs text-color_gsp p-4 md:p-8 lg:p-10">
        {% assign now_timestamp = 'now' | date: '%s' %}
        {% for article in blogs['events'].articles %}
            {% assign end_date_str = article.metafields.custom.event_end_date %}
            {% if end_date_str != blank %}
                {% assign end_date_timestamp = end_date_str | date: '%s' %}
                {% if end_date_timestamp >= now_timestamp %}

                    <div class="flex flex-col lg:flex-row gap-4 xl:gap-10 w-full cursor-pointer"
                         onclick="window.location.href='{{ article.url }}'">

                        <!-- title + info + links + booking -->
                        <div class="flex flex-col md:flex-row items-start w-full justify-between">
                            <!-- title + info -->
                            <div class="flex flex-col gap-3 mb-10 md:mb-0">
                                <div class="flex heading-md_gs heading-md_gsp text-color_gs text-color_gsp">
                                    {{ article.title }}
                                </div>

                                <!-- info -->
                                <div class="flex flex-col gap-2">
                                    <!-- date -->
                                    <div class="flex flex-row gap-2 lg:gap-2.5">
                                        <div class="flex flex-row body-md_gs body-md_gsp text-color_gs text-color_gsp items-center justify-center">
                                            {%- assign start = article.metafields.custom.event_start_date | date: "%d" -%}
                                            {%- assign end = article.metafields.custom.event_end_date | date: "%d %B %Y" -%}
                                            {{ start }} - {{ end }}
                                        </div>
                                    </div>

                                    <!-- location -->
                                    <div class="flex flex-row gap-2 lg:gap-2.5">
                                        <div class="flex flex-row body-md_gs body-md_gsp text-color_gs text-color_gsp justify-center items-center">
                                            {{ article.metafields.custom.event_location }}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- CTA buttons -->
                            <div class="w-full flex flex-col gap-4 pb-6 lg:pb-0 lg:flex-row">
                                <!-- Discover More -->
                                <div class="flex w-full">
                                    <a href="{{ article.url }}" class="w-full text-center link-lg-gs link-lg_gsp cta-blue_gs cta-truffle_gsp py-4 px-6"> {{ section.settings.event-slider-cta2-label }}</a>
                                </div>
                            </div>
                        </div>
                    </div>

                {% endif %}
            {% endif %}
        {% endfor %}
    </div>
</div>

