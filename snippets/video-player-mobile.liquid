<div class="flex lg:hidden w-screen h-screen justify-center items-center relative video-section">

    <!-- Video element -->
    {% if video_mobile != blank and video_mobile.sources != blank %}
    <video data-video class="w-full h-full object-cover hero-video-mobile" autoplay loop muted playsinline>
        <source src="{{ video_mobile.sources[0].url }}" type="application/x-mpegURL">
    </video>
    {% else %}
    <div class="text-red-500 z-40">⚠️ Nessun video disponibile</div>
    {% endif %}

    <!-- Gradient overlay -->
    <div
        class="absolute bottom-0 left-0 w-full h-[100vh] pointer-events-none bg-gradient-to-b from-transparent via-[#10101080] to-[#101010] z-10">
    </div>

    <!-- Custom controls -->
    <div data-controls
        class="absolute bottom-8 left-4 right-4 w-auto px-4 py-2 flex gap-4 items-center z-20 bg-black text-white rounded-full transition-opacity duration-500 opacity-100">
        <input type="range" data-seek value="0" class="flex-grow h-1">
        <button data-mute>{% render 'volume-off' %}</button>
        <!-- <button data-fullscreen>{% render 'fullscreen' %}</button> -->
    </div>

    <!-- Central play/pause/skip buttons -->
    <div data-central
        class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-20 flex items-center gap-6 transition-opacity duration-500 opacity-100">
        <button data-back>{% render 'back-15s' %}</button>
        <button data-play>{% render 'pause' %}</button>
        <button data-forward>{% render 'forward-15s' %}</button>
    </div>
</div>

<style>
[data-seek] {
    -webkit-appearance: none;
    width: 100%;
    height: 4px;
    background: transparent;
    border-radius: 2px;
    outline: none;
}
[data-seek]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    background: transparent;
    border-radius: 50%;
    cursor: pointer;
    margin-top: -5px;
    transition: transform 0.1s ease;
}
[data-seek]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
}
[data-seek]::-webkit-slider-runnable-track {
    height: 4px;
    background: linear-gradient(to right, #F76C00 0%, #F76C00 var(--seek, 0%), #444 var(--seek, 0%), #444 100%);
    border-radius: 2px;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".video-section").forEach(section => {

        // --- ELEMENTI ---
        const video = section.querySelector("[data-video]");
        const playBtn = section.querySelector("[data-play]");
        const muteBtn = section.querySelector("[data-mute]");
        const seekBar = section.querySelector("[data-seek]");
        const fullscreenBtn = section.querySelector("[data-fullscreen]");
        const backBtn = section.querySelector("[data-back]");
        const forwardBtn = section.querySelector("[data-forward]");
        const controls = section.querySelector("[data-controls]");
        const centralControls = section.querySelector("[data-central]");
        const hlsUrl = "{{ video_mobile.sources[0].url }}";

        let hideTimeout;
        let hlsInstance = null;

        // --- AVVIO VIDEO ---
        function startVideo() {
            if (!video) return;

            if (Hls.isSupported()) {
                hlsInstance = new Hls();
                hlsInstance.loadSource(hlsUrl);
                hlsInstance.attachMedia(video);
                hlsInstance.on(Hls.Events.MANIFEST_PARSED, () => {
                    tryAutoplay();
                });
            } else if (video.canPlayType('application/vnd.apple.mpegURL')) {
                video.src = hlsUrl;
                video.addEventListener("loadedmetadata", tryAutoplay);
            } else {
                console.warn("HLS non supportato in questo browser");
            }
        }

        function tryAutoplay() {
            video.play().catch(() => {
                console.log("Autoplay bloccato — serve interazione utente");
            });
        }

        startVideo();

        // --- SEEK BAR ---
        function updateSeekBar() {
            if (!isNaN(video.duration)) {
                const value = (100 / video.duration) * video.currentTime;
                seekBar.value = value;
                seekBar.style.setProperty('--seek', value + '%');
            }
            if (!video.paused && !video.ended) {
                requestAnimationFrame(updateSeekBar);
            }
        }

        video.addEventListener("play", () => requestAnimationFrame(updateSeekBar));

        // --- MOSTRA / NASCONDI CONTROLLI ---
        function showControls() {
            controls.style.opacity = "1";
            centralControls.style.opacity = "1";
            resetHideTimeout();
        }
        function hideControls() {
            controls.style.opacity = "0";
            centralControls.style.opacity = "0";
        }
        function resetHideTimeout() {
            clearTimeout(hideTimeout);
            hideTimeout = setTimeout(hideControls, 3000);
        }
        ["mousemove", "mousedown", "touchstart"].forEach(event => {
            section.addEventListener(event, showControls);
        });
        resetHideTimeout();

        // --- PLAY / PAUSA ---
        playBtn?.addEventListener("click", function () {
            if (video.paused) {
                video.play();
            } else {
                video.pause();
            }
        });

        video.addEventListener("play", () => {
            playBtn.innerHTML = `{% render 'pause' %}`;
        });
        video.addEventListener("pause", () => {
            playBtn.innerHTML = `{% render 'play-icon' %}`;
        });

        // --- MUTE / UNMUTE ---
        muteBtn?.addEventListener("click", function () {
            video.muted = !video.muted;
            muteBtn.innerHTML = video.muted
                ? `{% render 'volume-off' %}`
                : `{% render 'volume-up' %}`;
        });

        // --- SEEKING ---
        seekBar?.addEventListener("input", function () {
            if (!isNaN(video.duration)) {
                const time = video.duration * (seekBar.value / 100);
                video.currentTime = time;
            }
        });

        // --- FULLSCREEN ---
        fullscreenBtn?.addEventListener("click", () => {
            if (section.requestFullscreen) section.requestFullscreen();
            else if (section.webkitRequestFullscreen) section.webkitRequestFullscreen();
            else if (section.msRequestFullscreen) section.msRequestFullscreen();
        });

        // --- SKIP +/- 15s (dopo che il video è pronto) ---
        video.addEventListener("loadedmetadata", () => {
            console.log("Video pronto, durata:", video.duration);

            backBtn?.addEventListener("click", () => {
                if (isNaN(video.duration)) return;
                video.currentTime = Math.max(0, video.currentTime - 15);
            });

            forwardBtn?.addEventListener("click", () => {
                if (isNaN(video.duration)) return;
                video.currentTime = Math.min(video.duration, video.currentTime + 15);
            });
        });

    });
});
</script>
