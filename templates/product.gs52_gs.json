          }
        },
        "intro_text_area_YGnqPP": {
          "type": "intro-text-area",
          "settings": {
            "intro-text-area-title": "",
            "intro-text-area-text": "The “Performance” version provides an “easy sailing” deck and sail plan with 4 aft winches, mainsail sheet with fixed point, self-tacking jib (std.) and carbon bowsprit (std.). The cockpit is perfectly usable by guests, thanks to the choice of recessing all rigging."
          }
        }
