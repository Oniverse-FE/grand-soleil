            "cta_url": "#"
          }
        },
        "item_NLTGjM": {
          "type": "item",
          "settings": {
            "img_left": false,
            "image_desktop": "shopify://shop_images/0_3-HERO_1.png",
            "title": "Gamma long Cruise",
            "text": "\"Comfort Beyond Distance.\" È l'anima blue water, pensata per chi concepisce la barca come una vera e propria casa sul mare. Volumi generosi, autonomia impareggiabile, soluzioni di stivaggio intelligenti e un comfort assoluto definiscono questa gamma. L'eccellenza costruttiva e le doti marine garantiscono navigazioni sicure e confortevoli su qualsiasi distanza, per vivere il mare senza confini.",
