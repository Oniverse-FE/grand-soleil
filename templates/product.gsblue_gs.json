    "intro_slider_X3xXex": {
      "type": "intro-slider",
      "blocks": {
        "intro_title_anGtHB": {
          "type": "intro-title",
          "settings": {
            "intro-title-text": "Convertible interiors. From day to night, with a touch",
            "small-title": ""
          }
        },
        "intro_text_area_LHpLyg": {
          "type": "intro-text-area",
          "settings": {
            "intro-text-area-title": "",
            "intro-text-area-text": "The interiors of the Grand Soleil BLUE reflect the project’s essential and refined vision: bright spaces, clean lines, and natural, functional materials. The layout, understated yet welcoming, is designed to adapt seamlessly to different moments of the day.\n\nThanks to a modular system of cushions and surfaces, the space effortlessly transitions from the Day configuration—perfect for relaxation, reading or socializing—to the Night setup, comfortably accommodating up to four people without compromising on comfort or style.\n\nEvery detail has been carefully crafted to offer an authentic onboard experience, in perfect balance between functionality and Italian design."
          }
        }
      },
